---
import Layout from '../../layouts/Layout.astro';
import HeroSlider from '../../components/HeroSlider.astro';
import Filosofia from '../../components/Filosofia.astro';
import CatalogoModelos from '../../components/CatalogoModelos.astro';
import FabricacionPropia from '../../components/FabricacionPropia.astro';
import PartnersOficiales from '../../components/PartnersOficiales.astro';
import NoticiasEventos from '../../components/NoticiasEventos.astro';
import CTAContacto from '../../components/CTAContacto.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import NewsCard from '../../components/NewsCard.astro';
import ContactForm from '../../components/ContactForm.astro';
import ModelCard from '../../components/ModelCard.astro';
import { models } from '../../data/models';
import { newsArticles } from '../../data/news';

// Map models to catalog display
const surfModels = models.filter(m => m.line === 'LINEA SURF' || m.slug === '246');
const ftxModels = models.filter(m => m.line === 'LINEA FTX');

const catalogModels = [
  { name: '246 SURF', line: 'LINEA SURF', motorizacion: '250-350hp', eslora: '7.40 m', personas: '14', imageUrl: 'https://placehold.co/320x180/0a0e1a/a8b3c8?text=246+SURF+Illustration', href: '/modelos/246' },
  { name: '246 OB', line: 'LINEA OB', motorizacion: '250-350hp OB', eslora: '7.80 m', personas: '14', imageUrl: 'https://placehold.co/320x180/0a0e1a/a8b3c8?text=246+OB+Illustration', href: '/modelos/246-ob' },
  { name: '206 FTX', line: 'LINEA FTX', motorizacion: '150-200hp', eslora: '6.08 m', personas: '9', imageUrl: 'https://placehold.co/320x180/0a0e1a/a8b3c8?text=206+FTX+Illustration', href: '/modelos/206-ftx' },
];
---

<Layout title="CLASSER — Lanchas de Lujo | Astillero Fuentes" fixedNavbar={true}>
  <!-- SECTION 1: HERO SLIDER -->
  <HeroSlider />

  <!-- FILOSOFÍA -->
  <Filosofia />

  <!-- CATÁLOGO DE MODELOS -->
  <CatalogoModelos />

  <!-- FABRICACIÓN PROPIA -->
  <FabricacionPropia />

  <!-- PARTNERS OFICIALES -->
  <PartnersOficiales />

  <!-- NOTICIAS Y EVENTOS -->
  <NoticiasEventos />

  <!-- CTA CONTACTO -->
  <CTAContacto />
</Layout>

<script is:inline>
  // Drag-to-scroll for catalog
  document.addEventListener('DOMContentLoaded', () => {
    const catalogs = document.querySelectorAll('#catalog-scroll, #models-bar, #news-slider');
    catalogs.forEach(el => {
      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;

      el.addEventListener('mousedown', (e) => {
        isDown = true;
        el.classList.add('drag-scroll');
        startX = e.pageX - el.offsetLeft;
        scrollLeft = el.scrollLeft;
      });

      el.addEventListener('mouseleave', () => { isDown = false; });
      el.addEventListener('mouseup', () => { isDown = false; });
      el.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - el.offsetLeft;
        const walk = (x - startX) * 1.5;
        el.scrollLeft = scrollLeft - walk;
      });
    });
  });
</script>
