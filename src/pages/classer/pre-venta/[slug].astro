---
import Layout from '../../../layouts/Layout.astro';
import SectionLabel from '../../../components/SectionLabel.astro';
import { models, getModelBySlug } from '../../../data/models';

export function getStaticPaths() {
  return models.map(m => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;
const model = getModelBySlug(slug!);

if (!model) {
  return Astro.redirect('/classer');
}
---

<Layout
  title={`${model.name} — CLASSER | Astillero Fuentes`}
  description={model.tagline}
  fixedNavbar={true}
  hideFooter={!!model.preVentaVideoUrl}
>
  <!-- STICKY SECONDARY NAV -->
  <div id="model-subnav" class="fixed top-[72px] left-0 right-0 z-40 bg-bg-white border-b border-black/10 shadow-sm translate-y-[-100%] opacity-0 transition-none" aria-label="Navegación del modelo">
    <div class="container-site py-3 flex items-center justify-between gap-4">
      <!-- Model name -->
      <div class="flex items-center gap-4">
        <span class="font-display font-bold italic text-xl text-text-dark">{model.name.replace('Classer ', '')}</span>
        <div class="w-px h-6 bg-black/20" aria-hidden="true"></div>
      </div>
      <!-- Tabs -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Secciones del modelo">
        {['Especificaciones', 'Exterior', 'Interior', 'Galería'].map(tab => (
          <a href={`#${tab.toLowerCase()}`} class="text-text-muted text-xs font-medium uppercase tracking-wide hover:text-accent-blue transition-colors cursor-pointer">
            {tab}
          </a>
        ))}
      </nav>
      <!-- Brochure CTA -->
      <a
        href="#"
        class="hidden md:inline-flex items-center gap-2 bg-accent-blue hover:bg-accent-cyan text-white text-xs font-medium px-4 py-2 rounded-full transition-colors duration-200 cursor-pointer"
        aria-label="Descargar brochure del modelo"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Descargar brochure
      </a>
    </div>
  </div>

  <!-- HERO: scroll-video si tiene preVentaVideoUrl, fallback normal -->
  {model.preVentaVideoUrl ? (
    <!-- ── SCROLL-DRIVEN VIDEO HERO ─────────────────────────── -->
    <div id="scroll-video-wrapper" style="height: 350vh; position: relative;">
      <!-- sticky canvas que queda fijo mientras scrolleás -->
      <div id="scroll-video-sticky" style="position: sticky; top: 72px; height: calc(100vh - 72px); width: 100%; overflow: hidden; background: #000000;">

        <!-- video (oculto para poder hacer seek) -->
        <video
          id="scroll-video"
          src={model.preVentaVideoUrl}
          muted
          playsinline
          preload="auto"
          webkit-playsinline
          style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; background-color: #000000; display: block; border: none; outline: none;"
        />

        <!-- overlay info: aparece al final del scroll -->
        <div id="scroll-video-info" style="position: absolute; inset: 0; display: flex; align-items: center; pointer-events: none;">

          <!-- izquierda: nombre + specs -->
          <div id="scroll-info-left" style="position: absolute; left: clamp(2rem, 6vw, 8rem); top: 50%; transform: translateY(-50%); opacity: 1;">
            <h1
              id="scroll-title"
              class="font-display font-black italic"
              style="color: #ffffff; font-size: clamp(3rem, 9vw, 8rem); letter-spacing: -0.04em; line-height: 0.9; margin-bottom: 2rem; text-shadow: 0 2px 20px rgba(0,0,0,0.5); opacity: 0; transition: opacity 0.5s ease;"
            >
              {model.name.replace('Classer ', 'CLASSER ')}
            </h1>
            {model.preVentaSpecs && (
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                {model.preVentaSpecs.map((spec, si) => (
                  <div
                    class="scroll-spec-item"
                    data-spec-index={si}
                    style="display: flex; align-items: center; gap: 0.75rem; opacity: 0; transition: opacity 0.5s ease;"
                  >
                    <span style="display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 50%; background: rgba(255,255,255,0.08); flex-shrink: 0;">
                      <img
                        src={
                          spec.icon === 'ruler'            ? '/image/iconos/ESLORA.webp'      :
                          spec.icon === 'arrows-horizontal'? '/image/iconos/MANGA.webp'       :
                          spec.icon === 'users'            ? '/image/iconos/CAPACIDAD.webp'   :
                          spec.icon === 'lightning'        ? '/image/iconos/MOTORIZACION.webp':
                          ''
                        }
                        alt={spec.label}
                        width="22"
                        height="22"
                        style="width: 22px; height: 22px; object-fit: contain; filter: brightness(0) invert(1);"
                      />
                    </span>
                    <div>
                      <div style="color: rgba(255,255,255,0.45); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em;">{spec.label}</div>
                      <div style="color: #ffffff; font-size: 1rem; font-weight: 700; line-height: 1.2;">{spec.value}</div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- derecha: CTA pre-venta -->
          <div id="scroll-info-right" style="position: absolute; right: clamp(16rem, 6vw, 8rem); top: 485px; transform: translateY(-120%); text-align: center; opacity: 0; transition: opacity 0.5s ease;">
            <p
              class="font-display"
              style="color: #ffffff; font-size: clamp(3rem, 6vw, 5.5rem); font-style: italic; font-weight: 800; margin-bottom: 2rem; line-height: 1; letter-spacing: -0.02em;"
            >
              Pre-venta.
            </p>
            <a
              href="https://api.whatsapp.com/send?phone=5493534781206&text=Hola%2C%20me%20interesa%20la%20preventa%20de%20la%20CLASSER%20186.%20%C2%BFMe%20pueden%20contar%20c%C3%B3mo%20funciona%3F"
              id="scroll-video-cta"
              style="display: inline-block; background: #1e90d4; color: #ffffff; font-weight: 800; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 1rem 2.5rem; border-radius: 4px; text-decoration: none; pointer-events: auto; transition: background 200ms ease;"
            >
              INGRESA AHORA
            </a>
          </div>

        </div>

        <!-- scroll hint (desaparece cuando aparece la info) -->
        <div id="scroll-hint" style="position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; opacity: 1; transition: opacity 0.4s ease;">
          <span style="color: rgba(255,255,255,0.4); font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;">Scroll</span>
          <svg width="20" height="20" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>

      </div>
    </div>
  ) : (
    <!-- ── HERO NORMAL ──────────────────────────────────────── -->
    <section class="relative" style="height: 100vh; min-height: 600px;" aria-label={`Presentación ${model.name}`}>
      <img
        src={model.heroUrl}
        alt={model.name}
        width="1440"
        height="700"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" aria-hidden="true"></div>
      <div class="absolute bottom-16 left-0 right-0 container-site">
        <SectionLabel text={model.line} class="mb-4 block" />
        <h1 class="font-display font-black italic text-white leading-none mb-6 md:mb-8" style="font-size: clamp(2.8rem, 12vw, 9rem); letter-spacing: -0.05em;">
          {model.name.replace('Classer ', '')}
        </h1>
        <a
          href="#contacto"
          class="inline-block bg-white text-black font-extrabold text-[0.7rem] md:text-[0.85rem] uppercase tracking-[0.2em] px-10 py-4 hover:bg-opacity-90 transition-all duration-300 shadow-xl"
        >
          COTIZAR AHORA
        </a>
      </div>
    </section>
  )}
  



  

  <!-- CONFIGURADOR -->

</Layout>

<style is:global>
  /* Fondo oscuro para páginas de pre-venta con video */
  body:has(#scroll-video-wrapper) {
    overflow-x: hidden;
  }
  body:has(#scroll-video-wrapper) {
    background-color: #000000 !important;
  }
  body:has(#scroll-video-wrapper) main,
  body:has(#scroll-video-wrapper) .bg-bg-deep,
  body:has(#scroll-video-wrapper) .bg-bg-light,
  body:has(#scroll-video-wrapper) .bg-bg-mid {
    background-color: #000000 !important;
  }
  body:has(#scroll-video-wrapper)::-webkit-scrollbar {
    display: none;
  }
  body:has(#scroll-video-wrapper) {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
</style>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scroll-track-custom {
    position: relative;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    cursor: pointer;
  }

  .scroll-thumb-custom {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 6px;
    background: #ffffff;
    border-radius: 9999px;
    cursor: grab;
    min-width: 60px;
    transition: width 0.1s ease, background 0.2s ease;
  }

  .scroll-thumb-custom:active {
    cursor: grabbing;
    background: rgba(255, 255, 255, 0.8);
  }

  /* ── Diagram number badges ── */
  .diagram-badge {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #1e90d4;
    background: rgba(255,255,255,0.92);
    color: #1e2b50;
    font-size: 0.6rem;
    font-weight: 700;
    font-style: italic;
    font-family: 'Rogue Sans Nova Condensed', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: auto;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    z-index: 10;
  }

  .diagram-badge-list {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #1e90d4;
    color: #1e90d4;
    font-size: 0.6rem;
    font-weight: 700;
    font-style: italic;
    font-family: 'Rogue Sans Nova Condensed', sans-serif;
    flex-shrink: 0;
    line-height: 1;
  }

  /* Estado base de los feature items — texto atenuado */
  .feature-item span {
    color: #9aa0aa; /* grayish, apagado */
    transition: color 0.2s ease, font-weight 0.2s ease;
  }

  .feature-item .diagram-badge-list {
    border-color: #c5cad4;
    color: #c5cad4;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .diagram-badge {
    cursor: pointer; /* agregá esto al existente */
  }

  /* Estado highlighted */
.feature-highlight {
  background-color: rgba(30, 144, 212, 0.06);
  border-radius: 6px;
}

.feature-highlight .diagram-badge-list {
  background-color: #1e90d4;
  color: white;
  border-color: #1e90d4;
}

.feature-highlight span:last-child {
  font-weight: 600;
  color: #1e2b50 !important;
}

/* ── Mobile adaptation: scroll-video overlay ──────────────── */
@media (max-width: 767px) {
  /*
   * En PC: panel izquierdo centrado verticalmente (top:50% + translateY(-50%)),
   *        panel derecho a top:485px + translateY(-120%) a la derecha.
   * En móvil: ambos paneles anclados al fondo, divididos 50/50 horizontalmente.
   * Esto replica la estética PC pero adaptada a pantallas angostas.
   */

  /* Título: reducir de 3-8rem a 1.8-2.8rem para caber en el 50% izquierdo */
  #scroll-title {
    font-size: clamp(1.8rem, 8.5vw, 2.8rem) !important;
    margin-bottom: 0.6rem !important;
    line-height: 0.88 !important;
  }

  /* Panel izquierdo: de "centrado vertical a la izquierda" a "anclado abajo-izquierda" */
  #scroll-info-left {
    top: auto !important;
    bottom: 1.75rem !important;
    left: 1rem !important;
    right: 50% !important;          /* ocupa el 50% izquierdo */
    transform: none !important;
    padding-right: 0.5rem !important;
  }

  /* Reducir gap entre spec items para ahorrar altura */
  .scroll-spec-item {
    gap: 0.4rem !important;
  }

  /* Ícono circular de spec: ligeramente más pequeño */
  .scroll-spec-item > span:first-child {
    width: 1.8rem !important;
    height: 1.8rem !important;
    flex-shrink: 0 !important;
  }

  /* Imágen dentro del ícono */
  .scroll-spec-item > span:first-child img {
    width: 16px !important;
    height: 16px !important;
  }

  /* Valor de spec: ligeramente más pequeño */
  .scroll-spec-item > div > div:last-child {
    font-size: 0.85rem !important;
  }

  /* Panel derecho: de "top:485px + right fijo roto" a "anclado abajo-derecha" */
  #scroll-info-right {
    right: 1rem !important;
    left: 50% !important;           /* ocupa el 50% derecho */
    top: auto !important;
    bottom: 5.5rem !important;      /* sube sobre el botón de WhatsApp (56px + 1.5rem) */
    transform: none !important;
    text-align: center !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: flex-end !important;
  }

  /* "Pre-venta." — reducir de 3-5.5rem a 1.5-2.5rem */
  #scroll-info-right > p {
    font-size: clamp(1.5rem, 6.5vw, 2.5rem) !important;
    margin-bottom: 0.75rem !important;
    line-height: 1 !important;
  }

  /* Botón CTA: padding más compacto */
  #scroll-video-cta {
    padding: 0.65rem 1.1rem !important;
    font-size: 0.65rem !important;
    letter-spacing: 0.12em !important;
    white-space: nowrap !important;
  }

  /* Scroll hint: subir un poco para no tapar el botón WA */
  #scroll-hint {
    bottom: 0.75rem !important;
  }
}
</style>

<script is:inline>
  // ── Scroll-driven video scrubbing ────────────────────────────────
  (function () {
    const wrapper = document.getElementById('scroll-video-wrapper');
    const video   = document.getElementById('scroll-video');
    const info    = document.getElementById('scroll-video-info');
    const hint    = document.getElementById('scroll-hint');
    if (!wrapper || !video) return;

    let duration = 0;
    let rafId = null;
    let lastProgress = -1;

    function onMeta() {
      duration = video.duration || 0;
    }
    video.addEventListener('loadedmetadata', onMeta);
    video.addEventListener('canplay', onMeta); // iOS necesita este evento para acceso al seek
    if (video.readyState >= 1) onMeta();

    // iOS Safari necesita que el video haga autoplay (muted) para desbloquear el seeking.
    // Lo pausamos de inmediato y reiniciamos a t=0 para que el scroll tome el control.
    var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
                (/Macintosh/.test(navigator.userAgent) && navigator.maxTouchPoints > 1);
    if (isIOS) {
      video.play().then(function () {
        video.pause();
        video.currentTime = 0;
      }).catch(function () {});
    }

    function update() {
      rafId = null;
      if (!duration) return;

      const rect      = wrapper.getBoundingClientRect();
      const wrapperH  = wrapper.offsetHeight;
      const viewH     = window.innerHeight;
      // cuánto scrolleamos dentro del wrapper (0 → 1)
      const scrolled  = Math.max(0, -rect.top);
      const maxScroll = wrapperH - viewH;
      const progress  = maxScroll > 0 ? Math.min(1, scrolled / maxScroll) : 0;

      if (Math.abs(progress - lastProgress) < 0.001) return;
      lastProgress = progress;

      // mover el video
      const target = progress * duration;
      if (Math.abs(video.currentTime - target) > 0.05) {
        video.currentTime = target;
      }

      // ── Staggered item-by-item reveal ────────────────────────────
      const titleEl   = document.getElementById('scroll-title');
      const specItems = document.querySelectorAll('.scroll-spec-item');
      const infoLeft  = document.getElementById('scroll-info-left');
      const infoRight = document.getElementById('scroll-info-right');

      // 1. Title: 15% → 30%
      const titleOp = progress >= 0.15 ? Math.min(1, (progress - 0.15) / 0.15) : 0;
      if (titleEl) titleEl.style.opacity = String(titleOp);

      // 2. Each spec item sequentially from 30% to 78%
      //    Each item gets an equal slice of the range
      const specCount = specItems.length;
      const specStart = 0.30;
      const specEnd   = 0.78;
      const perItem   = specCount > 0 ? (specEnd - specStart) / specCount : 0.12;
      specItems.forEach((el, i) => {
        const start = specStart + i * perItem;
        const op    = progress >= start ? Math.min(1, (progress - start) / perItem) : 0;
        el.style.opacity = String(op);
      });

      // Container is always laid out (no own opacity), children control theirs
      if (infoLeft) infoLeft.style.opacity = '1';

      // 3. Right panel: 90% → 100%
      const rightOp = progress >= 0.90 ? Math.min(1, (progress - 0.90) / 0.10) : 0;
      if (infoRight) infoRight.style.opacity = String(rightOp);

      // pointer-events: only active once something is visible
      if (info) info.style.pointerEvents = progress >= 0.78 ? 'auto' : 'none';

      // scroll hint
      if (hint) hint.style.opacity = progress <= 0.15 ? '1' : String(Math.max(0, 1 - (progress - 0.15) / 0.15));
    }

    function onScroll() {
      if (!rafId) rafId = requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update(); // estado inicial
  })();

  // Sticky subnav GSAP behavior
  document.addEventListener('DOMContentLoaded', () => {

    // Diagram badge hover → highlight feature item
    document.querySelectorAll('.diagram-badge[data-index]').forEach(badge => {
      const idx = badge.dataset.index;
      const target = document.querySelector(`.feature-item[data-index="${idx}"]`);
      if (!target) return;

      badge.addEventListener('mouseenter', () => {
        target.classList.add('feature-highlight');
      });
      badge.addEventListener('mouseleave', () => {
        target.classList.remove('feature-highlight');
      });
    });


    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      const subnav = document.getElementById('model-subnav');
      if (subnav) {
        ScrollTrigger.create({
          trigger: '#especificaciones',
          start: 'top top+=72',
          onEnter: () => {
            gsap.to(subnav, { y: 0, opacity: 1, duration: 0.4, ease: 'power2.out' });
          },
          onLeaveBack: () => {
            gsap.to(subnav, { y: '-100%', opacity: 0, duration: 0.3, ease: 'power2.in' });
          },
        });
      }

      // Reveal animations
      document.querySelectorAll('.reveal').forEach(el => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 82%' },
          }
        );
      });
    }

    // Custom Scroll Logic
    function setupCustomScroll(containerId, trackId, thumbId) {
      const container = document.getElementById(containerId);
      const track = document.getElementById(trackId);
      const thumb = document.getElementById(thumbId);
      if (!container || !track || !thumb) return;

      function updateThumb() {
        const trackWidth = track.offsetWidth;
        const totalWidth = container.scrollWidth;
        const visibleWidth = container.clientWidth;
        const maxScroll = totalWidth - visibleWidth;
        
        if (maxScroll <= 0) {
          track.parentElement.style.display = 'none';
          return;
        }
        
        track.parentElement.style.display = 'block';
        const thumbWidth = Math.max((visibleWidth / totalWidth) * trackWidth, 80);
        thumb.style.width = thumbWidth + 'px';
        const thumbLeft = (container.scrollLeft / maxScroll) * (trackWidth - thumbWidth);
        thumb.style.left = thumbLeft + 'px';
      }

      container.addEventListener('scroll', updateThumb, { passive: true });
      window.addEventListener('resize', updateThumb, { passive: true });
      updateThumb();

      // Content Drag
      let isDown = false;
      let startX;
      let scrollLeftPos;

      container.addEventListener('mousedown', (e) => {
        isDown = true;
        container.classList.add('active');
        startX = e.pageX - container.offsetLeft;
        scrollLeftPos = container.scrollLeft;
      });
      document.addEventListener('mouseup', () => {
        isDown = false;
        container.classList.remove('active');
      });
      container.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - container.offsetLeft;
        const walk = (x - startX) * 2;
        container.scrollLeft = scrollLeftPos - walk;
      });

      // Thumb Drag
      let isDraggingThumb = false;
      let thumbStartX;
      let thumbStartScrollLeft;

      thumb.addEventListener('mousedown', (e) => {
        isDraggingThumb = true;
        thumbStartX = e.pageX;
        thumbStartScrollLeft = container.scrollLeft;
        document.body.style.userSelect = 'none';
        e.stopPropagation();
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDraggingThumb) return;
        const deltaX = e.pageX - thumbStartX;
        const trackWidth = track.offsetWidth;
        const thumbWidth = thumb.offsetWidth;
        const maxThumbTravel = trackWidth - thumbWidth;
        const maxScroll = container.scrollWidth - container.clientWidth;
        if (maxThumbTravel > 0) {
          container.scrollLeft = thumbStartScrollLeft + (deltaX / maxThumbTravel) * maxScroll;
        }
      });

      document.addEventListener('mouseup', () => {
        isDraggingThumb = false;
        document.body.style.userSelect = '';
      });
    }

    setupCustomScroll('interior-scroll', 'interior-track', 'interior-thumb');
    setupCustomScroll('galeria-scroll', 'galeria-track', 'galeria-thumb');

    // ── Horizontal Lazy Loading ──────────────────────────────────────
    // Watches placeholder divs inside each carousel and swaps them to
    // real <img> elements as they scroll into view
    function setupHorizontalLazyLoad(containerId) {
      const container = document.getElementById(containerId);
      if (!container) return;

      const placeholders = container.querySelectorAll('.lazy-carousel-img');
      if (!placeholders.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const placeholder = entry.target;
          const src = placeholder.dataset.src;
          if (!src) return;

          const img = document.createElement('img');
          img.src = src;
          img.alt = placeholder.dataset.alt || '';
          img.width = parseInt(placeholder.dataset.w || '560');
          img.height = parseInt(placeholder.dataset.h || '380');
          img.className = 'w-full h-full object-cover hover:scale-105 transition-transform duration-500';
          img.loading = 'lazy';
          img.style.opacity = '0';
          img.style.transition = 'opacity 0.4s ease';
          img.onload = () => { img.style.opacity = '1'; };

          placeholder.replaceWith(img);
          observer.unobserve(placeholder);
        });
      }, {
        root: container,         // observe within the carousel container
        rootMargin: '0px 300px 0px 0px', // preload 300px before visible
        threshold: 0.01,
      });

      placeholders.forEach(el => observer.observe(el));
    }

    setupHorizontalLazyLoad('interior-scroll');
    setupHorizontalLazyLoad('galeria-scroll');
  });
