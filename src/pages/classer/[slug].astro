---
import Layout from '../../layouts/Layout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import SpecGrid from '../../components/SpecGrid.astro';
import GalleryCollage from '../../components/GalleryCollage.astro';
import VersionsTable from '../../components/VersionsTable.astro';
import ModelMiniMenu from '../../components/ModelMiniMenu.astro';
import { models, getModelBySlug } from '../../data/models';

export function getStaticPaths() {
  return models.map(m => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;
const model = getModelBySlug(slug!);

if (!model) {
  return Astro.redirect('/classer');
}
---

<Layout
  title={`${model.name} — CLASSER | Astillero Fuentes`}
  description={model.tagline}
  fixedNavbar={true}
>
  <!-- STICKY SECONDARY NAV -->
  <div id="model-subnav" class="fixed top-[72px] left-0 right-0 z-40 bg-bg-white border-b border-black/10 shadow-sm translate-y-[-100%] opacity-0 transition-none" aria-label="Navegación del modelo">
    <div class="container-site py-3 flex items-center justify-between gap-4">
      <!-- Model name -->
      <div class="flex items-center gap-4">
        <span class="font-display font-bold italic text-xl text-text-dark">{model.name.replace('Classer ', '')}</span>
        <div class="w-px h-6 bg-black/20" aria-hidden="true"></div>
      </div>
      <!-- Tabs -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Secciones del modelo">
        {['Especificaciones', 'Exterior', 'Interior', 'Galería'].map(tab => (
          <a href={`#${tab.toLowerCase()}`} class="text-text-muted text-xs font-medium uppercase tracking-wide hover:text-accent-blue transition-colors cursor-pointer">
            {tab}
          </a>
        ))}
      </nav>
      <!-- Brochure CTA -->
      <a
        href="#"
        class="hidden md:inline-flex items-center gap-2 bg-accent-blue hover:bg-accent-cyan text-white text-xs font-medium px-4 py-2 rounded-full transition-colors duration-200 cursor-pointer"
        aria-label="Descargar brochure del modelo"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Descargar brochure
      </a>
    </div>
  </div>

  <!-- HERO -->
  <section class="relative" style="height: 100vh; min-height: 600px;" aria-label={`Presentación ${model.name}`}>
    <img
      src={model.heroUrl}
      alt={model.name}
      width="1440"
      height="700"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" aria-hidden="true"></div>
    <div class="absolute bottom-16 left-0 right-0 container-site">
      <SectionLabel text={model.line} class="mb-4 block" />
      <h1 class="font-display font-black italic text-white leading-none mb-6 md:mb-8" style="font-size: clamp(2.8rem, 12vw, 9rem); letter-spacing: -0.05em;">
        {model.name.replace('Classer ', '')}
      </h1>
      
      <a 
        href="#contacto" 
        class="inline-block bg-white text-black font-extrabold text-[0.7rem] md:text-[0.85rem] uppercase tracking-[0.2em] px-10 py-4 hover:bg-opacity-90 transition-all duration-300 shadow-xl"
      >
        COTIZAR AHORA
      </a>
    </div>
  </section>
  <!-- SPECS GRID -->
  <section id="especificaciones" class="bg-bg-deep py-20" aria-label="Especificaciones técnicas">
    <div class="container-site mb-12">
      <ModelMiniMenu modelName={model.name.replace('Classer ', '')} brochure={model.brochure} />
    </div>
    
    <div class="container-site px-4">
      <SpecGrid specs={model.specs} dark={true} />
    </div>


  </section>

  <!-- EXTERIOR DIAGRAM -->
  {model.exteriorFeatures.length > 0 && (
    <section id="exterior" class="py-20 bg-bg-light" aria-label="Características exteriores">
      <div class="container-site">

        {model.technicalDiagramUrl ? (
          <!-- Two-column layout: diagram left, list right -->
          <div class="flex flex-col lg:flex-row items-center gap-8 reveal">

            <!-- Diagram with optional number overlays -->
            <div class="lg:w-[60%] flex-shrink-0 relative">
              <img
                src={model.technicalDiagramUrl}
                alt={`Diagrama técnico ${model.name}`}
                class="w-full h-auto block"
                loading="lazy"
              />
              {model.featurePoints && model.featurePoints.map((pt, i) => (
                <span
                  class="diagram-badge"
                  style={`left: ${pt.x}%; top: ${pt.y}%;`}
                  aria-hidden="true"
                >
                  {i + 1}
                </span>
              ))}
            </div>

            <!-- Feature list -->
            <div class="lg:w-[40%] flex flex-col gap-0">
              {model.exteriorFeatures.map((feature, i) => (
                <div class="flex items-start gap-3 py-3 border-b border-black/10 group">
                  <span class="diagram-badge-list flex-shrink-0">{i + 1}</span>
                  <span class="text-text-dark text-sm leading-snug">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        ) : (
          <!-- Fallback: no diagram, just the grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 max-w-3xl mx-auto reveal">
            {model.exteriorFeatures.map((feature, i) => (
              <div class="flex items-center gap-3 py-2 border-b border-black/8">
                <span class="text-accent-blue font-bold text-sm flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-text-dark text-sm">{feature}</span>
              </div>
            ))}
          </div>
        )}

      </div>
    </section>
  )}

  <!-- INTERIOR GALLERY -->
  {model.interiorImages.length > 0 && (
    <section id="interior" class="py-20 bg-bg-deep overflow-hidden" aria-label="Galería interior">
      <!-- Title centered -->
      <div class="container-site">
        <div class="text-center mb-10 reveal">
          <h2 class="font-display font-bold italic text-3xl md:text-4xl text-white mb-3">Interior</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Un interior pensado para el confort sin comprometer el rendimiento.
          </p>
        </div>
      </div>

      <!-- Carousel full width -->
      <div id="interior-scroll" class="flex gap-2 h-80 md:h-[480px] reveal overflow-x-auto no-scrollbar cursor-grab active:cursor-grabbing w-full px-[26px]">
        {model.interiorImages.map((img, i) => (
          <div class={`overflow-hidden flex-shrink-0 ${i === 0 ? 'flex-[2]' : 'flex-[1.5]'} min-w-[300px] md:min-w-[500px]`}>
            {i < 3 ? (
              <img
                src={img.url}
                alt={`Interior ${model.name} — imagen ${i + 1}`}
                width={img.w}
                height={img.h}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'low'}
              />
            ) : (
              <div
                class="lazy-carousel-img w-full h-full bg-bg-mid"
                data-src={img.url}
                data-alt={`Interior ${model.name} — imagen ${i + 1}`}
                data-w={img.w}
                data-h={img.h}
              />
            )}
          </div>
        ))}
      </div>

      <!-- Progress Bar centered -->
      <div class="container-site">
        <div class="mx-auto mt-10 px-8" style="max-width: 600px;">
          <div id="interior-track" class="scroll-track-custom" role="scrollbar">
            <div id="interior-thumb" class="scroll-thumb-custom"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- EXTERIOR GALLERY -->
  {model.exteriorImages.length > 0 && (
    <section id="galeria" class="py-20 bg-bg-mid overflow-hidden" aria-label="Galería exterior">
      <!-- Title centered -->
      <div class="container-site">
        <div class="text-center mb-10 reveal">
          <h2 class="font-display font-bold italic text-3xl md:text-4xl text-white mb-3">Exterior</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Líneas que cortan el agua con elegancia y propósito.
          </p>
        </div>
      </div>

      <!-- Carousel full width -->
      <div id="galeria-scroll" class="flex gap-2 h-80 md:h-[480px] reveal overflow-x-auto no-scrollbar cursor-grab active:cursor-grabbing w-full px-[26px]">
        {model.exteriorImages.map((img, i) => (
          <div class={`overflow-hidden flex-shrink-0 ${i === 0 ? 'flex-[2]' : 'flex-[1.5]'} min-w-[300px] md:min-w-[500px]`}>
            {i < 3 ? (
              <img
                src={img.url}
                alt={`Exterior ${model.name} — imagen ${i + 1}`}
                width={img.w}
                height={img.h}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'low'}
              />
            ) : (
              <div
                class="lazy-carousel-img w-full h-full bg-bg-mid"
                data-src={img.url}
                data-alt={`Exterior ${model.name} — imagen ${i + 1}`}
                data-w={img.w}
                data-h={img.h}
              />
            )}
          </div>
        ))}
      </div>

      <!-- Progress Bar centered -->
      <div class="container-site">
        <div class="mx-auto mt-10 px-8" style="max-width: 600px;">
          <div id="galeria-track" class="scroll-track-custom" role="scrollbar">
            <div id="galeria-thumb" class="scroll-thumb-custom"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- VERSIONS TABLE -->
  {model.versions.length > 0 && (
    <VersionsTable
      modelName={model.name.replace('Classer ', '')}
      features={model.versions[0].features}
      silhouetteTechnicalUrl={model.silhouetteTechnicalUrl}
      diagramUrl="https://placehold.co/700x480/f4f4f2/6b7a99?text=Technical+Diagram"
    />
  )}

  <!-- CONFIGURADOR -->

</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scroll-track-custom {
    position: relative;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    cursor: pointer;
  }

  .scroll-thumb-custom {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 6px;
    background: #ffffff;
    border-radius: 9999px;
    cursor: grab;
    min-width: 60px;
    transition: width 0.1s ease, background 0.2s ease;
  }

  .scroll-thumb-custom:active {
    cursor: grabbing;
    background: rgba(255, 255, 255, 0.8);
  }

  /* ── Diagram number badges ── */
  .diagram-badge {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #1e90d4;
    background: rgba(255,255,255,0.92);
    color: #1e2b50;
    font-size: 0.6rem;
    font-weight: 700;
    font-style: italic;
    font-family: 'Rogue Sans Nova Condensed', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    z-index: 10;
  }

  .diagram-badge-list {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #1e90d4;
    color: #1e90d4;
    font-size: 0.6rem;
    font-weight: 700;
    font-style: italic;
    font-family: 'Rogue Sans Nova Condensed', sans-serif;
    flex-shrink: 0;
    line-height: 1;
  }
</style>

<script is:inline>
  // Sticky subnav GSAP behavior
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      const subnav = document.getElementById('model-subnav');
      if (subnav) {
        ScrollTrigger.create({
          trigger: '#especificaciones',
          start: 'top top+=72',
          onEnter: () => {
            gsap.to(subnav, { y: 0, opacity: 1, duration: 0.4, ease: 'power2.out' });
          },
          onLeaveBack: () => {
            gsap.to(subnav, { y: '-100%', opacity: 0, duration: 0.3, ease: 'power2.in' });
          },
        });
      }

      // Reveal animations
      document.querySelectorAll('.reveal').forEach(el => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 82%' },
          }
        );
      });
    }

    // Custom Scroll Logic
    function setupCustomScroll(containerId, trackId, thumbId) {
      const container = document.getElementById(containerId);
      const track = document.getElementById(trackId);
      const thumb = document.getElementById(thumbId);
      if (!container || !track || !thumb) return;

      function updateThumb() {
        const trackWidth = track.offsetWidth;
        const totalWidth = container.scrollWidth;
        const visibleWidth = container.clientWidth;
        const maxScroll = totalWidth - visibleWidth;
        
        if (maxScroll <= 0) {
          track.parentElement.style.display = 'none';
          return;
        }
        
        track.parentElement.style.display = 'block';
        const thumbWidth = Math.max((visibleWidth / totalWidth) * trackWidth, 80);
        thumb.style.width = thumbWidth + 'px';
        const thumbLeft = (container.scrollLeft / maxScroll) * (trackWidth - thumbWidth);
        thumb.style.left = thumbLeft + 'px';
      }

      container.addEventListener('scroll', updateThumb, { passive: true });
      window.addEventListener('resize', updateThumb, { passive: true });
      updateThumb();

      // Content Drag
      let isDown = false;
      let startX;
      let scrollLeftPos;

      container.addEventListener('mousedown', (e) => {
        isDown = true;
        container.classList.add('active');
        startX = e.pageX - container.offsetLeft;
        scrollLeftPos = container.scrollLeft;
      });
      document.addEventListener('mouseup', () => {
        isDown = false;
        container.classList.remove('active');
      });
      container.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - container.offsetLeft;
        const walk = (x - startX) * 2;
        container.scrollLeft = scrollLeftPos - walk;
      });

      // Thumb Drag
      let isDraggingThumb = false;
      let thumbStartX;
      let thumbStartScrollLeft;

      thumb.addEventListener('mousedown', (e) => {
        isDraggingThumb = true;
        thumbStartX = e.pageX;
        thumbStartScrollLeft = container.scrollLeft;
        document.body.style.userSelect = 'none';
        e.stopPropagation();
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDraggingThumb) return;
        const deltaX = e.pageX - thumbStartX;
        const trackWidth = track.offsetWidth;
        const thumbWidth = thumb.offsetWidth;
        const maxThumbTravel = trackWidth - thumbWidth;
        const maxScroll = container.scrollWidth - container.clientWidth;
        if (maxThumbTravel > 0) {
          container.scrollLeft = thumbStartScrollLeft + (deltaX / maxThumbTravel) * maxScroll;
        }
      });

      document.addEventListener('mouseup', () => {
        isDraggingThumb = false;
        document.body.style.userSelect = '';
      });
    }

    setupCustomScroll('interior-scroll', 'interior-track', 'interior-thumb');
    setupCustomScroll('galeria-scroll', 'galeria-track', 'galeria-thumb');

    // ── Horizontal Lazy Loading ──────────────────────────────────────
    // Watches placeholder divs inside each carousel and swaps them to
    // real <img> elements as they scroll into view
    function setupHorizontalLazyLoad(containerId) {
      const container = document.getElementById(containerId);
      if (!container) return;

      const placeholders = container.querySelectorAll('.lazy-carousel-img');
      if (!placeholders.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const placeholder = entry.target;
          const src = placeholder.dataset.src;
          if (!src) return;

          const img = document.createElement('img');
          img.src = src;
          img.alt = placeholder.dataset.alt || '';
          img.width = parseInt(placeholder.dataset.w || '560');
          img.height = parseInt(placeholder.dataset.h || '380');
          img.className = 'w-full h-full object-cover hover:scale-105 transition-transform duration-500';
          img.loading = 'lazy';
          img.style.opacity = '0';
          img.style.transition = 'opacity 0.4s ease';
          img.onload = () => { img.style.opacity = '1'; };

          placeholder.replaceWith(img);
          observer.unobserve(placeholder);
        });
      }, {
        root: container,         // observe within the carousel container
        rootMargin: '0px 300px 0px 0px', // preload 300px before visible
        threshold: 0.01,
      });

      placeholders.forEach(el => observer.observe(el));
    }

    setupHorizontalLazyLoad('interior-scroll');
    setupHorizontalLazyLoad('galeria-scroll');
  });
</script>
