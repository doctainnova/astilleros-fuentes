---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Astillero Fuentes — Bienvenidos" 
  hideNavbar={true} 
  hideFooter={true} 
  noScroll={true}
>
  <div class="fixed inset-0 bg-[#1b1936] flex flex-col items-center justify-center p-8 md:p-12 overflow-hidden">
    
    <!-- 1. TOP BRAND HEADER -->
    <header class="w-full max-w-[1400px] flex items-center justify-center gap-8 md:gap-20 mb-16 md:mb-24 px-8">
      <!-- Brand Name -->
      <span class="hidden md:block text-white italic text-3xl md:text-5xl whitespace-nowrap" style="font-family: Georgia, 'Times New Roman', serif; font-weight: 400;">
        Astillero Fuentes
      </span>
      
      <!-- Shield Logo -->
      <div class="flex-shrink-0">
        <svg
          width="70"
          height="76"
          viewBox="0 0 64 70"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M4 4 L60 4 L60 40 C60 56 32 68 32 68 C32 68 4 56 4 40 Z"
            stroke="white"
            stroke-width="1.8"
            stroke-linejoin="round"
            fill="none"
          />
          <text
            x="32"
            y="31"
            text-anchor="middle"
            dominant-baseline="middle"
            font-family="Georgia, 'Times New Roman', serif"
            font-size="24"
            font-weight="700"
            fill="white"
          >F</text>
          <path d="M13 44 Q19 40 25 44 Q31 48 37 44 Q43 40 51 44" stroke="white" stroke-width="1.5" fill="none" opacity="0.9"/>
          <path d="M13 51 Q19 47 25 51 Q31 55 37 51 Q43 47 51 51" stroke="white" stroke-width="1.5" fill="none" opacity="0.6"/>
          <path d="M15 58 Q21 54 27 58 Q33 62 39 58 Q45 54 50 58" stroke="white" stroke-width="1.5" fill="none" opacity="0.4"/>
        </svg>
      </div>

      <!-- Tagline -->
      <span class="text-white font-light text-base md:text-xl whitespace-nowrap opacity-80" style="letter-spacing: 0.02em;">
        Más de 50 años navegando juntos.
      </span>
    </header>

    <!-- 2. THREE CARDS GRID -->
    <div class="w-full max-w-[1550px] grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 px-10">
      
      <!-- CARD 1: CLASSER -->
      <div class="flex flex-col gap-8 items-center">
        <a 
          href="/classer" 
          class="w-full aspect-square bg-[#03050a] flex flex-col items-center justify-center gap-6 transition-all duration-500 hover:scale-[1.03] hover:bg-[#070a14] border border-white/5 shadow-2xl active:scale-[0.98]"
        >
          <!-- Swoosh SVG -->
          <svg width="80" height="40" viewBox="0 0 50 26" fill="none" class="opacity-90">
            <path d="M2 24 L25 2 L48 24" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-display font-bold text-white text-4xl md:text-6xl uppercase tracking-[0.2em] leading-none">CLASSER</span>
        </a>
        <p class="text-white font-light text-center text-lg md:text-xl max-w-[300px] leading-relaxed opacity-90">
          Embarcaciones deportivas de lujo.
        </p>
      </div>

      <!-- CARD 2: TM -->
      <div class="flex flex-col gap-8 items-center">
        <div 
          class="w-full aspect-square bg-[#03050a] flex flex-col items-center justify-center opacity-70 border border-white/5"
        >
          <span class="text-white italic font-bold leading-none select-none" style="font-family: Georgia, serif; font-size: 8rem; letter-spacing: -0.07em;">
            TM
          </span>
        </div>
        <p class="text-white font-light text-center text-lg md:text-xl max-w-[300px] leading-relaxed opacity-90">
          Diseños 1 de 1 y restauraciones únicas.
        </p>
      </div>

      <!-- CARD 3: FTS -->
      <div class="flex flex-col gap-8 items-center">
        <div 
          class="w-full aspect-square bg-[#03050a] flex flex-col items-center justify-center gap-2 opacity-70 border border-white/5"
        >
          <span class="font-display font-bold text-white leading-none tracking-tight" style="font-size: 6rem;">FTS</span>
          <span class="text-white/50 text-xs md:text-sm uppercase tracking-[0.5em] font-medium">ADVENTURE</span>
        </div>
        <p class="text-white font-light text-center text-lg md:text-xl max-w-[300px] leading-relaxed opacity-90">
          Service a tu lancha y accesorios para el agua.
        </p>
      </div>

    </div>

  </div>
</Layout>

<style>
  /* Title font import if not global */
  @font-face {
    font-family: 'Barlow Condensed';
    font-style: normal;
    font-weight: 700;
    src: url(https://fonts.gstatic.com/s/barlowcondensed/v12/HTakL3o-R1sy6ayUf2-r_R3UuHshnE_770Z_v9v6.woff2) format('woff2');
  }
  .font-display {
    font-family: 'Barlow Condensed', sans-serif;
  }
</style>
