---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { models } from '../data/models';
---

<Layout
  title="Contacto — CLASSER | Astillero Fuentes"
  fixedNavbar={true}
  description="Contactá a un asesor Classer. Estamos en Villa María, Córdoba, Argentina."
>
  <section class="min-h-screen pt-24 pb-0 bg-bg-white" aria-label="Contacto">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">

      <!-- LEFT: FORM -->
      <div class="flex flex-col justify-start px-5 md:px-16 lg:px-24 pt-10 pb-16 bg-bg-white">
        <div class="max-w-md w-full">
          <div class="reveal mb-8">
            <SectionLabel text="CONTACTO" class="mb-3 block" />
            <h1 class="font-display font-bold text-4xl md:text-5xl text-text-dark leading-tight mb-3">
              Empezá tu viaje
            </h1>
            <p class="text-text-muted text-sm leading-relaxed">
              Nuestro equipo de expertos está a tu disposición para asesorarte sin compromiso.
              Completá el formulario y nos ponemos en contacto a la brevedad.
            </p>
          </div>

          <form class="reveal flex flex-col gap-5" aria-label="Formulario de contacto" novalidate>
            <div class="flex flex-col gap-1">
              <label for="c-nombre" class="text-text-muted text-xs uppercase tracking-wide font-barlow">Nombre completo</label>
              <input
                id="c-nombre"
                name="nombre"
                type="text"
                placeholder="Juan Pérez"
                autocomplete="name"
                required
                class="border-b border-black/20 focus:border-accent-blue outline-none bg-transparent text-text-dark placeholder-text-muted py-2.5 text-sm transition-colors"
                aria-required="true"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="c-email" class="text-text-muted text-xs uppercase tracking-wide font-barlow">Correo electrónico</label>
              <input
                id="c-email"
                name="email"
                type="email"
                placeholder="juanperez@gmail.com"
                autocomplete="email"
                required
                class="border-b border-black/20 focus:border-accent-blue outline-none bg-transparent text-text-dark placeholder-text-muted py-2.5 text-sm transition-colors"
                aria-required="true"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="c-interes" class="text-text-muted text-xs uppercase tracking-wide font-barlow">Interés</label>
              <select
                id="c-interes"
                name="interes"
                class="border-b border-black/20 focus:border-accent-blue outline-none bg-transparent text-text-dark py-2.5 text-sm transition-colors cursor-pointer appearance-none"
              >
                <option value="">Seleccionar modelo...</option>
                {models.map(m => (
                  <option value={m.slug}>{m.name}</option>
                ))}
                <option value="general">Consulta general</option>
              </select>
            </div>
            <div class="flex flex-col gap-1">
              <label for="c-mensaje" class="text-text-muted text-xs uppercase tracking-wide font-barlow">Mensaje adicional</label>
              <textarea
                id="c-mensaje"
                name="mensaje"
                placeholder="Contanos más sobre vos..."
                rows="4"
                class="border-b border-black/20 focus:border-accent-blue outline-none bg-transparent text-text-dark placeholder-text-muted py-2.5 text-sm transition-colors resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="mt-2 w-full bg-text-dark hover:bg-bg-mid text-white font-barlow font-semibold uppercase tracking-[0.15em] text-sm py-4 rounded transition-colors duration-200 cursor-pointer"
            >
              ENVIAR SOLICITUD
            </button>
            <p class="text-text-muted text-[0.65rem] text-center leading-relaxed">
              Al enviar aceptás nuestra política de privacidad. Tus datos son tratados con confidencialidad.
            </p>
          </form>

          <!-- Contact info -->
          <div class="reveal mt-12 pt-8 border-t border-black/10 flex flex-col gap-3">
            <a href="https://api.whatsapp.com/send/?phone=5493534781206&text=Hola%21+Necesito+hablar+con+el+%C3%A1rea+de+ventas.&type=phone_number&app_absent=0" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group cursor-pointer">
              <div class="w-9 h-9 border border-accent-blue/40 rounded flex items-center justify-center group-hover:bg-accent-blue/10 transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#1e90d4" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.533 5.849L0 24l6.335-1.509A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894c-1.943 0-3.747-.536-5.289-1.467l-.379-.225-3.756.895.952-3.655-.246-.389A9.862 9.862 0 012.105 12C2.105 6.529 6.529 2.105 12 2.105S21.895 6.529 21.895 12 17.471 21.894 12 21.894z"/></svg>
              </div>
              <span class="text-text-dark text-sm group-hover:text-accent-blue transition-colors">+54 9 353 478-1206</span>
            </a>
            <a href="https://www.instagram.com/classer.oficial/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group cursor-pointer">
              <div class="w-9 h-9 border border-accent-blue/40 rounded flex items-center justify-center group-hover:bg-accent-blue/10 transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1e90d4" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="#1e90d4" stroke="none"/></svg>
              </div>
              <span class="text-text-dark text-sm group-hover:text-accent-blue transition-colors">@classer.oficial</span>
            </a>
          </div>
        </div>
      </div>

      <!-- RIGHT: MAP + PHOTO -->
      <div class="flex flex-col bg-bg-light">
        <div class="flex flex-col justify-center px-5 md:px-12 py-10 md:py-16 flex-1">
          <div class="reveal mb-8">
            <h2 class="font-display font-bold text-3xl text-text-dark mb-2">Vení a visitarnos</h2>
            <p class="text-text-muted text-sm">Estamos ubicados en Villa María, Córdoba.</p>
          </div>

          <!-- Map -->
          <div class="reveal map-wrap mb-6">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3370.0588631201704!2d-63.232938523475596!3d-32.363966442699294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95cc42dbdbc420ab%3A0xfb970bdf8066d2cb!2sAstillero%20Fuentes!5e0!3m2!1ses-419!2sar!4v1774126052372!5m2!1ses-419!2sar"
              class="map-iframe"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación Astillero Fuentes"
            ></iframe>
          </div>

          <!-- Address card -->
          <div class="reveal bg-white rounded-lg p-5 shadow-sm border border-black/5 mb-6">
            <p class="text-text-muted text-xs uppercase tracking-wide font-barlow mb-2">Dirección</p>
            <p class="text-text-dark text-sm font-medium">Villa María, Córdoba, Argentina</p>
            <p class="text-text-muted text-xs mt-1">Horario: Lunes a Viernes 9:00–18:00 | Sábados 9:00–13:00</p>
          </div>

          
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* Contenedor responsive del mapa */
  .map-wrap {
    position: relative;
    width: 100%;
    height: 220px;
    border-radius: 10px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .map-wrap { height: 340px; }
  }

  @media (min-width: 1024px) {
    .map-wrap { height: 400px; }
  }

  .map-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('form[aria-label="Formulario de contacto"]');
  const btn  = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  // Crear el elemento de feedback dinámicamente
  const status = document.createElement('p');
  status.className = 'text-center text-sm font-medium mt-1 hidden';
  btn?.insertAdjacentElement('afterend', status);

  const showStatus = (msg: string, isError: boolean) => {
    status.textContent = msg;
    status.className = `text-center text-sm font-medium mt-1 ${isError ? 'text-red-500' : 'text-green-600'}`;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const interestSelect = form.querySelector<HTMLSelectElement>('#c-interes');
    const interestText   = interestSelect?.selectedOptions[0]?.text ?? '';

    const payload = {
      full_name: (data.get('nombre') as string)?.trim(),
      email:     (data.get('email')  as string)?.trim(),
      interest:  interestText,
      message:   (data.get('mensaje') as string)?.trim() || '',
    };

    if (!payload.full_name || !payload.email) {
      showStatus('Por favor completá nombre y correo.', true);
      return;
    }

    if (btn) {
      btn.disabled = true;
      btn.textContent = 'ENVIANDO...';
    }
    status.className = 'hidden';

    try {
      const res = await fetch('https://darkturquoise-rabbit-399304.hostingersite.com/api/contact.php', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      showStatus('¡Mensaje enviado! Nos comunicaremos pronto.', false);
      form.reset();
    } catch (err) {
      showStatus('Hubo un error al enviar. Intentá de nuevo o escribinos por WhatsApp.', true);
      console.error('[contacto]', err);
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'ENVIAR SOLICITUD';
      }
    }
  });
</script>
