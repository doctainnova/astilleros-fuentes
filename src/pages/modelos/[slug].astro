---
import Layout from '../../layouts/Layout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import SpecGrid from '../../components/SpecGrid.astro';
import GalleryCollage from '../../components/GalleryCollage.astro';
import VersionsTable from '../../components/VersionsTable.astro';
import { models, getModelBySlug } from '../../data/models';

export function getStaticPaths() {
  return models.map(m => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;
const model = getModelBySlug(slug!);

if (!model) {
  return Astro.redirect('/modelos');
}
---

<Layout
  title={`${model.name} — CLASSER | Astillero Fuentes`}
  description={model.tagline}
  heroImageUrl={model.heroUrl}
>
  <!-- STICKY SECONDARY NAV -->
  <div id="model-subnav" class="fixed top-[72px] left-0 right-0 z-40 bg-bg-white border-b border-black/10 shadow-sm translate-y-[-100%] opacity-0 transition-none" aria-label="Navegación del modelo">
    <div class="container-site py-3 flex items-center justify-between gap-4">
      <!-- Model name -->
      <div class="flex items-center gap-4">
        <span class="font-display font-bold italic text-xl text-text-dark">{model.name.replace('Classer ', '')}</span>
        <div class="w-px h-6 bg-black/20" aria-hidden="true"></div>
      </div>
      <!-- Tabs -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Secciones del modelo">
        {['Especificaciones', 'Exterior', 'Interior', 'Galería'].map(tab => (
          <a href={`#${tab.toLowerCase()}`} class="text-text-muted text-xs font-medium uppercase tracking-wide hover:text-accent-blue transition-colors cursor-pointer">
            {tab}
          </a>
        ))}
      </nav>
      <!-- Brochure CTA -->
      <a
        href="#"
        class="hidden md:inline-flex items-center gap-2 bg-accent-blue hover:bg-accent-cyan text-white text-xs font-medium px-4 py-2 rounded-full transition-colors duration-200 cursor-pointer"
        aria-label="Descargar brochure del modelo"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Descargar brochure
      </a>
    </div>
  </div>

  <!-- HERO -->
  <section class="relative" style="height: 70vh; min-height: 500px;" aria-label={`Presentación ${model.name}`}>
    <img
      src={model.heroUrl}
      alt={model.name}
      width="1440"
      height="700"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" aria-hidden="true"></div>
    <div class="absolute bottom-12 left-0 right-0 container-site">
      <SectionLabel text={model.line} class="mb-2 block" />
      <h1 class="font-display font-bold italic text-white leading-none" style="font-size: clamp(3rem, 8vw, 6rem);">
        {model.name.replace('Classer ', '')}
      </h1>
    </div>
  </section>

  <!-- SPECS GRID -->
  <section id="especificaciones" class="bg-bg-deep py-0" aria-label="Especificaciones técnicas">
    <SpecGrid specs={model.specs} dark={true} />


  </section>

  <!-- EXTERIOR DIAGRAM -->
  {model.exteriorFeatures.length > 0 && (
    <section id="exterior" class="py-20 bg-bg-light" aria-label="Características exteriores">
      <div class="container-site">


        <!-- Technical diagram -->
        <div class="reveal mb-10">
          <img
            src="https://placehold.co/700x480/f4f4f2/6b7a99?text=Technical+Diagram+206+FTX"
            alt={`Diagrama técnico ${model.name}`}
            width="700"
            height="480"
            class="w-full max-w-3xl mx-auto rounded-lg block"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Feature grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 max-w-3xl mx-auto reveal">
          {model.exteriorFeatures.map((feature, i) => (
            <div class="flex items-center gap-3 py-2 border-b border-black/8">
              <span class="text-accent-blue font-bold text-sm flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-text-dark text-sm">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- INTERIOR GALLERY -->
  {model.interiorImages.length > 0 && (
    <section id="interior" class="py-20 bg-bg-deep gallery-section" aria-label="Galería interior">
      <div class="container-site">
        <div class="text-center mb-10 reveal">
          <h2 class="font-display font-bold italic text-3xl md:text-4xl text-white mb-3">Interior</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Un interior pensado para el confort sin comprometer el rendimiento.
          </p>
        </div>
        <div id="interior-scroll" class="flex gap-3 h-64 md:h-80 reveal overflow-x-auto no-scrollbar cursor-grab active:cursor-grabbing">
          {model.interiorImages.map((img, i) => (
            <div class={`gallery-img-wrapper overflow-hidden rounded-lg flex-shrink-0 ${i === 0 ? 'flex-[2]' : 'flex-[1.5]'} min-w-[300px] md:min-w-[450px]`}>
              {i <= 1 ? (
                <img
                  src={img.url}
                  alt={`Interior ${model.name} — imagen ${i + 1}`}
                  width={img.w}
                  height={img.h}
                  loading="lazy"
                  fetchpriority="low"
                  decoding="async"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <img
                  data-src={img.url}
                  src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
                  alt={`Interior ${model.name} — imagen ${i + 1}`}
                  width={img.w}
                  height={img.h}
                  fetchpriority="low"
                  decoding="async"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              )}
            </div>
          ))}
        </div>

        <!-- Progress Bar -->
        <div class="mx-auto mt-12 px-8" style="max-width: 600px;">
          <div id="interior-track" class="scroll-track-custom" role="scrollbar">
            <div id="interior-thumb" class="scroll-thumb-custom"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- EXTERIOR GALLERY -->
  {model.exteriorImages.length > 0 && (
    <section id="galeria" class="py-20 bg-bg-mid gallery-section" aria-label="Galería exterior">
      <div class="container-site">
        <div class="text-center mb-10 reveal">
          <h2 class="font-display font-bold italic text-3xl md:text-4xl text-white mb-3">Exterior</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Líneas que cortan el agua con elegancia y propósito.
          </p>
        </div>
        <div id="galeria-scroll" class="flex gap-3 h-64 md:h-80 reveal overflow-x-auto no-scrollbar cursor-grab active:cursor-grabbing">
          {model.exteriorImages.map((img, i) => (
            <div class={`gallery-img-wrapper overflow-hidden rounded-lg flex-shrink-0 ${i === 0 ? 'flex-[2]' : 'flex-[1.5]'} min-w-[300px] md:min-w-[450px]`}>
              {i <= 1 ? (
                <img
                  src={img.url}
                  alt={`Exterior ${model.name} — imagen ${i + 1}`}
                  width={img.w}
                  height={img.h}
                  loading="lazy"
                  fetchpriority="low"
                  decoding="async"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <img
                  data-src={img.url}
                  src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
                  alt={`Exterior ${model.name} — imagen ${i + 1}`}
                  width={img.w}
                  height={img.h}
                  fetchpriority="low"
                  decoding="async"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              )}
            </div>
          ))}
        </div>

        <!-- Progress Bar -->
        <div class="mx-auto mt-12 px-8" style="max-width: 600px;">
          <div id="galeria-track" class="scroll-track-custom" role="scrollbar">
            <div id="galeria-thumb" class="scroll-thumb-custom"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- VERSIONS TABLE -->
  {model.versions.length > 0 && (
    <VersionsTable
      modelName={model.name.replace('Classer ', '')}
      features={model.versions[0].features}
      silhouetteTechnicalUrl={model.silhouetteTechnicalUrl}
      diagramUrl="https://placehold.co/700x480/f4f4f2/6b7a99?text=Technical+Diagram+206+FTX"
    />
  )}

  <!-- CONFIGURADOR -->

</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scroll-track-custom {
    position: relative;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    cursor: pointer;
  }

  .scroll-thumb-custom {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 6px;
    background: #ffffff;
    border-radius: 9999px;
    cursor: grab;
    min-width: 60px;
    transition: width 0.1s ease, background 0.2s ease;
  }

  .scroll-thumb-custom:active {
    cursor: grabbing;
    background: rgba(255, 255, 255, 0.8);
  }

  /* ── Shimmer skeleton para imágenes de galería ── */
  .gallery-img-wrapper {
    position: relative;
    background-color: rgba(255, 255, 255, 0.04);
  }

  .gallery-img-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.06) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: gallery-shimmer 1.6s ease-in-out infinite;
    z-index: 1;
    pointer-events: none;
    border-radius: inherit;
  }

  .gallery-img-wrapper.img-loaded::before,
  .gallery-img-wrapper.img-error::before {
    display: none;
  }

  @keyframes gallery-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* La imagen real no debe tapar el shimmer mientras carga */
  .gallery-img-wrapper img {
    position: relative;
    z-index: 2;
    will-change: transform;
  }

  /* Defer rendering of off-screen gallery sections */
  .gallery-section {
    content-visibility: auto;
    contain-intrinsic-size: auto 600px;
  }

  /* GPU layer for smooth horizontal scroll */
  #interior-scroll,
  #galeria-scroll {
    will-change: scroll-position;
    transform: translateZ(0);
  }
</style>

<!-- Subnav sticky: requires GSAP as ESM module (not available as global in inline scripts) -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const subnav = document.getElementById('model-subnav');
  if (subnav) {
    ScrollTrigger.create({
      trigger: '#especificaciones',
      start: 'top top+=72',
      onEnter: () => {
        gsap.to(subnav, { y: 0, opacity: 1, duration: 0.4, ease: 'power2.out' });
      },
      onLeaveBack: () => {
        gsap.to(subnav, { y: '-100%', opacity: 0, duration: 0.3, ease: 'power2.in' });
      },
    });
  }
</script>

<script is:inline>
  // Custom Scroll Logic (no GSAP dependency)
  document.addEventListener('DOMContentLoaded', () => {
    function setupCustomScroll(containerId, trackId, thumbId) {
      const container = document.getElementById(containerId);
      const track = document.getElementById(trackId);
      const thumb = document.getElementById(thumbId);
      if (!container || !track || !thumb) return;

      function updateThumb() {
        requestAnimationFrame(() => {
          // Reads first
          const trackWidth = track.offsetWidth;
          const totalWidth = container.scrollWidth;
          const visibleWidth = container.clientWidth;
          const maxScroll = totalWidth - visibleWidth;
          const scrollLeft = container.scrollLeft;

          // Writes after
          if (maxScroll <= 0) {
            track.parentElement.style.display = 'none';
            return;
          }
          track.parentElement.style.display = 'block';
          const thumbWidth = Math.max((visibleWidth / totalWidth) * trackWidth, 80);
          thumb.style.width = thumbWidth + 'px';
          thumb.style.left = ((scrollLeft / maxScroll) * (trackWidth - thumbWidth)) + 'px';
        });
      }

      container.addEventListener('scroll', updateThumb, { passive: true });
      window.addEventListener('resize', updateThumb, { passive: true });
      updateThumb();

      // Content Drag
      let isDown = false;
      let startX;
      let scrollLeftPos;

      container.addEventListener('mousedown', (e) => {
        isDown = true;
        container.classList.add('active');
        startX = e.pageX - container.offsetLeft;
        scrollLeftPos = container.scrollLeft;
      });
      document.addEventListener('mouseup', () => {
        isDown = false;
        container.classList.remove('active');
      });
      container.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - container.offsetLeft;
        const walk = (x - startX) * 2;
        container.scrollLeft = scrollLeftPos - walk;
      });

      // Thumb Drag
      let isDraggingThumb = false;
      let thumbStartX;
      let thumbStartScrollLeft;

      thumb.addEventListener('mousedown', (e) => {
        isDraggingThumb = true;
        thumbStartX = e.pageX;
        thumbStartScrollLeft = container.scrollLeft;
        document.body.style.userSelect = 'none';
        e.stopPropagation();
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDraggingThumb) return;
        const deltaX = e.pageX - thumbStartX;
        const trackWidth = track.offsetWidth;
        const thumbWidth = thumb.offsetWidth;
        const maxThumbTravel = trackWidth - thumbWidth;
        const maxScroll = container.scrollWidth - container.clientWidth;
        if (maxThumbTravel > 0) {
          container.scrollLeft = thumbStartScrollLeft + (deltaX / maxThumbTravel) * maxScroll;
        }
      });

      document.addEventListener('mouseup', () => {
        isDraggingThumb = false;
        document.body.style.userSelect = '';
      });
    }

    // ── Lazy load manual para imágenes en scroll horizontal ──
    function loadImage(img) {
      img.src = img.dataset.src;
      img.removeAttribute('data-src');
      img.onload = () => img.closest('.gallery-img-wrapper')?.classList.add('img-loaded');
      img.onerror = () => img.closest('.gallery-img-wrapper')?.classList.add('img-error');
    }

    function setupHorizontalLazyLoad(scrollId) {
      const container = document.getElementById(scrollId);
      if (!container) return;
      const imgs = container.querySelectorAll('img[data-src]');
      if (!imgs.length) return;

      if ('IntersectionObserver' in window) {
        // Use the scroll container as root → fires exactly when images enter the visible strip
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                loadImage(entry.target);
                observer.unobserve(entry.target);
              }
            });
          },
          {
            root: container,
            rootMargin: '0px 600px 0px 0px', // preload 600px ahead while scrolling right
            threshold: 0
          }
        );
        imgs.forEach(img => observer.observe(img));
      } else {
        imgs.forEach(img => loadImage(img));
      }
    }

    setupHorizontalLazyLoad('interior-scroll');
    setupHorizontalLazyLoad('galeria-scroll');

    // Marcar como loaded las imágenes lazy directas (índice 0 y 1)
    document.querySelectorAll('.gallery-img-wrapper img:not([data-src])').forEach(img => {
      const markLoaded = () => img.closest('.gallery-img-wrapper')?.classList.add('img-loaded');
      if (img.complete && img.naturalWidth > 0) {
        markLoaded();
      } else {
        img.addEventListener('load', markLoaded, { once: true });
      }
    });

    setupCustomScroll('interior-scroll', 'interior-track', 'interior-thumb');
    setupCustomScroll('galeria-scroll', 'galeria-track', 'galeria-thumb');
  });
</script>
