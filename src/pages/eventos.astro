---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

// AGROACTIVA
import agro01 from "../assets/noticias/AGROACTIVA/1.webp";
import agro02 from "../assets/noticias/AGROACTIVA/2.webp";
import agro03 from "../assets/noticias/AGROACTIVA/3.webp";
import agro04 from "../assets/noticias/AGROACTIVA/4.webp";

// CACEL
import cacel01 from "../assets/noticias/CACEL/1.webp";
import cacel02 from "../assets/noticias/CACEL/2.webp";
import cacel03 from "../assets/noticias/CACEL/3.webp";
import cacel04 from "../assets/noticias/CACEL/4.webp";
import cacel05 from "../assets/noticias/CACEL/5.webp";
import cacel06 from "../assets/noticias/CACEL/6.webp";
import cacel07 from "../assets/noticias/CACEL/7.webp";
import cacel08 from "../assets/noticias/CACEL/8.webp";
import cacel09 from "../assets/noticias/CACEL/9.webp";
import cacel10 from "../assets/noticias/CACEL/10.webp";
import cacel11 from "../assets/noticias/CACEL/11.webp";

// LANZAMIENTO 246
import lnz01 from "../assets/noticias/LANZAMIENTO/LNZ246-01.webp";
import lnz02 from "../assets/noticias/LANZAMIENTO/LNZ246-02.webp";
import lnz03 from "../assets/noticias/LANZAMIENTO/LNZ246-03.webp";
import lnz04 from "../assets/noticias/LANZAMIENTO/LNZ246-04.webp";
import lnz05 from "../assets/noticias/LANZAMIENTO/LNZ246-05.webp";

// NUEVA FÁBRICA
import fab01 from "../assets/noticias/NUEVA-FABRICA/1.webp";
import fab02 from "../assets/noticias/NUEVA-FABRICA/2.webp";
import fab03 from "../assets/noticias/NUEVA-FABRICA/3.webp";
import fab04 from "../assets/noticias/NUEVA-FABRICA/4.webp";
import fab05 from "../assets/noticias/NUEVA-FABRICA/5.webp";
import fab06 from "../assets/noticias/NUEVA-FABRICA/6.webp";
import fab07 from "../assets/noticias/NUEVA-FABRICA/7.webp";
import fab08 from "../assets/noticias/NUEVA-FABRICA/8.webp";
import fab09 from "../assets/noticias/NUEVA-FABRICA/9.webp";

const events = [
  {
    id: "agoactiva",
    badge: "NOTICIAS",
    date: "JUNIO, 2025",
    title: "AGROACTIVA 2025",
    desc: "Presencia de marca en uno de los eventos más grandes del campo argentino.",
    body: [
      "Del 4 al 7 de junio de 2025, parte del equipo comercial de Astillero Fuentes, Classer asistió a la Agroactiva. Un evento orientado al campo Argentino en donde se presentan variedad de empresas, incluidas automotrices como de interés general.",
      "En el evento se presentaron dos 246, una 170 y una 206 FTX.",
    ],
    thumbSrc: agro01,
    thumbAlt: "Agroactiva 2025 — Presencia de Astillero Fuentes",
    detailSrc: agro01,
    detailAlt: "Exhibición de modelos Classer en Agroactiva",
    gallery: [
      { src: agro01, pos: "center" },
      { src: agro02, pos: "center" },
      { src: agro03, pos: "center" },
      { src: agro04, pos: "center" },
    ],
    objectPosition: "center top",
  },
  {
    id: "cacel-2025",
    badge: "NOTICIAS",
    date: "NOVIEMBRE, 2025",
    title: "SALÓN NÁUTICO (CACEL)",
    desc: "Participación en el evento principal de la industria náutica argentina.",
    body: [
      "Del 7 al 16 de noviembre de 2025, el equipo comercial y de diseño de Astillero Fuentes, Classer asistió al Salón Nautico Argentino 24° organizado por CACEL. Este es el evento principal de la industria náutica en donde las marcas más reconocidas presentan lo nuevo para los siguientes años y en donde el usuario puede ver el producto frente a frente.",
      "En este evento presentamos dos 246, una versión surf y otra OB. Además de dos 206 FTX una versión flyer y otra LTD. El evento fue un éxito desde el punto de vista de nuestra relación con el cliente, recibiendo varios elogios por las lanchas presentadas y por la calidad de fabricación de las mismas.",
    ],
    thumbSrc: cacel01,
    thumbAlt: "CACEL 2025 — Salón Náutico Argentino",
    detailSrc: cacel01,
    detailAlt: "Stand de Classer en el Salón Náutico",
    gallery: [
      { src: cacel01, pos: "center" },
      { src: cacel03, pos: "center" }, // Grupo de personas
      { src: cacel04, pos: "center" },
      { src: cacel05, pos: "center" }, // Premiación/Gente
      { src: cacel06, pos: "center" },
      { src: cacel07, pos: "center" },
      { src: cacel08, pos: "center" }, // Gente en stand
      { src: cacel09, pos: "center" },
      { src: cacel10, pos: "center" },
      { src: cacel11, pos: "center" },
    ],
    objectPosition: "center center",
  },
  {
    id: "lanzamiento-246",
    badge: "LANZAMIENTO",
    date: "SEPTIEMBRE, 2024",
    title: "LANZAMIENTO CLASSER 246",
    desc: "Presentación oficial de nuestra lancha insignia ante más de 150 personas.",
    body: [
      "El viernes 6 de septiembre de 2024 fue el lanzamiento de nuestra lancha insignia, la Classer 246. Fue un evento sin precedentes para nosotros, con una asistencia de 150 personas, entre ellas clientes de años y años, proveedores, amigos, familiares y canales de difusión.",
      "En el evento se dio un recibimiento con bebidas y algunos snacks. El evento fue en nuestro nuevo astillero, en el centro del showroom estaba la nueva 246, la cual fue destapada en el momento cúspide de la noche.",
      "Un evento inolvidable y emocionante, en donde Los directores del astillero dieron un discurso a todos los presentes dando la bienvenida y agradeciendo la presencia de cada uno.",
    ],
    thumbSrc: lnz01,
    thumbAlt: "Lanzamiento Classer 246 — presentación oficial del modelo",
    detailSrc: lnz01,
    detailAlt: "Classer 246 en el agua durante el evento de lanzamiento",
    gallery: [
      { src: lnz01, pos: "center top" }, // Presentador
      { src: lnz02, pos: "top" }, // Público/Gente
      { src: lnz03, pos: "top" }, // Músicos
      { src: lnz04, pos: "center" },
      { src: lnz05, pos: "top" }, // Brindis/Gente
    ],
    objectPosition: "center top",
  },
  {
    id: "astillero-fuentes",
    badge: "NOTICIAS",
    date: "AGOSTO, 2023",
    title: "NUESTRA NUEVA FÁBRICA",
    desc: "Inauguración de la planta industrial con tecnología de punta.",
    body: [
      "En 2023, más precisamente en Agosto de ese mismo año Astillero Fuentes abrió las puertas y comenzó su producción en la nueva fábrica.",
      "Una industrialización con tecnología de punta, que representó un salto enorme en capacidad comparado al hogar anterior de la marca.",
    ],
    thumbSrc: fab01,
    thumbAlt: "Nuevas instalaciones Astillero Fuentes en Villa María",
    detailSrc: fab01,
    detailAlt: "Nuevas instalaciones Astillero Fuentes",
    gallery: [
      { src: fab01, pos: "center" },
      { src: fab02, pos: "center" },
      { src: fab03, pos: "center" },
      { src: fab04, pos: "center" },
      { src: fab05, pos: "center" },
      { src: fab06, pos: "center" },
      { src: fab07, pos: "center" },
      { src: fab08, pos: "center" },
      { src: fab09, pos: "center" },
    ],
    objectPosition: "center center",
  },
];
---

<Layout
  title="Eventos y Noticias — CLASSER | Astillero Fuentes"
  description="Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño."
  fixedNavbar={true}
>
  <section
    class="mini-hero bg-white text-center"
    aria-label="Noticias y eventos"
  >
    <div class="container-site">
      <h1
        class="font-display text-[2.5rem] md:text-[3.5rem] text-[#1a1a2e] mb-4"
      >
        Noticias y eventos
      </h1>
      <p
        class="font-body text-[0.95rem] text-gray-500 max-w-lg mx-auto leading-relaxed"
      >
        Mantente actualizado con lo último del astillero, próximos eventos y
        premios de diseño.
      </p>
    </div>
  </section>

  <section class="event-selector bg-white" aria-label="Selector de eventos">
    <div class="selector-nav">
      <div class="cards-viewport" role="list" aria-label="Lista de eventos">
        {
          events.map((ev, i) => (
            <article
              class={`ev-card ${i === 1 ? "ev-card--active" : ""}`}
              data-index={i}
              role="listitem"
              aria-label={`Evento: ${ev.title}`}
              aria-selected={i === 1 ? "true" : "false"}
              tabindex="0"
            >
              <div class="ev-card__inner">
                <div class="ev-card__img-wrap">
                  <span class="ev-badge-float">{ev.badge}</span>
                  <Image
                    src={ev.thumbSrc}
                    alt={ev.thumbAlt}
                    width={600}
                    loading={i === 1 ? "eager" : "lazy"}
                    decoding="async"
                    class="ev-card__img"
                    style={ev.objectPosition ? `object-position: ${ev.objectPosition}` : ""}
                  />
                </div>
                <div class="ev-card__body">
                  <p class="ev-date">{ev.date}</p>
                  <h3 class="ev-title">{ev.title}</h3>
                  <p class="ev-desc">{ev.desc}</p>
                  <div class="ev-link">
                    LEER ARTÍCULO <span>&rarr;</span>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="progress-container">
      <div id="events-track" class="custom-track">
        <div id="events-thumb" class="custom-thumb"></div>
      </div>
    </div>
  </section>

  <section class="event-detail" aria-label="Detalle del evento seleccionado">
    {
      events.map((ev, i) => (
        <div
          class={`detail-panel ${i === 1 ? "detail-panel--active" : ""}`}
          id={`detail-${ev.id}`}
          aria-hidden={i !== 1 ? "true" : "false"}
        >
          <div class="container-site">
            <div class="detail-header">
              <span class="ev-badge-dark">{ev.badge}</span>
              <p class="detail-date">{ev.date}</p>
            </div>
            <h2 class="detail-title">{ev.title}</h2>

            <div class="detail-grid">
              <div class="detail-img-wrap">
                <Image
                  src={ev.detailSrc}
                  alt={ev.detailAlt}
                  width={680}
                  loading="lazy"
                  decoding="async"
                  class="detail-img"
                  style={ev.objectPosition ? `object-position: ${ev.objectPosition}` : ""}
                />
              </div>

              <div class="detail-text">
                {ev.body.map((p) => (
                  <p class="article-text">{p}</p>
                ))}
              </div>
            </div>
          </div>

          {ev.gallery && ev.gallery.length > 0 && (
            <div class="detail-gallery">
              {ev.gallery.map((item, gi) => (
                <div class="gallery-item">
                  <Image
                    src={item.src}
                    alt={`${ev.title} — foto ${gi + 1}`}
                    width={500}
                    loading="lazy"
                    decoding="async"
                    class="gallery-img"
                    style={item.pos ? `object-position: ${item.pos}` : ""}
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </section>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     MINI HERO
  ═══════════════════════════════════════════════════════════ */
  .mini-hero {
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  /* ═══════════════════════════════════════════════════════════
     EVENT SELECTOR (EL CALCADO)
  ═══════════════════════════════════════════════════════════ */
  .event-selector {
    padding: 0 0 3rem;
    overflow: hidden;
  }

  .selector-nav {
    width: 100%;
    margin: 0 auto;
  }

  .cards-viewport {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 2rem 0;
  }

  /* --- Tarjeta Inactiva (Blanca y vertical) --- */
  .ev-card {
    flex: 0 0 320px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    user-select: none;
    overflow: hidden;
    height: 400px; /* Altura fija para mantener simetría */
    opacity: 0.7;
    transform: scale(0.95);
  }

  .ev-card:hover {
    opacity: 1;
    border-color: #cbd5e1;
  }

  .ev-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ev-card__img-wrap {
    position: relative;
    width: 100%;
    height: 220px; /* En tarjeta inactiva */
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .ev-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top; /* Asegura que no se corten las cabezas */
    transition: transform 0.6s ease;
  }

  /* Badge Flotante estilo revista */
  .ev-badge-float {
    position: absolute;
    top: 16px;
    left: 16px;
    background: #ffffff;
    color: #000000;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    z-index: 10;
  }

  .ev-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ev-date {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .ev-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: #1e293b;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .ev-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #64748b;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ev-link {
    display: none; /* Oculto en inactivas */
  }

  /* --- Tarjeta Activa (Gigante, lila, horizontal) --- */
  .ev-card--active {
    flex: 0 0 900px;
    background: #d4d0de; /* El lila exacto de la imagen */
    border-color: transparent;
    opacity: 1;
    transform: scale(1);
    height: 420px; /* Ligeramente más alta */
  }

  .ev-card--active .ev-card__inner {
    flex-direction: row; /* Pasa a ser lado a lado */
    padding: 24px;
    gap: 32px;
    align-items: center;
  }

  .ev-card--active .ev-card__img-wrap {
    width: 55%;
    height: 100%;
    border-radius: 12px;
  }

  .ev-card--active .ev-card__body {
    width: 45%;
    padding: 0;
    justify-content: center;
  }

  .ev-card--active .ev-title {
    font-size: 2.2rem; /* Título mucho más grande */
    color: #1a1a2e;
    margin-bottom: 1rem;
  }

  .ev-card--active .ev-desc {
    font-size: 0.95rem;
    color: #475569;
    -webkit-line-clamp: 5;
    margin-bottom: 1.5rem;
  }

  .ev-card--active .ev-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #1a1a2e;
    margin-top: auto;
  }

  /* --- SCROLLBAR CUSTOM (Calcada) --- */
  .progress-container {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .custom-track {
    width: 350px;
    height: 8px;
    background: #e2e8f0;
    border-radius: 10px;
    position: relative;
    cursor: pointer;
  }

  .custom-thumb {
    height: 12px;
    width: 60px;
    background: #000000;
    position: absolute;
    top: -2px;
    left: 0;
    border-radius: 10px;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  /* ═══════════════════════════════════════════════════════════
     EVENT DETAIL PANEL
  ═══════════════════════════════════════════════════════════ */
  .event-detail {
    background: #ffffff;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .detail-panel {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }

  .detail-panel--active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .detail-panel--entering {
    display: block;
    opacity: 0;
    transform: translateY(12px);
  }

  .container-site {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .detail-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 3rem;
    margin-bottom: 1rem;
  }

  .ev-badge-dark {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    padding: 4px 10px;
    background: #111;
    color: #fff;
  }

  .detail-date {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: #888;
  }

  .detail-title {
    font-family: "Rogue Sans Nova Extended", sans-serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #1a1a2e;
    margin-bottom: 2rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .detail-img-wrap {
    border-radius: 8px;
    overflow: hidden;
  }
  .detail-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .article-text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.8;
  }

  .detail-gallery {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 1rem 2rem 2rem;
    max-width: 1300px;
    margin: 0 auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
  }
  .detail-gallery::-webkit-scrollbar {
    height: 6px;
    display: block;
  }
  .detail-gallery::-webkit-scrollbar-track {
    background: transparent;
  }
  .detail-gallery::-webkit-scrollbar-thumb {
    background-color: #cbd5e1;
    border-radius: 20px;
  }
  .gallery-item {
    flex: 0 0 300px;
    height: 220px;
    border-radius: 8px;
    overflow: hidden;
    scroll-snap-align: start;
  }
  .gallery-item:first-child {
    flex: 0 0 300px; /* Igualamos al resto para consistencia en grid largo */
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top; /* Evita que se corten las caras en la galería */
    transition: transform 0.4s ease;
  }
  .gallery-item:hover .gallery-img {
    transform: scale(1.04);
  }

  /* --- RESPONSIVE MOBILE --- */
  @media (max-width: 900px) {
    .cards-viewport {
      justify-content: flex-start;
      overflow-x: auto;
      padding-left: 20px;
      scrollbar-width: none;
    }
    .cards-viewport::-webkit-scrollbar {
      display: none;
    }
    .ev-card {
      flex: 0 0 280px;
      height: 380px;
    }
    .ev-card--active {
      flex: 0 0 90vw;
      flex-direction: column;
      height: auto;
    }
    .ev-card--active .ev-card__inner {
      flex-direction: column;
      padding: 16px;
      gap: 16px;
    }
    .ev-card--active .ev-card__img-wrap {
      width: 100%;
      height: 200px;
    }
    .ev-card--active .ev-card__body {
      width: 100%;
    }
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll<HTMLElement>(".ev-card");
    const panels = document.querySelectorAll<HTMLElement>(".detail-panel");
    const eventsCount = cards.length;
    const thumb = document.getElementById("events-thumb") as HTMLElement;
    const track = document.getElementById("events-track") as HTMLElement;

    let current = 1;

    const updateThumb = (index: number) => {
      // Divide el track en 3 posiciones (0, 1, 2)
      if (!thumb || !track) return;
      const trackWidth = track.clientWidth;
      const thumbWidth = thumb.clientWidth;
      const maxTravel = trackWidth - thumbWidth;
      const percentage = index / (eventsCount - 1);
      thumb.style.transform = `translateX(${percentage * maxTravel}px)`;
    };

    const goTo = (index: number) => {
      if (index < 0 || index >= eventsCount) return;

      cards.forEach((card, i) => {
        const isActive = i === index;
        card.classList.toggle("ev-card--active", isActive);
        card.setAttribute("aria-selected", isActive ? "true" : "false");

        // Efecto scroll para móviles: centra la tarjeta activa
        if (isActive && window.innerWidth <= 900) {
          card.scrollIntoView({
            behavior: "smooth",
            inline: "center",
            block: "nearest",
          });
        }
      });

      const oldPanel = document.querySelector<HTMLElement>(
        ".detail-panel--active",
      );
      const newPanel = panels[index];

      if (oldPanel && oldPanel !== newPanel) {
        oldPanel.classList.remove("detail-panel--active");
        oldPanel.setAttribute("aria-hidden", "true");

        newPanel.classList.add("detail-panel--entering");
        newPanel.setAttribute("aria-hidden", "false");
        void newPanel.offsetWidth;
        newPanel.classList.remove("detail-panel--entering");
        newPanel.classList.add("detail-panel--active");
      } else if (!oldPanel) {
        newPanel.classList.add("detail-panel--active");
        newPanel.setAttribute("aria-hidden", "false");
      }

      current = index;
      updateThumb(index);
    };

    cards.forEach((card, i) => {
      card.addEventListener("click", () => goTo(i));
    });

    // Permitir clic en el track para navegar (dinámico según cantidad)
    if (track) {
      track.addEventListener("click", (e) => {
        const rect = track.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const percentage = clickX / rect.width;
        const index = Math.min(
          eventsCount - 1,
          Math.floor(percentage * eventsCount),
        );
        goTo(index);
      });
    }

    // Al cargar, verificar si hay un hash en la URL
    const hash = window.location.hash.replace('#', '');
    if (hash) {
      let found = false;
      panels.forEach((panel, idx) => {
        if (panel.id === `detail-${hash}`) {
          goTo(idx);
          found = true;
          // Pequeño scroll para centrar el selector si es necesario
          setTimeout(() => {
            const card = cards[idx];
            card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          }, 100);
        }
      });
      if (!found) goTo(1);
    } else {
      goTo(1); // Inicializa en la segunda tarjeta por defecto
    }
  });
</script>
