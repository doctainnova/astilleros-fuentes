---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import caselImg      from '../assets/noticias/casel.webp';
import lzn01Img      from '../assets/noticias/lzn246/LNZ246-01.webp';
import fabricaNotImg from '../assets/noticias/fabrica.webp';
import lzn02Img      from '../assets/noticias/lzn246/LNZ246-02.webp';
import lzn03Img      from '../assets/noticias/lzn246/LNZ246-03.webp';
import lzn04Img      from '../assets/noticias/lzn246/LNZ246-04.webp';
import n1Img         from '../assets/noticias/1.webp';
import n2Img         from '../assets/noticias/2.webp';
import n3Img         from '../assets/noticias/3.webp';
import n4Img         from '../assets/noticias/4.webp';
import n5Img         from '../assets/noticias/5.webp';
import n6Img         from '../assets/noticias/6.webp';
import n7Img         from '../assets/noticias/7.webp';
import n8Img         from '../assets/noticias/8.webp';
import n9Img         from '../assets/noticias/9.webp';
import n10Img        from '../assets/noticias/10.webp';

const events = [
  {
    id: 'cacel-2025',
    badge: 'NOTICIAS',
    date: 'FEBRERO, 2025',
    title: 'CACEL 2025',
    desc: 'Participación en el Campeonato Argentino de Carreras de Embarcaciones Ligeras en Villa María.',
    body: [
      'Classer participó en el CACEL 2025, el Campeonato Argentino de Carreras de Embarcaciones Ligeras, celebrado en Villa María. Una jornada de adrenalina y deportividad que reunió a los mejores pilotos y embarcaciones del país.',
      'La presencia de Classer en esta competencia refleja el compromiso del astillero con el deporte náutico y la excelencia en el desempeño de sus embarcaciones. Los modelos de la línea Classic demostraron su rendimiento y maniobrabilidad en condiciones de competencia real.',
      'Una experiencia que refuerza el legado deportivo de Astillero Fuentes y la pasión por el agua que define a la marca.',
    ],
    thumbSrc: caselImg,
    thumbAlt: 'CACEL 2025 — Campeonato Argentino de Carreras en Villa María',
    detailSrc: caselImg,
    detailAlt: 'CACEL 2025 — Campeonato Argentino de Carreras',
    gallery: [lzn02Img, lzn03Img, lzn04Img, n1Img, n2Img],
  },
  {
    id: 'lanzamiento-246',
    badge: 'LANZAMIENTO',
    date: 'MARZO, 2025',
    title: 'Lanzamiento Classer 246',
    desc: 'Presentación oficial del modelo más emblemático de la línea DF. Una noche de diseño, rendimiento y legado.',
    body: [
      'El lanzamiento oficial del Classer 246 reunió a distribuidores, prensa especializada y apasionados de la náutica en una velada memorable en Villa María. El modelo, insignia de la línea DF, fue presentado con todas sus innovaciones y detalles de fabricación.',
      'Con una eslora máxima de 7.40m y motorización de hasta 350hp, el Classer 246 representa el estándar de la excelencia en embarcaciones de lujo argentinas. Construido íntegramente en el Astillero Fuentes, combina tradición artesanal con tecnología de vanguardia.',
      'La noche culminó con una demostración en el agua que dejó a todos los presentes sin palabras. El Classer 246 ya está disponible para cotización.',
    ],
    thumbSrc: lzn01Img,
    thumbAlt: 'Lanzamiento Classer 246 — presentación oficial del modelo',
    detailSrc: lzn01Img,
    detailAlt: 'Classer 246 en el agua durante el evento de lanzamiento',
    gallery: [lzn02Img, lzn03Img, lzn04Img, n1Img, n2Img, n3Img, n4Img],
  },
  {
    id: 'astillero-fuentes',
    badge: 'NOTICIAS',
    date: 'ENERO, 2025',
    title: 'Astillero Fuentes',
    desc: 'Nuevas instalaciones y expansión del showroom en Villa María, Córdoba.',
    body: [
      'Astillero Fuentes inauguró sus nuevas instalaciones en Villa María, Córdoba, con un moderno showroom diseñado para recibir a clientes y visitantes. La expansión refleja el crecimiento sostenido de la empresa en el sector náutico argentino.',
      'El nuevo espacio incorpora áreas de exhibición de modelos, sala de personalización de colores y tapicerías, y una zona de producción visitable para que los clientes vean de cerca el proceso de fabricación artesanal.',
      'Con más de 30 años en el mercado, Astillero Fuentes consolida su posición como referente de la industria náutica argentina.',
    ],
    thumbSrc: fabricaNotImg,
    thumbAlt: 'Nuevas instalaciones Astillero Fuentes en Villa María',
    detailSrc: fabricaNotImg,
    detailAlt: 'Nuevas instalaciones Astillero Fuentes',
    gallery: [n5Img, n6Img, n7Img, n8Img, n9Img, n10Img],
  },
];
---

<Layout
  title="Eventos y Noticias — CLASSER | Astillero Fuentes"
  description="Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño."
  fixedNavbar={true}
>

  <!-- ============================================================
       MINI HERO
       ============================================================ -->
  <section class="mini-hero bg-bg-light text-center" aria-label="Noticias y eventos">
    <div class="container-site">
      <h1 class="hero-title">Noticias y eventos</h1>
      <p class="hero-sub">
        Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño.
      </p>
    </div>
  </section>


  <!-- ============================================================
       EVENT SELECTOR — flechas + cards centradas
       ============================================================ -->
  <section class="event-selector" aria-label="Selector de eventos">

    <!-- Flechas de navegación -->
    <div class="selector-nav">
      <div class="selector-arrows">
        <button id="prev-btn" class="nav-arrow" aria-label="Evento anterior" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button id="next-btn" class="nav-arrow" aria-label="Siguiente evento">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>

      <!-- Cards track -->
      <div class="cards-viewport" role="list" aria-label="Lista de eventos">
        {events.map((ev, i) => (
          <article
            class={`ev-card ${i === 1 ? 'ev-card--active' : ''}`}
            data-index={i}
            role="listitem"
            aria-label={`Evento: ${ev.title}`}
            aria-selected={i === 1 ? 'true' : 'false'}
            tabindex="0"
          >
            <div class="ev-card__img-wrap">
              <Image
                src={ev.thumbSrc}
                alt={ev.thumbAlt}
                width={400}
                height={260}
                loading={i === 1 ? 'eager' : 'lazy'}
                decoding="async"
                class="ev-card__img"
              />
            </div>
            <div class="ev-card__body">
              <span class="ev-badge">{ev.badge}</span>
              <p class="ev-date">{ev.date}</p>
              <h3 class="ev-title">{ev.title}</h3>
              <p class="ev-desc">{ev.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Dots indicators -->
    <div class="selector-dots" aria-hidden="true">
      {events.map((_, i) => (
        <button class={`dot ${i === 1 ? 'dot--active' : ''}`} data-dot={i} aria-label={`Ir al evento ${i + 1}`}></button>
      ))}
    </div>

  </section>


  <!-- ============================================================
       DETALLE DINÁMICO — cambia con el evento seleccionado
       ============================================================ -->
  <section class="event-detail" aria-label="Detalle del evento seleccionado">
    {events.map((ev, i) => (
      <div
        class={`detail-panel ${i === 1 ? 'detail-panel--active' : ''}`}
        id={`detail-${ev.id}`}
        aria-hidden={i !== 1 ? 'true' : 'false'}
      >
        <div class="container-site">
          <div class="detail-header">
            <span class="ev-badge ev-badge--dark">{ev.badge}</span>
            <p class="detail-date">{ev.date}</p>
          </div>
          <h2 class="detail-title">{ev.title}</h2>

          <div class="detail-grid">
            <!-- Imagen principal -->
            <div class="detail-img-wrap">
              <Image
                src={ev.detailSrc}
                alt={ev.detailAlt}
                width={680}
                height={460}
                loading="lazy"
                decoding="async"
                class="detail-img"
              />
            </div>

            <!-- Texto -->
            <div class="detail-text">
              {ev.body.map(p => (
                <p class="article-text">{p}</p>
              ))}
            </div>
          </div>
        </div>

        <!-- Galería de fotos del evento -->
        {ev.gallery && ev.gallery.length > 0 && (
          <div class="detail-gallery">
            {ev.gallery.map((img, gi) => (
              <div class="gallery-item">
                <Image
                  src={img}
                  alt={`${ev.title} — foto ${gi + 1}`}
                  width={500}
                  height={320}
                  loading="lazy"
                  decoding="async"
                  class="gallery-img"
                />
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </section>

</Layout>


<style>
  /* ═══════════════════════════════════════════════════════════
     MINI HERO
  ═══════════════════════════════════════════════════════════ */

  .mini-hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    color: var(--color-text-dark);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(26, 26, 46, 0.65);
    max-width: 440px;
    margin-inline: auto;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .mini-hero { padding-top: 6.5rem; padding-bottom: 2.5rem; }
    .hero-title { font-size: clamp(1.75rem, 8vw, 2.25rem); }
    .hero-sub   { font-size: 0.9375rem; }
  }


  /* ═══════════════════════════════════════════════════════════
     EVENT SELECTOR
  ═══════════════════════════════════════════════════════════ */

  .event-selector {
    background: #ffffff;
    padding: 3rem 0 2rem;
  }

  /* Nav: flechas + viewport */
  .selector-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 0 40px;
    max-width: 1600px;
    margin: 0 auto;
  }

  /* En desktop, selector-arrows se "disuelve" en el flex row */
  .selector-arrows {
    display: contents;
  }

  /* Flechas */
  .nav-arrow {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid #e0e0e0;
    background: #ffffff;
    color: #111111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }

  .nav-arrow:hover:not(:disabled) {
    border-color: #111111;
    background: #111111;
    color: #ffffff;
    transform: scale(1.05);
  }

  .nav-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Viewport de cards */
  .cards-viewport {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    overflow: hidden;
    justify-content: center;
  }

  /* Cards individuales */
  .ev-card {
    flex: 0 0 340px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #e8e8e8;
    background: #f9f9f9;
    cursor: pointer;
    opacity: 0.5;
    transform: scale(0.92);
    transition: opacity 0.35s ease, transform 0.35s ease, border-color 0.25s;
    user-select: none;
  }

  .ev-card:focus {
    outline: 2px solid #00a3e0;
    outline-offset: 2px;
  }

  .ev-card--active {
    flex: 0 0 520px;
    opacity: 1;
    transform: scale(1);
    border-color: transparent;
    background: #edeaf7;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }

  .ev-card__img-wrap {
    overflow: hidden;
    height: 180px;
  }

  .ev-card--active .ev-card__img-wrap {
    height: 220px;
  }

  .ev-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .ev-card:hover .ev-card__img {
    transform: scale(1.04);
  }

  .ev-card__body {
    padding: 20px 22px 22px;
  }

  .ev-badge {
    display: inline-block;
    font-family: var(--font-barlow, sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 99px;
    background: #111111;
    color: #ffffff;
  }

  .ev-badge--dark {
    background: #0d1222;
  }

  .ev-date {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #888;
    margin-top: 10px;
  }

  .ev-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
    margin-top: 5px;
  }

  .ev-card--active .ev-title {
    font-size: 20px;
  }

  .ev-desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: #555;
    line-height: 1.6;
    margin-top: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Dots */
  .selector-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    padding-bottom: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #d0d0d0;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
  }

  .dot--active {
    background: #111111;
    transform: scale(1.3);
  }


  /* ═══════════════════════════════════════════════════════════
     EVENT DETAIL PANEL
  ═══════════════════════════════════════════════════════════ */

  .event-detail {
    background: #ffffff;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .detail-panel {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .detail-panel--active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .detail-panel--entering {
    display: block;
    opacity: 0;
    transform: translateY(12px);
  }

  .detail-panel--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .container-site {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .detail-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 3rem;
    margin-bottom: 1rem;
  }

  .detail-date {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #888;
  }

  .detail-title {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #1a1a2e;
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .detail-img-wrap {
    border-radius: 8px;
    overflow: hidden;
  }

  .detail-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .article-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(26, 26, 46, 0.80);
    line-height: 1.8;
  }

  /* Galería del evento */
  .detail-gallery {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .detail-gallery::-webkit-scrollbar {
    display: none;
  }

  .gallery-item {
    flex-shrink: 0;
    height: 260px;
    border-radius: 8px;
    overflow: hidden;
    flex: 0 0 340px;
  }

  .gallery-item:first-child {
    flex: 0 0 480px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.04);
  }

  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════════════════════ */

  @media (max-width: 900px) {
    .ev-card { flex: 0 0 240px; }
    .ev-card--active { flex: 0 0 360px; }
    .detail-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    /* Selector: flechas arriba en fila, cards debajo */
    .selector-nav {
      flex-direction: column;
      gap: 14px;
      padding: 0 16px;
      align-items: stretch;
    }

    .selector-arrows {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .cards-viewport {
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;
    }

    .cards-viewport::-webkit-scrollbar { display: none; }

    .ev-card { flex: 0 0 220px; }
    .ev-card--active { flex: 0 0 280px; }
    .ev-card__body { padding: 14px 16px 16px; }
    .ev-card__img-wrap { height: 140px; }
    .ev-card--active .ev-card__img-wrap { height: 160px; }
    .ev-title { font-size: 15px; }
    .ev-card--active .ev-title { font-size: 17px; }
    .nav-arrow { width: 40px; height: 40px; }
    .detail-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .detail-title { font-size: clamp(1.5rem, 7vw, 2rem); }
    .detail-header { padding-top: 2rem; }
    .gallery-item { flex: 0 0 240px !important; height: 160px; }
    .detail-gallery { padding: 0 1rem; }
  }
</style>


<script>
  document.addEventListener('DOMContentLoaded', () => {

    const events = [
      'cacel-2025',
      'lanzamiento-246',
      'astillero-fuentes',
    ];

    const cards     = document.querySelectorAll<HTMLElement>('.ev-card');
    const dots      = document.querySelectorAll<HTMLElement>('.dot');
    const panels    = document.querySelectorAll<HTMLElement>('.detail-panel');
    const prevBtn   = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn   = document.getElementById('next-btn') as HTMLButtonElement;

    let current = 1; // empieza en el centro

    const goTo = (index: number) => {
      if (index < 0 || index >= events.length) return;

      // Update cards
      cards.forEach((card, i) => {
        const isActive = i === index;
        card.classList.toggle('ev-card--active', isActive);
        card.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('dot--active', i === index);
      });

      // Swap detail panel with animation
      const oldPanel = document.querySelector<HTMLElement>('.detail-panel--active');
      const newPanel = panels[index];

      if (oldPanel && oldPanel !== newPanel) {
        oldPanel.classList.remove('detail-panel--active');
        oldPanel.setAttribute('aria-hidden', 'true');

        // Animate in new panel
        newPanel.classList.add('detail-panel--entering');
        newPanel.setAttribute('aria-hidden', 'false');

        // Force reflow
        void newPanel.offsetWidth;

        newPanel.classList.remove('detail-panel--entering');
        newPanel.classList.add('detail-panel--active');
      } else if (!oldPanel) {
        newPanel.classList.add('detail-panel--active');
        newPanel.setAttribute('aria-hidden', 'false');
      }

      // Update buttons
      prevBtn.disabled = index === 0;
      nextBtn.disabled = index === events.length - 1;

      current = index;
    };

    // Arrow buttons
    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    // Dots
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    // Cards click
    cards.forEach((card, i) => {
      card.addEventListener('click', () => goTo(i));
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') goTo(i);
      });
    });

    // Keyboard arrows
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    // Initialize
    goTo(1);
  });
</script>