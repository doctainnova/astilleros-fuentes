---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import caselImg      from '../assets/noticias/casel.webp';
import lzn01Img      from '../assets/noticias/lzn246/LNZ246-01.webp';
import fabricaNotImg from '../assets/noticias/fabrica.webp';
import lzn02Img      from '../assets/noticias/lzn246/LNZ246-02.webp';
import lzn03Img      from '../assets/noticias/lzn246/LNZ246-03.webp';
import lzn04Img      from '../assets/noticias/lzn246/LNZ246-04.webp';
import n1Img         from '../assets/noticias/1.webp';
import n2Img         from '../assets/noticias/2.webp';
import n3Img         from '../assets/noticias/3.webp';
import n4Img         from '../assets/noticias/4.webp';
import n5Img         from '../assets/noticias/5.webp';
import n6Img         from '../assets/noticias/6.webp';
import n7Img         from '../assets/noticias/7.webp';
import n8Img         from '../assets/noticias/8.webp';
import n9Img         from '../assets/noticias/9.webp';
import n10Img        from '../assets/noticias/10.webp';

const events = [
  {
    id: 'cacel-2025',
    badge: 'NOTICIAS',
    date: 'FEBRERO, 2025',
    title: 'CACEL 2025',
    desc: 'Participación en el Campeonato Argentino de Carreras de Embarcaciones Ligeras en Villa María.',
    body: [
      'Classer participó en el CACEL 2025, el Campeonato Argentino de Carreras de Embarcaciones Ligeras, celebrado en Villa María. Una jornada de adrenalina y deportividad que reunió a los mejores pilotos y embarcaciones del país.',
      'La presencia de Classer en esta competencia refleja el compromiso del astillero con el deporte náutico y la excelencia en el desempeño de sus embarcaciones. Los modelos de la línea Classic demostraron su rendimiento y maniobrabilidad en condiciones de competencia real.',
      'Una experiencia que refuerza el legado deportivo de Astillero Fuentes y la pasión por el agua que define a la marca.',
    ],
    thumbSrc: caselImg,
    thumbAlt: 'CACEL 2025 — Campeonato Argentino de Carreras en Villa María',
    detailSrc: caselImg,
    detailAlt: 'CACEL 2025 — Campeonato Argentino de Carreras',
    gallery: [lzn02Img, lzn03Img, lzn04Img, n1Img, n2Img],
  },
  {
    id: 'lanzamiento-246',
    badge: 'LANZAMIENTO',
    date: 'MARZO, 2025',
    title: 'Lanzamiento 246',
    desc: 'Experimenta las últimas innovaciones e historias del mundo de Classer. Desde eventos exclusivos hasta avances técnicos, descubre qué define nuestro legado.',
    body: [
      'El lanzamiento oficial del Classer 246 reunió a distribuidores, prensa especializada y apasionados de la náutica en una velada memorable en Villa María. El modelo, insignia de la línea DF, fue presentado con todas sus innovaciones y detalles de fabricación.',
      'Con una eslora máxima de 7.40m y motorización de hasta 350hp, el Classer 246 representa el estándar de la excelencia en embarcaciones de lujo argentinas. Construido íntegramente en el Astillero Fuentes, combina tradición artesanal con tecnología de vanguardia.',
      'La noche culminó con una demostración en el agua que dejó a todos los presentes sin palabras. El Classer 246 ya está disponible para cotización.',
    ],
    thumbSrc: lzn01Img,
    thumbAlt: 'Lanzamiento Classer 246 — presentación oficial del modelo',
    detailSrc: lzn01Img,
    detailAlt: 'Classer 246 en el agua durante el evento de lanzamiento',
    gallery: [lzn02Img, lzn03Img, lzn04Img, n1Img, n2Img, n3Img, n4Img],
  },
  {
    id: 'astillero-fuentes',
    badge: 'NOTICIAS',
    date: 'ENERO, 2025',
    title: 'Astillero Fuentes',
    desc: 'Nuevas instalaciones y expansión del showroom en Villa María, Córdoba.',
    body: [
      'Astillero Fuentes inauguró sus nuevas instalaciones en Villa María, Córdoba, con un moderno showroom diseñado para recibir a clientes y visitantes. La expansión refleja el crecimiento sostenido de la empresa en el sector náutico argentino.',
      'El nuevo espacio incorpora áreas de exhibición de modelos, sala de personalización de colores y tapicerías, y una zona de producción visitable para que los clientes vean de cerca el proceso de fabricación artesanal.',
      'Con más de 30 años en el mercado, Astillero Fuentes consolida su posición como referente de la industria náutica argentina.',
    ],
    thumbSrc: fabricaNotImg,
    thumbAlt: 'Nuevas instalaciones Astillero Fuentes en Villa María',
    detailSrc: fabricaNotImg,
    detailAlt: 'Nuevas instalaciones Astillero Fuentes',
    gallery: [n5Img, n6Img, n7Img, n8Img, n9Img, n10Img],
  },
];
---

<Layout
  title="Eventos y Noticias — CLASSER | Astillero Fuentes"
  description="Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño."
  fixedNavbar={true}
>

  <section class="mini-hero bg-white text-center" aria-label="Noticias y eventos">
    <div class="container-site">
      <h1 class="font-display text-[2.5rem] md:text-[3.5rem] text-[#1a1a2e] mb-4">Noticias y eventos</h1>
      <p class="font-body text-[0.95rem] text-gray-500 max-w-lg mx-auto leading-relaxed">
        Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño.
      </p>
    </div>
  </section>


  <section class="event-selector bg-white" aria-label="Selector de eventos">

    <div class="selector-nav">
      <div class="cards-viewport" role="list" aria-label="Lista de eventos">
        {events.map((ev, i) => (
          <article
            class={`ev-card ${i === 1 ? 'ev-card--active' : ''}`}
            data-index={i}
            role="listitem"
            aria-label={`Evento: ${ev.title}`}
            aria-selected={i === 1 ? 'true' : 'false'}
            tabindex="0"
          >
            <div class="ev-card__inner">
              <div class="ev-card__img-wrap">
                <span class="ev-badge-float">{ev.badge}</span>
                <Image
                  src={ev.thumbSrc}
                  alt={ev.thumbAlt}
                  width={600}
                  height={400}
                  loading={i === 1 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="ev-card__img"
                />
              </div>
              <div class="ev-card__body">
                <p class="ev-date">{ev.date}</p>
                <h3 class="ev-title">{ev.title}</h3>
                <p class="ev-desc">{ev.desc}</p>
                <div class="ev-link">LEER ARTÍCULO <span>&rarr;</span></div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="progress-container">
      <div id="events-track" class="custom-track">
        <div id="events-thumb" class="custom-thumb"></div>
      </div>
    </div>

  </section>


  <section class="event-detail" aria-label="Detalle del evento seleccionado">
    {events.map((ev, i) => (
      <div
        class={`detail-panel ${i === 1 ? 'detail-panel--active' : ''}`}
        id={`detail-${ev.id}`}
        aria-hidden={i !== 1 ? 'true' : 'false'}
      >
        <div class="container-site">
          <div class="detail-header">
            <span class="ev-badge-dark">{ev.badge}</span>
            <p class="detail-date">{ev.date}</p>
          </div>
          <h2 class="detail-title">{ev.title}</h2>

          <div class="detail-grid">
            <div class="detail-img-wrap">
              <Image
                src={ev.detailSrc}
                alt={ev.detailAlt}
                width={680}
                height={460}
                loading="lazy"
                decoding="async"
                class="detail-img"
              />
            </div>

            <div class="detail-text">
              {ev.body.map(p => (
                <p class="article-text">{p}</p>
              ))}
            </div>
          </div>
        </div>

        {ev.gallery && ev.gallery.length > 0 && (
          <div class="detail-gallery">
            {ev.gallery.map((img, gi) => (
              <div class="gallery-item">
                <Image
                  src={img}
                  alt={`${ev.title} — foto ${gi + 1}`}
                  width={500}
                  height={320}
                  loading="lazy"
                  decoding="async"
                  class="gallery-img"
                />
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </section>

</Layout>


<style>
  /* ═══════════════════════════════════════════════════════════
     MINI HERO
  ═══════════════════════════════════════════════════════════ */
  .mini-hero {
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  /* ═══════════════════════════════════════════════════════════
     EVENT SELECTOR (EL CALCADO)
  ═══════════════════════════════════════════════════════════ */
  .event-selector {
    padding: 0 0 3rem;
    overflow: hidden;
  }

  .selector-nav {
    width: 100%;
    margin: 0 auto;
  }

  .cards-viewport {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 2rem 0;
  }

  /* --- Tarjeta Inactiva (Blanca y vertical) --- */
  .ev-card {
    flex: 0 0 320px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    user-select: none;
    overflow: hidden;
    height: 400px; /* Altura fija para mantener simetría */
    opacity: 0.7;
    transform: scale(0.95);
  }

  .ev-card:hover {
    opacity: 1;
    border-color: #cbd5e1;
  }

  .ev-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ev-card__img-wrap {
    position: relative;
    width: 100%;
    height: 220px; /* En tarjeta inactiva */
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .ev-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  /* Badge Flotante estilo revista */
  .ev-badge-float {
    position: absolute;
    top: 16px;
    left: 16px;
    background: #ffffff;
    color: #000000;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    z-index: 10;
  }

  .ev-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ev-date {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .ev-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: #1e293b;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .ev-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #64748b;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ev-link {
    display: none; /* Oculto en inactivas */
  }

  /* --- Tarjeta Activa (Gigante, lila, horizontal) --- */
  .ev-card--active {
    flex: 0 0 900px;
    background: #d4d0de; /* El lila exacto de la imagen */
    border-color: transparent;
    opacity: 1;
    transform: scale(1);
    height: 420px; /* Ligeramente más alta */
  }

  .ev-card--active .ev-card__inner {
    flex-direction: row; /* Pasa a ser lado a lado */
    padding: 24px;
    gap: 32px;
    align-items: center;
  }

  .ev-card--active .ev-card__img-wrap {
    width: 55%;
    height: 100%;
    border-radius: 12px;
  }

  .ev-card--active .ev-card__body {
    width: 45%;
    padding: 0;
    justify-content: center;
  }

  .ev-card--active .ev-title {
    font-size: 2.2rem; /* Título mucho más grande */
    color: #1a1a2e;
    margin-bottom: 1rem;
  }

  .ev-card--active .ev-desc {
    font-size: 0.95rem;
    color: #475569;
    -webkit-line-clamp: 5;
    margin-bottom: 1.5rem;
  }

  .ev-card--active .ev-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #1a1a2e;
    margin-top: auto;
  }

  /* --- SCROLLBAR CUSTOM (Calcada) --- */
  .progress-container {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .custom-track {
    width: 350px;
    height: 8px;
    background: #e2e8f0;
    border-radius: 10px;
    position: relative;
    cursor: pointer;
  }

  .custom-thumb {
    height: 12px;
    width: 60px;
    background: #000000;
    position: absolute;
    top: -2px;
    left: 0;
    border-radius: 10px;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1); 
    will-change: transform;
  }

  /* ═══════════════════════════════════════════════════════════
     EVENT DETAIL PANEL
  ═══════════════════════════════════════════════════════════ */
  .event-detail {
    background: #ffffff;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .detail-panel {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .detail-panel--active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .detail-panel--entering {
    display: block;
    opacity: 0;
    transform: translateY(12px);
  }

  .container-site { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .detail-header {
    display: flex; align-items: center; gap: 14px; padding-top: 3rem; margin-bottom: 1rem;
  }

  .ev-badge-dark {
    font-family: var(--font-body); font-size: 10px; font-weight: 800; letter-spacing: 1.5px;
    padding: 4px 10px; background: #111; color: #fff;
  }

  .detail-date { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.5px; color: #888; }

  .detail-title {
    font-family: 'Rogue Sans Nova Extended', sans-serif; font-style: italic; font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem); color: #1a1a2e; margin-bottom: 2rem;
  }

  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
  .detail-img-wrap { border-radius: 8px; overflow: hidden; }
  .detail-img { width: 100%; height: auto; display: block; object-fit: cover; }
  .detail-text { display: flex; flex-direction: column; gap: 1.25rem; }
  .article-text { font-family: var(--font-body); font-size: 0.95rem; color: #475569; line-height: 1.8; }

  .detail-gallery {
    display: flex; gap: 6px; overflow-x: auto; scrollbar-width: none; padding: 0 2rem; max-width: 1200px; margin: 0 auto;
  }
  .detail-gallery::-webkit-scrollbar { display: none; }
  .gallery-item { flex: 0 0 340px; height: 260px; border-radius: 8px; overflow: hidden; }
  .gallery-item:first-child { flex: 0 0 480px; }
  .gallery-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .gallery-item:hover .gallery-img { transform: scale(1.04); }

  /* --- RESPONSIVE MOBILE --- */
  @media (max-width: 900px) {
    .cards-viewport { justify-content: flex-start; overflow-x: auto; padding-left: 20px; scrollbar-width: none; }
    .cards-viewport::-webkit-scrollbar { display: none; }
    .ev-card { flex: 0 0 280px; height: 380px; }
    .ev-card--active { flex: 0 0 90vw; flex-direction: column; height: auto; }
    .ev-card--active .ev-card__inner { flex-direction: column; padding: 16px; gap: 16px; }
    .ev-card--active .ev-card__img-wrap { width: 100%; height: 200px; }
    .ev-card--active .ev-card__body { width: 100%; }
    .detail-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const eventsCount = 3;
    const cards = document.querySelectorAll<HTMLElement>('.ev-card');
    const panels = document.querySelectorAll<HTMLElement>('.detail-panel');
    const thumb = document.getElementById('events-thumb') as HTMLElement;
    const track = document.getElementById('events-track') as HTMLElement;

    let current = 1; 

    const updateThumb = (index: number) => {
      // Divide el track en 3 posiciones (0, 1, 2)
      if (!thumb || !track) return;
      const trackWidth = track.clientWidth;
      const thumbWidth = thumb.clientWidth;
      const maxTravel = trackWidth - thumbWidth;
      const percentage = index / (eventsCount - 1);
      thumb.style.transform = `translateX(${percentage * maxTravel}px)`;
    };

    const goTo = (index: number) => {
      if (index < 0 || index >= eventsCount) return;

      cards.forEach((card, i) => {
        const isActive = i === index;
        card.classList.toggle('ev-card--active', isActive);
        card.setAttribute('aria-selected', isActive ? 'true' : 'false');
        
        // Efecto scroll para móviles: centra la tarjeta activa
        if (isActive && window.innerWidth <= 900) {
          card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });

      const oldPanel = document.querySelector<HTMLElement>('.detail-panel--active');
      const newPanel = panels[index];

      if (oldPanel && oldPanel !== newPanel) {
        oldPanel.classList.remove('detail-panel--active');
        oldPanel.setAttribute('aria-hidden', 'true');

        newPanel.classList.add('detail-panel--entering');
        newPanel.setAttribute('aria-hidden', 'false');
        void newPanel.offsetWidth;
        newPanel.classList.remove('detail-panel--entering');
        newPanel.classList.add('detail-panel--active');
      } else if (!oldPanel) {
        newPanel.classList.add('detail-panel--active');
        newPanel.setAttribute('aria-hidden', 'false');
      }

      current = index;
      updateThumb(index);
    };

    cards.forEach((card, i) => {
      card.addEventListener('click', () => goTo(i));
    });

    // Permitir clic en el track para navegar
    if (track) {
      track.addEventListener('click', (e) => {
        const rect = track.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const percentage = clickX / rect.width;
        
        if (percentage < 0.33) goTo(0);
        else if (percentage > 0.66) goTo(2);
        else goTo(1);
      });
    }

    goTo(1); // Inicializa en el centro
  });
</script>