---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import caselImg      from '../assets/noticias/casel.webp';
import lzn01Img      from '../assets/noticias/lzn246/LNZ246-01.webp';
import fabricaNotImg from '../assets/noticias/fabrica.webp';
import lzn02Img      from '../assets/noticias/lzn246/LNZ246-02.webp';
import lzn03Img      from '../assets/noticias/lzn246/LNZ246-03.webp';
import lzn04Img      from '../assets/noticias/lzn246/LNZ246-04.webp';
import n1Img         from '../assets/noticias/1.webp';
import n2Img         from '../assets/noticias/2.webp';
import n3Img         from '../assets/noticias/3.webp';
import n4Img         from '../assets/noticias/4.webp';
import n5Img         from '../assets/noticias/5.webp';
import n6Img         from '../assets/noticias/6.webp';
import n7Img         from '../assets/noticias/7.webp';
import n8Img         from '../assets/noticias/8.webp';
import n9Img         from '../assets/noticias/9.webp';
import n10Img        from '../assets/noticias/10.webp';
---

<Layout
  title="Eventos y Noticias — CLASSER | Astillero Fuentes"
  description="Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño."
  fixedNavbar={true}
>

  <!-- ============================================================
       MINI HERO
       ============================================================ -->
  <section
    class="mini-hero bg-bg-light text-center"
    aria-label="Noticias y eventos"
  >
    <div class="container-site">
      <h1 class="hero-title">Noticias y eventos</h1>
      <p class="hero-sub">
        Mantente actualizado con lo último del astillero, próximos eventos y premios de diseño.
      </p>
    </div>
  </section>


  <!-- ============================================================
       CARRUSEL DE CARDS — slider horizontal con scroll-snap
       ============================================================ -->
  <section
    class="news-slider"
    aria-label="Carrusel de noticias y eventos"
  >
    <!-- Track scrollable horizontal -->
    <div class="news-slider__track" role="list">

      <!-- ── Card 1: CACEL 2025 (lateral izquierda) ── -->
      <article
        class="news-slider__item"
        role="listitem"
        aria-label="Evento: CACEL 2025"
      >
        <div class="news-card__inner">
          <Image
            src={caselImg}
            alt="CACEL 2025 — Campeonato Argentino de Carreras en Villa María"
            width={400}
            height={280}
            loading="lazy"
            decoding="async"
            sizes="(max-width: 767px) 80vw, 297px"
            class="card-img"
          />
          <div class="card-body">
            <span class="badge">NOTICIAS</span>
            <p class="card-date">FEBRERO, 2025</p>
            <h3 class="card-heading">CACEL 2025</h3>
            <p class="card-desc">
              Participación en el Campeonato Argentino de Carreras de Embarcaciones Ligeras en Villa María.
            </p>
          </div>
        </div>
      </article>

      <!-- ── Card 2: Lanzamiento 246 (activa/central) ── -->
      <article
        class="news-slider__item news-slider__item--active"
        role="listitem"
        aria-label="Evento: Lanzamiento Classer 246"
      >
        <div class="news-card__inner news-card__inner--active">
          <Image
            src={lzn01Img}
            alt="Lanzamiento Classer 246 — presentación oficial del modelo"
            width={400}
            height={280}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            sizes="(max-width: 767px) 80vw, 297px"
            class="card-img"
          />
          <div class="card-body">
            <span class="badge">LANZAMIENTO</span>
            <p class="card-date">MARZO, 2025</p>
            <h3 class="card-heading">Lanzamiento 246</h3>
            <p class="card-desc">
              Experimenta las últimas innovaciones e historias del mundo de Classer. Desde eventos
              exclusivos hasta avances técnicos, descubre qué define nuestro legado.
            </p>
            <a href="#detalle-lanzamiento-246" class="card-cta">LEER ARTÍCULO →</a>
          </div>
        </div>
      </article>

      <!-- ── Card 3: Astillero Fuentes (lateral derecha) ── -->
      <article
        class="news-slider__item"
        role="listitem"
        aria-label="Evento: Astillero Fuentes"
      >
        <div class="news-card__inner">
          <Image
            src={fabricaNotImg}
            alt="Nuevas instalaciones Astillero Fuentes en Villa María, Córdoba"
            width={400}
            height={280}
            loading="lazy"
            decoding="async"
            sizes="(max-width: 767px) 80vw, 297px"
            class="card-img"
          />
          <div class="card-body">
            <span class="badge">NOTICIAS</span>
            <p class="card-date">ENERO, 2025</p>
            <h3 class="card-heading">Astillero Fuentes</h3>
            <p class="card-desc">
              Nuevas instalaciones y expansión del showroom en Villa María, Córdoba.
            </p>
          </div>
        </div>
      </article>

    </div><!-- /.news-slider__track -->

    <!-- Scrollbar news slider -->
    <div class="news-slider__scrollbar-wrap" aria-hidden="true">
      <div class="news-slider__scrollbar-track">
        <div class="news-slider__scrollbar-thumb"></div>
      </div>
    </div>

  </section><!-- /.news-slider -->


  <!-- ============================================================
       DETALLE DE ARTÍCULO — "Lanzamiento Classer 246"
       ============================================================ -->
  <section
    class="py-16 md:py-20 bg-white"
    id="detalle-lanzamiento-246"
    aria-label="Detalle del artículo: Lanzamiento Classer 246"
  >
    <div class="container-site">

      <h2 class="article-title">Lanzamiento Classer 246</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-start">

        <!-- Imagen del artículo -->
        <div>
          <Image
            src={lzn01Img}
            alt="Classer 246 en el agua durante el evento de lanzamiento"
           
            loading="lazy"
            decoding="async"
            sizes="(max-width: 767px) 100vw, 50vw"
            class="w-full rounded-sm"
          />
        </div>

        <!-- Texto: 3 párrafos -->
        <div class="flex flex-col gap-5">
          <p class="article-text">
            Contanos más sobre vos&hellip; Lorem ipsum dolor sit amet, consectetuer adipiscing elit,
            sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.
            Ut wisi enim ad minim veniam, quis nostrud exerci tation ullamcorper suscipit lobortis
            nisl ut aliquip ex ea commodo consequat. Duis autem vel eum iriure dolor in hendrerit
            in vulputate velit esse molestie consequat, vel illum dolore eu feugiat nulla facilisis
            at vero eros et accumsan et iusto odio dignissim qui blandit praesent luptatum zzril
            delenit augue duis dolore te feugiat nulla facilisi.
          </p>
          <p class="article-text">
            Nam liber tempor cum soluta nobis eligend optio congue nihil imperdiet doming id quod
            mazim placerat facer possim assum. Lorem ipsum dolor sit amet, consectetuer adipiscing
            elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat
            volutpat. Ut wisi enim ad minim veniam, quis nostrud exerci tation ullamcorper suscipit
            lobortis nisl ut aliquip ex ea commodo consequat.
          </p>
          <p class="article-text">
            Duis autem vel eum iriure dolor in hendrerit in vulputate velit esse molestie consequat,
            vel illum dolore eu feugiat nulla facilisis. At vero eos et accusam et justo duo dolores
            et ea rebum stet clita kasd gubergren, no sea takimata sanctus est lorem ipsum dolor
            sit amet.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       GALERÍA DE FOTOS — slider horizontal full-bleed
       ============================================================ -->
  <section class="photo-slider" aria-label="Galería de fotos del evento">

    <div class="photo-slider__track">
      <div class="photo-slider__item">
        <Image src={lzn02Img} alt="Lanzamiento Classer 246 — foto 1" width={760} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 38vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={lzn03Img} alt="Lanzamiento Classer 246 — foto 2" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={lzn04Img} alt="Lanzamiento Classer 246 — foto 3" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n1Img} alt="Lanzamiento Classer 246 — foto 4" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n2Img} alt="Lanzamiento Classer 246 — foto 5" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n3Img} alt="Lanzamiento Classer 246 — foto 6" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n4Img} alt="Lanzamiento Classer 246 — foto 7" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n5Img} alt="Lanzamiento Classer 246 — foto 8" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n6Img} alt="Lanzamiento Classer 246 — foto 9" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n7Img} alt="Lanzamiento Classer 246 — foto 10" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n8Img} alt="Lanzamiento Classer 246 — foto 11" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n9Img} alt="Lanzamiento Classer 246 — foto 12" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
      <div class="photo-slider__item">
        <Image src={n10Img} alt="Lanzamiento Classer 246 — foto 13" width={400} height={280} loading="lazy" decoding="async" sizes="(max-width: 767px) 80vw, 20vw" class="photo-img" />
      </div>
    </div>

    <div class="photo-slider__scrollbar-wrap" aria-hidden="true">
      <div class="photo-slider__scrollbar-track">
        <div class="photo-slider__scrollbar-thumb"></div>
      </div>
    </div>

  </section><!-- /.photo-slider -->

</Layout>


<style>
  /* ═══════════════════════════════════════════════════════════
     MINI HERO
  ═══════════════════════════════════════════════════════════ */

  .mini-hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    color: var(--color-text-dark);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(26, 26, 46, 0.65);
    max-width: 440px;
    margin-inline: auto;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .mini-hero {
      padding-top: 6.5rem;
      padding-bottom: 2.5rem;
    }
    .hero-title { font-size: clamp(1.75rem, 8vw, 2.25rem); }
    .hero-sub   { font-size: 0.9375rem; }
  }


  /* ═══════════════════════════════════════════════════════════
     NEWS SLIDER — contenedor y track horizontal con scroll-snap
  ═══════════════════════════════════════════════════════════ */

  .news-slider {
    width: 100%;
    overflow: hidden;
    position: relative;
    background-color: #ffffff;
    padding-block: 3rem;
  }

  .news-slider__track {
    display: flex;
    flex-direction: row;              /* horizontal */
    align-items: center;
    overflow-x: scroll;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding-top: 24px;
    padding-bottom: 24px;
    /* centra la card activa de 660px; mínimo 24px en pantallas pequeñas */
    padding-left: max(24px, calc((100% - 660px) / 2));
    padding-right: max(24px, calc((100% - 660px) / 2));
  }

  .news-slider__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Items ───────────────────────────────────────────────── */

  .news-slider__item {
    flex: 0 0 660px;
    min-width: 0;
    scroll-snap-align: center;
    border-radius: 16px;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .news-slider__item--active {
    opacity: 1;
  }

  /* ── Card inner layout (2 columnas: imagen izq + texto der) ── */

  .news-card__inner {
    display: grid;
    grid-template-columns: 45% 55%;
    min-height: 280px;
    border-radius: 16px;
    overflow: hidden;
    background-color: #ffffff;
    border: 1px solid #e8e8e8;
  }

  .news-card__inner--active {
    background-color: #edeaf7;
    border: none;
  }

  /* ── Card image slot ────────────────────────────────────── */

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Card text area ─────────────────────────────────────── */

  .card-body {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
  }

  .badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-barlow);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 99px;
    background-color: #111111;
    color: #ffffff;
  }

  .card-date {
    font-family: var(--font-barlow);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #888888;
    margin-top: 14px;
  }

  .card-heading {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: #111111;
    line-height: 1.3;
    margin-top: 6px;
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: #555555;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 10px;
  }

  .card-cta {
    display: inline-block;
    margin-top: 20px;
    font-family: var(--font-barlow);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-accent-blue, #1E7DC8);
    text-decoration: none;
  }

  .card-cta:hover {
    text-decoration: underline;
  }


  /* ═══════════════════════════════════════════════════════════
     SCROLLBAR COMPARTIDA — news slider y galería
  ═══════════════════════════════════════════════════════════ */

  .news-slider__scrollbar-wrap {
    display: flex;
    justify-content: center;
    padding: 14px 0 18px;
  }

  .news-slider__scrollbar-track {
    position: relative;
    width: 200px;
    height: 4px;
    background-color: #e0e0e0;
    border-radius: 99px;
    cursor: pointer;
  }

  .news-slider__scrollbar-thumb {
    position: absolute;
    top: 0;
    left: 0;
    height: 4px;
    background-color: #111111;
    border-radius: 99px;
    cursor: grab;
    transition: background-color 0.2s;
  }

  .news-slider__scrollbar-thumb:active {
    cursor: grabbing;
    background-color: #333;
  }


  /* ═══════════════════════════════════════════════════════════
     ARTICLE DETAIL
  ═══════════════════════════════════════════════════════════ */

  .article-title {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #1a1a2e;
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  .article-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(26, 26, 46, 0.80);
    line-height: 1.8;
  }


  /* ═══════════════════════════════════════════════════════════
     PHOTO SLIDER — galería full-bleed con 4 fotos
  ═══════════════════════════════════════════════════════════ */

  .photo-slider {
    width: 100%;
    overflow: hidden;
    margin-top: 0;
    padding-bottom: 0;
    background-color: #ffffff;
  }

  .photo-slider__track {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    gap: 4px;
    padding: 0;
  }

  .photo-slider__track::-webkit-scrollbar {
    display: none;
  }

  .photo-slider__item {
    flex-shrink: 0;
    scroll-snap-align: start;
    height: 280px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #1a1f1a;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Proporciones por posición */
  .photo-slider__item:nth-child(1) { flex: 0 0 38%; }
  .photo-slider__item:nth-child(2) { flex: 0 0 20%; }
  .photo-slider__item:nth-child(3) { flex: 0 0 20%; }
  .photo-slider__item:nth-child(4) { flex: 0 0 20%; }

  /* ── Scrollbar personalizada ─────────────────────── */

  .photo-slider__scrollbar-wrap {
    display: flex;
    justify-content: center;
    padding: 14px 0 18px;
  }

  .photo-slider__scrollbar-track {
    position: relative;
    width: 200px;
    height: 4px;
    background-color: #e0e0e0;
    border-radius: 99px;
    cursor: pointer;
  }

  .photo-slider__scrollbar-thumb {
    position: absolute;
    top: 0;
    left: 0;
    height: 4px;
    background-color: #111111;
    border-radius: 99px;
    cursor: grab;
    transition: background-color 0.2s;
  }

  .photo-slider__scrollbar-thumb:active {
    cursor: grabbing;
    background-color: #333;
  }


  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE — MOBILE (< 768px)
  ═══════════════════════════════════════════════════════════ */

  @media (max-width: 767px) {

    /* News slider: cards 85vw, centra con peek lateral */
    .news-slider__item {
      flex: 0 0 85vw;
    }

    .news-slider__track {
      padding-left: calc((100% - 85vw) / 2);
      padding-right: calc((100% - 85vw) / 2);
    }

    /* Card: stack imagen arriba, texto abajo */
    .news-card__inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }

    .card-img {
      min-height: 150px;
      height: 150px;
    }

    /* Photo slider: cada foto 80vw en scroll horizontal */
    .photo-slider__item {
      flex: 0 0 80vw !important;
      height: 220px;
    }
  }
</style>


<script>
  document.addEventListener('DOMContentLoaded', () => {

    // ── NEWS SLIDER ─────────────────────────────────────────
    const track    = document.querySelector<HTMLElement>('.news-slider__track');
    const cards    = document.querySelectorAll<HTMLElement>('.news-slider__item');
    const nsSbTrack = document.querySelector<HTMLElement>('.news-slider__scrollbar-track');
    const nsSbThumb = document.querySelector<HTMLElement>('.news-slider__scrollbar-thumb');

    if (track && cards.length) {

      const setActiveCard = (index: number) => {
        cards.forEach((card, i) => {
          card.classList.toggle('news-slider__item--active', i === index);
        });
      };

      const scrollToCard = (index: number) => {
        const card = cards[index] as HTMLElement;
        const targetLeft = card.offsetLeft - (track.clientWidth - card.offsetWidth) / 2;
        track.scrollTo({ left: targetLeft, behavior: 'smooth' });
      };

      // Scrollbar sync
      if (nsSbTrack && nsSbThumb) {
        const updateNsThumb = () => {
          const scrollable = track.scrollWidth - track.clientWidth;
          if (scrollable <= 0) return;
          const ratio     = track.clientWidth / track.scrollWidth;
          const thumbW    = Math.max(nsSbTrack.clientWidth * ratio, 32);
          const thumbLeft = (track.scrollLeft / scrollable) * (nsSbTrack.clientWidth - thumbW);
          nsSbThumb.style.width = `${thumbW}px`;
          nsSbThumb.style.left  = `${thumbLeft}px`;
        };

        track.addEventListener('scroll', updateNsThumb, { passive: true });
        window.addEventListener('resize', updateNsThumb);
        updateNsThumb();

        let nsDragging = false, nsDragStartX = 0, nsDragStartScroll = 0;
        nsSbThumb.addEventListener('mousedown', (e: MouseEvent) => {
          nsDragging = true; nsDragStartX = e.clientX; nsDragStartScroll = track.scrollLeft;
          e.preventDefault();
        });
        document.addEventListener('mousemove', (e: MouseEvent) => {
          if (!nsDragging) return;
          const scrollable = track.scrollWidth - track.clientWidth;
          const ratio = scrollable / (nsSbTrack.clientWidth - nsSbThumb.offsetWidth);
          track.scrollLeft = nsDragStartScroll + (e.clientX - nsDragStartX) * ratio;
        });
        document.addEventListener('mouseup', () => { nsDragging = false; });
        nsSbTrack.addEventListener('click', (e: MouseEvent) => {
          if (e.target === nsSbThumb) return;
          const rect = nsSbTrack.getBoundingClientRect();
          const scrollable = track.scrollWidth - track.clientWidth;
          track.scrollLeft = ((e.clientX - rect.left) / nsSbTrack.clientWidth) * scrollable;
        });
      }

      // Activa card según scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const index = [...cards].indexOf(entry.target as HTMLElement);
              if (index !== -1) setActiveCard(index);
            }
          });
        },
        { root: track, threshold: 0.6 }
      );
      cards.forEach(card => observer.observe(card));

      // Inicializar en card 2 (Lanzamiento 246)
      const initCard = cards[1];
      if (initCard) {
        track.scrollLeft = (initCard as HTMLElement).offsetLeft - (track.clientWidth - (initCard as HTMLElement).offsetWidth) / 2;
        setActiveCard(1);
      }

      // Autoplay
      let autoplayTimer: ReturnType<typeof setInterval> | undefined;
      let activeIndex = 1;

      const advanceSlide = () => {
        activeIndex = (activeIndex + 1) % cards.length;
        scrollToCard(activeIndex);
      };

      const stopAutoplay = () => { if (autoplayTimer !== undefined) clearInterval(autoplayTimer); };
      const startAutoplay = () => { stopAutoplay(); autoplayTimer = setInterval(advanceSlide, 5000); };

      const indexObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const i = [...cards].indexOf(entry.target as HTMLElement);
              if (i !== -1) activeIndex = i;
            }
          });
        },
        { root: track, threshold: 0.6 }
      );
      cards.forEach(card => indexObserver.observe(card));

      track.addEventListener('mouseenter', stopAutoplay);
      track.addEventListener('touchstart', stopAutoplay, { passive: true });
      track.addEventListener('mouseleave', () => { setTimeout(startAutoplay, 3000); });
      startAutoplay();
    }


    // ── GALERÍA DE FOTOS — scrollbar arrastrable ────────────
    const photoTrack  = document.querySelector<HTMLElement>('.photo-slider__track');
    const sbTrack     = document.querySelector<HTMLElement>('.photo-slider__scrollbar-track');
    const sbThumb     = document.querySelector<HTMLElement>('.photo-slider__scrollbar-thumb');

    if (photoTrack && sbTrack && sbThumb) {

      const updateThumb = () => {
        const scrollable = photoTrack.scrollWidth - photoTrack.clientWidth;
        if (scrollable <= 0) return;
        const ratio      = photoTrack.clientWidth / photoTrack.scrollWidth;
        const thumbW     = Math.max(sbTrack.clientWidth * ratio, 32);
        const thumbLeft  = (photoTrack.scrollLeft / scrollable) * (sbTrack.clientWidth - thumbW);
        sbThumb.style.width = `${thumbW}px`;
        sbThumb.style.left  = `${thumbLeft}px`;
      };

      photoTrack.addEventListener('scroll', updateThumb, { passive: true });
      window.addEventListener('resize', updateThumb);
      updateThumb();

      // Arrastrar el thumb con el mouse
      let dragging = false;
      let dragStartX = 0;
      let dragStartScroll = 0;

      sbThumb.addEventListener('mousedown', (e: MouseEvent) => {
        dragging = true;
        dragStartX = e.clientX;
        dragStartScroll = photoTrack.scrollLeft;
        e.preventDefault();
      });

      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (!dragging) return;
        const scrollable = photoTrack.scrollWidth - photoTrack.clientWidth;
        const thumbW     = sbThumb.offsetWidth;
        const trackW     = sbTrack.clientWidth;
        const ratio      = scrollable / (trackW - thumbW);
        photoTrack.scrollLeft = dragStartScroll + (e.clientX - dragStartX) * ratio;
      });

      document.addEventListener('mouseup', () => { dragging = false; });

      // Click en el track (fuera del thumb) salta a esa posición
      sbTrack.addEventListener('click', (e: MouseEvent) => {
        if (e.target === sbThumb) return;
        const rect       = sbTrack.getBoundingClientRect();
        const clickRatio = (e.clientX - rect.left) / sbTrack.clientWidth;
        const scrollable = photoTrack.scrollWidth - photoTrack.clientWidth;
        photoTrack.scrollLeft = clickRatio * scrollable;
      });
    }

  });
</script>