---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import heroSource from '../assets/home/slider-1.webp';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideNavbar?: boolean;
  hideFooter?: boolean;
  fixedNavbar?: boolean;
  noScroll?: boolean;
  preloadHero?: boolean;
}

const {
  title = 'CLASSER — Astillero Fuentes | Lanchas de Lujo desde 1972',
  description = 'Creando experiencias trascendentales en el agua desde 1972. Diseñado en Italia, construido para el mundo.',
  ogImage,
  hideNavbar = false,
  hideFooter = false,
  fixedNavbar = true,
  noScroll = false,
  preloadHero = false,
} = Astro.props;

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const heroPreload = preloadHero
  ? await getImage({ src: heroSource, width: 1200, format: 'avif', quality: 82 })
  : null;

const FONTS_URL =
  'https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,600;0,700;0,800;1,600;1,700;1,800&family=Barlow:wght@400;500&family=Inter:wght@300;400;500;600&display=swap';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://classer.com.ar');
const ogImageFinal = ogImage ?? 'https://classer.com.ar/og-default.jpg';
---
<!doctype html>
<html lang="es" class={noScroll ? 'overflow-hidden' : ''}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0e1a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="CLASSER — Astillero Fuentes" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFinal} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/image/AF 2.webp" />

    <title>{title}</title>

    <!-- Google Fonts — carga no bloqueante (preload+onload trick) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href={FONTS_URL}
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href={FONTS_URL} />
    </noscript>

    <!-- Hero preload (solo en páginas con hero slider) -->
    {heroPreload && (
      <link
        rel="preload"
        as="image"
        href={heroPreload.src}
        type="image/avif"
        fetchpriority="high"
      />
    )}
  </head>
  <body class={noScroll ? 'h-screen overflow-hidden' : ''}>
    {!hideNavbar && <Navbar isFixed={fixedNavbar} />}
    <main id="main-content">
      <slot />
    </main>
    {!hideFooter && <Footer />}

    {!hideNavbar && (
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll<HTMLElement>('.reveal:not([data-animated])').forEach(el => {
          gsap.fromTo(el,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 82%',
              },
            }
          );
          el.dataset.animated = 'true';
        });
      });
    </script>
    <a
      href="https://wa.me/543534781206"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="wa-btn"
    >
      <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012 .05C5.495.05.05 5.495.05 12c0 2.12.553 4.105 1.538 5.835L.057 24l6.304-1.654A11.882 11.882 0 0012 23.95c6.505 0 11.95-5.445 11.95-11.95 0-3.193-1.244-6.195-3.504-8.453"/>
      </svg>
    </a>
    )}

    <style>
      .wa-btn {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 100;
        width: 56px;
        height: 56px;
        border-radius: 9999px;
        background: #25d366;
        box-shadow: 0 4px 16px rgba(37, 211, 102, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 200ms ease, box-shadow 200ms ease;
      }
      .wa-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.55);
      }
      .wa-btn:focus-visible {
        outline: 2px solid #25d366;
        outline-offset: 3px;
      }
    </style>
  </body>
</html>