---
import { Image } from 'astro:assets';
import { models } from '../data/models';
import classerLogo from '../assets/brand/CLASSER 1.webp';

interface Props {
  isFixed?: boolean;
}

const { isFixed = false } = Astro.props;
---

<header
  id="navbar"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${isFixed ? 'navbar-visible' : 'navbar-hidden'}`}
  style="height: 72px;"
  data-is-fixed={isFixed.toString()}
>
  <div class="container-site h-full flex items-center justify-between">

    <a href="/" class="flex-shrink-0" aria-label="CLASSER — Astillero Fuentes">
      <Image src={classerLogo} alt="" width={200} format="webp" quality={85} loading="eager" decoding="async" class="text-white color-white invert" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
      <a href="/" class="text-sm font-medium text-text-secondary hover:text-white transition-colors cursor-pointer">Inicio</a>

      <!-- Modelos trigger — hover activates mega menu -->
      <div id="models-trigger" role="navigation" aria-label="Modelos">
        <button
          type="button"
          class="text-sm font-medium text-text-secondary hover:text-white transition-colors flex items-center gap-1 cursor-pointer"
          aria-haspopup="true"
          aria-expanded="false"
          id="modelos-btn"
        >
          Modelos
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="mt-0.5" aria-hidden="true">
            <path d="M6 8L2 4h8L6 8z"/>
          </svg>
        </button>
      </div>

      <a href="/legado" class="text-sm font-medium text-text-secondary hover:text-white transition-colors cursor-pointer">Legado</a>
      <a href="/eventos" class="text-sm font-medium text-text-secondary hover:text-white transition-colors cursor-pointer">Eventos</a>
      <a href="/contacto" class="text-sm font-medium border border-accent-blue text-accent-blue hover:bg-accent-blue hover:text-white transition-all duration-200 px-4 py-2 rounded cursor-pointer">Contacto</a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer" aria-label="Abrir menú" aria-expanded="false">
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="ham-line1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="ham-line2"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="ham-line3"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="md:hidden hidden bg-bg-dark border-t border-white/10" role="dialog" aria-label="Menú móvil">
    <div class="container-site py-6 flex flex-col gap-0">
      <a href="/" class="text-white text-base font-medium py-3 border-b border-white/10">Inicio</a>

      <!-- Mobile Modelos — tap to expand submenu -->
      <div>
        <button
          id="mobile-models-btn"
          type="button"
          class="w-full flex items-center justify-between text-white text-base font-medium py-3 border-b border-white/10 cursor-pointer"
          aria-expanded="false"
        >
          <span>Modelos</span>
          <svg
            id="mobile-models-chevron"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
            style="transition: transform 200ms ease; flex-shrink: 0;"
            aria-hidden="true"
          >
            <path d="M8 10L4 6h8L8 10z"/>
          </svg>
        </button>

        <!-- Text-only submenu — no thumbnails on mobile -->
        <div id="mobile-models-submenu" class="hidden flex-col" style="background: rgba(255,255,255,0.03);">
          {models.map(model => (
            <a
              href={`/classer/${model.slug}`}
              class="flex items-center justify-between"
              style="
                padding: 0.75rem 1rem;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                color: rgba(255,255,255,0.7);
                font-size: 0.9rem;
                text-decoration: none;
              "
            >
              <span>{model.name}</span>
              <span style="color: rgba(255,255,255,0.35); font-size: 0.75rem;">{model.eslora}</span>
            </a>
          ))}
        </div>
      </div>

      <a href="/legado" class="text-white text-base font-medium py-3 border-b border-white/10">Legado</a>
      <a href="/eventos" class="text-white text-base font-medium py-3 border-b border-white/10">Eventos</a>
      <a href="/contacto" class="inline-block border border-accent-blue text-accent-blue px-4 py-2 rounded text-sm font-medium mt-4 text-center">Contacto</a>
    </div>
  </div>
</header>

<!-- ─── MEGA MENU — position: fixed, always 100vw ───────────── -->
<!-- Placed outside <header> so it can freely span the viewport -->
<div
  id="models-mega-menu"
  class="mega-hidden"
  role="region"
  aria-label="Catálogo de modelos Classer"
>
  <div class="max-w-6xl mx-auto flex flex-row justify-center" style="gap: 2px; align-items: flex-start;">
    {models.map(model => (
      <a
        href={`/classer/${model.slug}`}
        class="mega-card group flex flex-col items-center"
      >
        <!-- Thumbnail -->
        <div class="relative overflow-hidden rounded-lg" style="width: 160px; height: 110px; background: #e8e8e8; flex-shrink: 0;">
          <img
            src={model.thumbnailUrl}
            alt={model.name}
            width="160"
            height="110"
            style="width: 100%; height: 100%; object-fit: cover; transition: transform 300ms ease;"
            class="group-hover:scale-[1.04]"
            loading="lazy"
          />
          {model.badge && (
            <span
              class="absolute top-2 right-2"
              style={`font-size: 0.55rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.125rem 0.5rem; border-radius: 9999px; ${model.badge === 'NUEVO' ? 'background: #1e90d4; color: #ffffff;' : 'background: #1a2035; color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.2);'}`}
            >
              {model.badge}
            </span>
          )}
        </div>

        <!-- Text below thumbnail -->
        <div class="mt-3 text-center">
          <p
            class="font-display font-bold group-hover:text-accent-blue transition-colors"
            style="font-size: 0.82rem; color: #0a0e1a; line-height: 1.2;"
          >
            {model.name}
          </p>
          <p style="font-size: 0.7rem; color: #9ca3af; margin-top: 0.125rem;">
            {model.eslora}
          </p>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  /* ── Navbar visibility states ──────────────────────────────── */
  #navbar {
    transition: transform 0.4s ease, opacity 0.4s ease, background-color 0.3s ease;
  }
  .navbar-hidden {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }
  .navbar-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: all;
    background-color: #0f1525;
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 20px rgba(0,0,0,0.6);
  }

  /* ── Mega menu base ─────────────────────────────────────────── */
  #models-mega-menu {
    position: fixed;
    top: 72px;
    left: 0;
    width: 100vw;
    background: #ffffff;
    border-top: 1px solid rgba(0,0,0,0.08);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    padding: 1.5rem 2rem;
    z-index: 49;
  }

  /* ── Mega menu visibility toggle ───────────────────────────── */
  .mega-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .mega-visible {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
    transition: opacity 200ms ease, transform 200ms ease;
  }

  /* ── Mega card ──────────────────────────────────────────────── */
  .mega-card {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 150ms ease;
  }
  .mega-card:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  /* ── Hide mega menu on mobile (hover doesn't apply) ─────────── */
  @media (max-width: 767px) {
    #models-mega-menu {
      display: none !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const navbar          = document.getElementById('navbar');
  const introHeader     = document.getElementById('intro-header');
  const mobileMenuBtn   = document.getElementById('mobile-menu-btn');
  const mobileMenu      = document.getElementById('mobile-menu');
  const hamLine1        = document.getElementById('ham-line1');
  const hamLine2        = document.getElementById('ham-line2');
  const hamLine3        = document.getElementById('ham-line3');

  // ── Navbar reveal on scroll — vanilla JS ─────────────────────
  function updateNavbar(): void {
    if (navbar?.dataset.isFixed === 'true') return;
    
    const threshold = introHeader?.offsetHeight ?? 200;
    if (window.scrollY > threshold) {
      navbar?.classList.remove('navbar-hidden');
      navbar?.classList.add('navbar-visible');
    } else {
      navbar?.classList.remove('navbar-visible');
      navbar?.classList.add('navbar-hidden');
    }
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // ── Mega menu hover — vanilla JS ─────────────────────────────
  const trigger  = document.getElementById('models-trigger');
  const megaMenu = document.getElementById('models-mega-menu');
  let hideTimeout: ReturnType<typeof setTimeout>;

  function showMenu(): void {
    clearTimeout(hideTimeout);
    megaMenu?.classList.remove('mega-hidden');
    megaMenu?.classList.add('mega-visible');
    document.getElementById('modelos-btn')?.setAttribute('aria-expanded', 'true');
  }

  function hideMenu(): void {
    hideTimeout = setTimeout(() => {
      megaMenu?.classList.remove('mega-visible');
      megaMenu?.classList.add('mega-hidden');
      document.getElementById('modelos-btn')?.setAttribute('aria-expanded', 'false');
    }, 120);
  }

  trigger?.addEventListener('mouseenter', showMenu);
  trigger?.addEventListener('mouseleave', hideMenu);
  megaMenu?.addEventListener('mouseenter', showMenu);
  megaMenu?.addEventListener('mouseleave', hideMenu);

  // ── Mobile hamburger toggle ───────────────────────────────────
  let menuOpen = false;
  mobileMenuBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenuBtn.setAttribute('aria-expanded', String(menuOpen));
    if (menuOpen) {
      mobileMenu?.classList.remove('hidden');
      gsap.fromTo(mobileMenu, { y: -10, opacity: 0 }, { y: 0, opacity: 1, duration: 0.25, ease: 'power2.out' });
      gsap.to(hamLine1, { rotation: 45, y: 8, duration: 0.2 });
      gsap.to(hamLine2, { opacity: 0, duration: 0.2 });
      gsap.to(hamLine3, { rotation: -45, y: -8, duration: 0.2 });
    } else {
      gsap.to(mobileMenu, {
        y: -10, opacity: 0, duration: 0.2, ease: 'power2.in',
        onComplete: () => mobileMenu?.classList.add('hidden'),
      });
      gsap.to(hamLine1, { rotation: 0, y: 0, duration: 0.2 });
      gsap.to(hamLine2, { opacity: 1, duration: 0.2 });
      gsap.to(hamLine3, { rotation: 0, y: 0, duration: 0.2 });
    }
  });

  // ── Mobile models submenu toggle ──────────────────────────────
  const mobileModelsBtn      = document.getElementById('mobile-models-btn');
  const mobileModelsSubmenu  = document.getElementById('mobile-models-submenu');
  const mobileModelsChevron  = document.getElementById('mobile-models-chevron') as HTMLElement | null;
  let modelsOpen = false;

  mobileModelsBtn?.addEventListener('click', () => {
    modelsOpen = !modelsOpen;
    mobileModelsBtn.setAttribute('aria-expanded', String(modelsOpen));
    if (modelsOpen) {
      mobileModelsSubmenu?.classList.remove('hidden');
      mobileModelsSubmenu?.classList.add('flex');
      if (mobileModelsChevron) mobileModelsChevron.style.transform = 'rotate(180deg)';
    } else {
      mobileModelsSubmenu?.classList.remove('flex');
      mobileModelsSubmenu?.classList.add('hidden');
      if (mobileModelsChevron) mobileModelsChevron.style.transform = 'rotate(0deg)';
    }
  });
</script>
