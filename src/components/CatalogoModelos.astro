---
import { models } from '../data/models';

const iconMap: Record<string, string> = {
  ruler: 'ESLORA.webp',
  users: 'CAPACIDAD.webp',
  lightning: 'MOTORIZACION.webp',
};

// --- Mapeo de Datos Técnicos Reales ---
const realSpecs: Record<string, { eslora: string; personas: string; motor: string }> = {
  '246':      { eslora: '7,40 m', personas: '14', motor: '200 a 350 hp' },
  '246 SURF': { eslora: '7,40 m', personas: '14', motor: '200 a 350 hp' },
  '246 OB':   { eslora: '7,40 m', personas: '14', motor: '200 a 350 hp' },
  '206 FTX':  { eslora: '6,08 m', personas: '9',  motor: '150 a 200 hp' },
  '186':      { eslora: '5,80 m', personas: '8',  motor: '115 a 150 hp' },
  '170':      { eslora: '5,70 m', personas: '7',  motor: '90 a 150 hp' },
  '165':      { eslora: '5,30 m', personas: '6',  motor: '70 a 115 hp' },
};

const siluetaFileMap: Record<string, string> = {
  '246': '246 DF',
  '246 SURF': '246 SURF',
  '246 OB': '246 OB',
  '206 FTX': '206 FTX',
};

function getSiluetaUrl(name: string): string {
  const key = name.replace('Classer ', '');
  const filename = siluetaFileMap[key] ?? key;
  return `/image/siluetas/${encodeURIComponent(filename)}.webp`;
}

const groupedModels = models.reduce((acc, model) => {
  const line = model.line || 'OTROS';
  if (!acc[line]) acc[line] = [];
  acc[line].push(model);
  return acc;
}, {} as Record<string, typeof models>);

const lines = Object.keys(groupedModels);
---

<section class="catalogo-container">
  <div id="catalogo-scroll" class="scroll-wrapper">
    {lines.map((line) => {
      const parts = line.split(' ');
      const prefix = parts[0]; 
      const suffix = parts.slice(1).join(' ');
      const lineModels = groupedModels[line];

      return (
        <div class="linea-group">
          <div class="linea-header">
            <div class="header-curve-container">
              
            </div>
            <div class="header-text-container">
              <span class="line-label">{prefix} <strong>{suffix}</strong></span>
              <div class="header-divider-flat"></div>
            </div>
          </div>

          <div class="cards-flex">
            {lineModels.map((model) => {
              const modelKey = model.name.replace('Classer ', '');
              const specs = realSpecs[modelKey] || { eslora: 'TBD', personas: 'TBD', motor: 'TBD' };
              
              return (
                <a href={`/classer/${model.slug}`} class="model-card">
                  <div class="model-info">
                    <h3 class="model-name">{modelKey}</h3>
                    <div class="model-visual">
                      <img 
                        src={getSiluetaUrl(model.name)} 
                        alt={model.name} 
                        class="silhouette-img"
                        loading="lazy"
                      />
                    </div>
                  </div>

                  <div class="model-specs">
                    <div class="spec-unit">
                      <div class="spec-top">
                        <img src={`/image/iconos/${iconMap['ruler']}`} alt="" class="spec-icon" />
                        <span class="spec-label">ESLORA</span>
                      </div>
                      <span class="spec-value">{specs.eslora}</span>
                    </div>

                    <div class="spec-unit">
                      <div class="spec-top">
                        <img src={`/image/iconos/${iconMap['users']}`} alt="" class="spec-icon" />
                        <span class="spec-label">PERSONAS</span>
                      </div>
                      <span class="spec-value">{specs.personas}</span>
                    </div>

                    <div class="spec-unit">
                      <div class="spec-top">
                        <img src={`/image/iconos/${iconMap['lightning']}`} alt="" class="spec-icon" />
                        <span class="spec-label">MOTORIZACIÓN</span>
                      </div>
                      <span class="spec-value">{specs.motor}</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <div class="progress-container">
    <div id="catalogo-track" class="custom-track">
      <div id="catalogo-thumb" class="custom-thumb"></div>
    </div>
  </div>
</section>

<script>
  const setupCatalogoScroll = () => {
    const container = document.getElementById('catalogo-scroll') as HTMLElement;
    const track = document.getElementById('catalogo-track') as HTMLElement;
    const thumb = document.getElementById('catalogo-thumb') as HTMLElement;

    if (!container || !track || !thumb) return;

    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let velocity = 0;
    let rafId: number;
    let lastPosX: number;

    const updateThumb = () => {
      const maxScroll = container.scrollWidth - container.clientWidth;
      if (maxScroll <= 0) {
          thumb.style.display = 'none';
          return;
      }
      thumb.style.display = 'block';

      const scrollPercentage = container.scrollLeft / maxScroll;
      const maxThumbTravel = track.clientWidth - thumb.clientWidth;
      const thumbPosition = scrollPercentage * maxThumbTravel;
      
      thumb.style.transform = `translateX(${thumbPosition}px)`;
    };

    const applyInertia = () => {
      if (isDown) return; 
      if (Math.abs(velocity) > 0.1) {
        container.scrollLeft += velocity;
        velocity *= 0.95; 
        updateThumb();
        rafId = requestAnimationFrame(applyInertia);
      }
    };

    container.addEventListener('mousedown', (e) => {
      isDown = true;
      container.classList.add('cursor-grabbing');
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
      velocity = 0;
      cancelAnimationFrame(rafId);
    });

    window.addEventListener('mouseup', () => {
      if (!isDown) return;
      isDown = false;
      container.classList.remove('cursor-grabbing');
      applyInertia(); 
    });

    window.addEventListener('mouseleave', () => {
        if (!isDown) return;
        isDown = false;
        container.classList.remove('cursor-grabbing');
        applyInertia();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX);
      velocity = (lastPosX - e.pageX) * 0.8; 
      lastPosX = e.pageX;
      container.scrollLeft = scrollLeft - walk;
      updateThumb();
    });

    let isDraggingThumb = false;
    let thumbStartX: number;
    let thumbStartScroll: number;

    thumb.addEventListener('mousedown', (e) => {
      isDraggingThumb = true;
      thumbStartX = e.pageX;
      thumbStartScroll = container.scrollLeft;
      container.classList.add('cursor-grabbing');
      document.body.style.userSelect = 'none'; 
      e.stopPropagation(); 
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDraggingThumb) return;
      const deltaX = e.pageX - thumbStartX;
      const trackWidth = track.clientWidth;
      const thumbWidth = thumb.clientWidth;
      const maxThumbTravel = trackWidth - thumbWidth;
      const maxScroll = container.scrollWidth - container.clientWidth;
      
      if(maxThumbTravel > 0) {
          const scrollMove = (deltaX / maxThumbTravel) * maxScroll;
          container.scrollLeft = thumbStartScroll + scrollMove;
          updateThumb();
      }
    });

    window.addEventListener('mouseup', () => {
      isDraggingThumb = false;
      document.body.style.userSelect = '';
      container.classList.remove('cursor-grabbing');
    });

    track.addEventListener('click', (e) => {
      if (e.target === thumb) return;
      const rect = track.getBoundingClientRect();
      const clickPositionRatio = (e.clientX - rect.left) / rect.width;
      const targetScroll = clickPositionRatio * (container.scrollWidth - container.clientWidth);
      container.scrollTo({ left: targetScroll, behavior: 'smooth' });
    });

    container.addEventListener('touchstart', () => { cancelAnimationFrame(rafId); }, { passive: true });
    container.addEventListener('scroll', updateThumb, { passive: true });
    window.addEventListener('resize', updateThumb);

    updateThumb();
  };

  document.addEventListener('astro:page-load', setupCatalogoScroll);
  setupCatalogoScroll();
</script>

<style>
  :root {
    --bg-gray: #f0f0ee;
    --text-black: #000000 !important; 
    --line-gray: #cccbc8;
    --font-barlow: 'Rogue Sans Nova Condensed', sans-serif;
  }

  .catalogo-container {
    background-color: var(--bg-gray);
    width: 100%;
    overflow: hidden;
    padding-top: 1rem; /* Reduciendo más */
    padding-bottom: 2rem; /* Reduciendo más */
  }

  .scroll-wrapper {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    padding-left: 5vw; /* Margen un poco más dinámico */
    gap: 3rem; /* Espacio entre grupos reducido para mayor cohesión */
    scroll-behavior: auto; 
    overscroll-behavior-x: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  .scroll-wrapper::-webkit-scrollbar { display: none; }

  .linea-group {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
  }

  /* --- HEADER --- */
  .linea-header {
    width: 100%;
    margin-bottom: 1.5rem; /* Menos espacio entre título y lanchas */
    display: flex;
    flex-direction: column;
    position: relative;
    padding-left: 2rem; 
  }

  .header-curve-container {
    width: 100%;
    height: 25px; /* Curva un poco más discreta */
    overflow: hidden;
    margin-bottom: -1px; 
  }

  .header-curve-img {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    object-position: left center;
    opacity: 0.25; 
  }

  .header-text-container {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: -8px; 
    position: relative;
    z-index: 1;
  }

  .line-label {
    font-family: var(--font-barlow);
    font-size: 2.4rem; /* Antes 2.8rem */
    text-transform: uppercase;
    font-style: italic;
    white-space: nowrap;
    color: #000000 !important;
    letter-spacing: -0.02em;
  }

  .line-label strong { font-weight: 850; }

  .header-divider-flat {
    height: 1px;
    background-color: #000000;
    flex-grow: 1;
    opacity: 0.8;
  }

  /* --- CARDS --- */
  .cards-flex {
    display: flex;
    gap: 0; 
  }

  .model-card {
    /* AQUÍ ESTÁ LA MAGIA DEL TAMAÑO: clamp para que sea responsivo y deje asomar a la 3ra lancha */
    width: clamp(320px, 35vw, 420px); 
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    padding: 0 2.5rem; /* Menos padding lateral */
    border-right: 1px solid rgba(0,0,0,0.06);
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .model-card:last-child {
    border-right: none;
  }

  .model-name {
    font-family: var(--font-barlow);
    font-size: clamp(2.5rem, 4.5vw, 4.2rem); 
    font-weight: 900;
    font-style: italic;
    color: #000000 !important;
    margin: 0;
    line-height: 0.85;
    text-align: center;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .model-visual {
    width: 100%;
    height: 120px; /* Reducido de 150px a 120px */
    display: flex;
    align-items: flex-end;
    justify-content: center;
    margin: 1rem 0 1.5rem 0; /* Márgenes aún más compactos */
  }

  .silhouette-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .model-card:hover .silhouette-img {
    transform: scale(1.04) translateZ(0); /* Efecto hover sutil */
  }

 /* --- SPECS --- */
  .model-specs {
    display: flex;
    justify-content: space-between;
    width: 100%;
    border-top: 1.5px solid #000000;
    padding-top: 1rem; /* De 1.25 a 1.0 */
  }

  .spec-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px; /* Reducido de 120px */
  }

  .spec-top {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
  }

  .spec-icon {
    width: 22px; /* Reduciendo 1 punto */
    height: 22px;
    filter: brightness(0);
  }

  .spec-label {
    font-family: var(--font-barlow);
    font-size: 1.05rem; /* Ajuste final */
    font-weight: 800;
    letter-spacing: 0.05em;
    color: #000000 !important;
  }

  .spec-value {
    font-family: var(--font-barlow);
    font-size: 1.45rem; /* Ajuste final */
    font-weight: 500;
    color: #000000 !important;
  }

  /* --- SCROLLBAR CUSTOM --- */
  .progress-container {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 2.5rem; /* Más cerca del contenido */
  }

  .custom-track {
    width: 300px; /* Barra un poco más corta para acompañar la escala */
    height: 5px;
    background: #dcdcd8;
    border-radius: 10px;
    position: relative;
    cursor: pointer;
  }

  .custom-thumb {
    height: 9px;
    width: 60px;
    background: #000000;
    position: absolute;
    top: -2px;
    left: 0;
    border-radius: 10px;
    transition: transform 0.05s linear; 
    will-change: transform;
    cursor: grab;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .custom-thumb:active { cursor: grabbing; }

  /* --- GLOBALES INTERACTIVIDAD --- */
  .cursor-grabbing, .cursor-grabbing * {
    cursor: grabbing !important;
  }

  /* --- RESPONSIVE MOBILE --- */
  @media (max-width: 768px) {
    .scroll-wrapper { padding-left: 1rem; gap: 2rem; }
    .linea-header { padding-left: 1rem; }
    .model-card {
      /* En móvil sigue mostrando una lancha principal y un pedazo de la siguiente */
      width: 80vw; 
      padding: 0 4vw;
    }
    .model-name { font-size: 3.5rem; }
    .model-visual { height: 160px; }
    .model-specs { padding-top: 1.25rem; max-width: 100%; }
    .spec-unit { min-width: auto; }
    .spec-value { font-size: 1rem; }
    .spec-icon { width: 16px; height: 16px; }
    .custom-track { width: 70vw; }
  }
</style>