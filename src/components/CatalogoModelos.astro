---
import { models } from '../data/models';

// ── Icon → PNG file mapping ──────────────────────────────────────
const iconMap: Record<string, string> = {
  ruler:               'ESLORA.png',
  'arrows-horizontal': 'MANGA.png',
  'arrow-up':          'PUNTAL.png',
  lightning:           'MOTORIZACION.png',
  drop:                'COMBUSTIBLE.png',
  users:               'CAPACIDAD.png',
  gauge:               'CAPACIDAD.png',
};

// ── Silueta: overrides where name.replace('Classer ','') ≠ filename ─
const siluetaFileMap: Record<string, string> = {
  '246': '246 SURF',   // model "Classer 246" is LINEA SURF; no plain 246.png exists
};

// ── Logo: overrides for filename mismatches ──────────────────────
const logoFileMap: Record<string, string> = {
  '165': 'C165',
  '170': 'C170',
  '246': '246 SURF',   // LINEA SURF 246 model
};

function getSiluetaUrl(name: string): string {
  const key = name.replace('Classer ', '');
  const filename = siluetaFileMap[key] ?? key;
  return `/image/siluetas/${encodeURIComponent(filename)}.png`;
}

function getLogoUrl(name: string): string {
  const key = name.replace('Classer ', '');
  const filename = logoFileMap[key] ?? key;
  return `/image/logos-lanchas/${encodeURIComponent(filename)}.png`;
}

// ── Group models by line ─────────────────────────────────────────
const groupedModels = models.reduce((acc, model) => {
  const line = model.line || 'OTHERS';
  if (!acc[line]) acc[line] = [];
  acc[line].push(model);
  return acc;
}, {} as Record<string, typeof models>);

const lines = Object.keys(groupedModels);
---

<section
  style="background: #f0f0ee;"
  class="pt-16 pb-14 overflow-hidden"
  aria-label="Catálogo de modelos"
>
  <!-- ─── SCROLL CONTAINER ───────────────────────────────────────── -->
  <div
    id="catalogo-scroll"
    class="flex flex-col cursor-grab active:cursor-grabbing"
    style="overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none;"
  >

    <!-- ── ROW 1: HEADERS DE LÍNEA ─────────────────────────────── -->
    <div class="flex">
      {lines.map((line) => {
        const parts = line.split(' ');
        const prefix = parts[0];                   // "LINEA"
        const suffix = parts.slice(1).join(' ');   // "FTX" / "SURF" / "OB"
        return (
          <div
            class="linea-header-wrapper"
            style={`min-width: calc(${groupedModels[line].length} * 40vw);`}
          >
            <div class="linea-header">
              <div class="linea-header__line"></div>
              <img
                src="/image/iconos/LINEA%20GRAFICA.png"
                alt=""
                class="linea-header__curve"
                aria-hidden="true"
                loading="eager"
              />
              <span class="linea-header__texto">
                {prefix} <strong>{suffix}</strong>
              </span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- ── ROW 2: CARDS ────────────────────────────────────────── -->
    <div class="flex px-6 pb-8">
      {lines.map((line) => (
        <div class="flex">
          {groupedModels[line].map((model) => (
            <a
              href={`/classer/${model.slug}`}
              class="catalogo-card"
            >

              <!-- Badge "NUEVO" / "PRONTO" -->
              {model.badge && (
                <span class={`model-badge model-badge--${model.badge.toLowerCase()}`}>
                  {model.badge}
                </span>
              )}

              <!-- Logo PNG con fallback de texto -->
              <div class="model-logo">
                <img
                  src={getLogoUrl(model.name)}
                  alt={model.name}
                  class="model-logo__img"
                  loading="lazy"
                  onerror="this.style.display='none'; var fb=this.parentElement.querySelector('.model-logo__fallback'); if(fb) fb.style.display='flex';"
                />
                <div class="model-logo__fallback" style="display:none;">
                  <span class="model-logo__fallback-text">
                    {model.name.replace('Classer ', '')}
                  </span>
                </div>
              </div>

              <!-- Silueta PNG alineada por la base -->
              <div class="model-silhouette">
                <img
                  src={getSiluetaUrl(model.name)}
                  alt={`Silueta ${model.name}`}
                  class="model-silhouette__img"
                  loading="lazy"
                  width="320"
                  height="180"
                />
              </div>

              <!-- Specs: primeros 3 con ícono PNG -->
              <div class="specs-row">
                {model.specs.slice(0, 3).map((spec) => (
                  <div class="spec-item">
                    <img
                      src={`/image/iconos/${iconMap[spec.icon] ?? 'ESLORA.png'}`}
                      alt={spec.label}
                      class="spec-item__icon"
                      width="22"
                      height="22"
                      loading="lazy"
                      aria-hidden="true"
                    />
                    <span class="spec-item__label">{spec.label}</span>
                    <span class="spec-item__value">{spec.value}</span>
                  </div>
                ))}
              </div>

            </a>
          ))}
        </div>
      ))}
    </div>

  </div><!-- /#catalogo-scroll -->

  <!-- ─── ROW 3: BARRA DE PROGRESO CUSTOM ────────────────────── -->
  <div class="mx-auto mt-4 px-8" style="max-width: 600px;">
    <div id="catalogo-track" class="scroll-track" role="scrollbar">
      <div id="catalogo-thumb" class="scroll-thumb"></div>
    </div>
  </div>

</section>


<style>
  #catalogo-scroll::-webkit-scrollbar {
    display: none;
  }

  /* ── Linea Header ─────────────────────────────────────────── */

  .linea-header-wrapper {
    flex-shrink: 0;
  }

  .linea-header {
    display: flex;
    align-items: center;
    padding: 0 32px 12px;
    width: 100%;
    gap: 0;
  }

  .linea-header__line {
    flex: 1;
    height: 1px;
    background: #111111;
    opacity: 0.25;
  }

  .linea-header__curve {
    height: 24px;
    width: auto;
    object-fit: contain;
    display: block;
    opacity: 0.25;
    flex-shrink: 0;
  }

  .linea-header__texto {
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.8rem);
    font-weight: 400;
    color: #111111;
    white-space: nowrap;
    padding-left: 8px;
    line-height: 1;
  }

  .linea-header__texto strong {
    font-weight: 900;
    font-style: italic;
  }

  /* ── Card ─────────────────────────────────────────────────── */

  .catalogo-card {
    min-width: 40vw;
    max-width: 500px;
    padding: 1.5rem 2rem;
    flex-shrink: 0;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    transition: transform 0.3s ease;
  }

  @media (min-width: 1400px) {
    .catalogo-card {
      min-width: 420px;
    }
  }

  .catalogo-card:hover {
    transform: translateY(-4px);
  }

  /* Separador vertical sutil entre cards consecutivas */
  .catalogo-card + .catalogo-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 15%;
    height: 70%;
    width: 1px;
    background: #111111;
    opacity: 0.08;
  }

  /* ── Badge ────────────────────────────────────────────────── */

  .model-badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 99px;
    padding: 4px 10px;
    margin-bottom: 10px;
  }

  .model-badge--nuevo {
    background: #111111;
    color: #ffffff;
  }

  .model-badge--pronto {
    background: transparent;
    border: 1.5px solid #111111;
    color: #111111;
  }

  /* ── Model Logo ───────────────────────────────────────────── */

  .model-logo {
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .model-logo__img {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  .model-logo__fallback {
    height: 100%;
    align-items: center;
    justify-content: center;
  }

  .model-logo__fallback-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-style: italic;
    font-size: 3.5rem;
    font-weight: 800;
    color: #111111;
    line-height: 1;
  }

  /* ── Silhouette ───────────────────────────────────────────── */

  .model-silhouette {
    width: 100%;
    max-width: 280px;
    height: 160px;
    display: flex;
    align-items: flex-end;        /* anclar por la base, alinea siluetas entre sí */
    justify-content: center;
    margin-bottom: 20px;
  }

  .model-silhouette__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    transition: transform 0.4s ease;
  }

  .catalogo-card:hover .model-silhouette__img {
    transform: translateY(-6px);
  }

  /* ── Specs ────────────────────────────────────────────────── */

  .specs-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: auto;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    padding-top: 1.25rem;
    width: 100%;
    max-width: 300px;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    min-width: 70px;
  }

  .spec-item__icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    opacity: 0.75;
  }

  .spec-item__label {
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #111111;
    text-align: center;
  }

  .spec-item__value {
    font-size: 0.82rem;
    font-weight: 500;
    color: #111111;
    text-align: center;
  }

  /* ── Progress Bar ─────────────────────────────────────────── */

  .scroll-track {
    position: relative;
    height: 8px;
    background: #dcdcd8;
    border-radius: 9999px;
    cursor: pointer;
    max-width: 600px;
    margin: 0 auto;
  }

  .scroll-thumb {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 12px;
    background: #111111;
    border-radius: 9999px;
    cursor: grab;
    min-width: 60px;
    transition: width 0.1s ease;
  }

  .scroll-thumb:active {
    cursor: grabbing;
  }

  /* ── Mobile ───────────────────────────────────────────────── */

  @media (max-width: 767px) {
    .catalogo-card {
      min-width: 85vw;
      max-width: none;
      padding: 1.25rem 1.5rem;
    }
  }
</style>


<script>
  const container = document.getElementById('catalogo-scroll') as HTMLElement | null;
  const track = document.getElementById('catalogo-track') as HTMLElement | null;
  const thumb = document.getElementById('catalogo-thumb') as HTMLElement | null;

  function updateThumb() {
    if (!container || !track || !thumb) return;
    const trackWidth = track.offsetWidth;
    const totalWidth = container.scrollWidth;
    const visibleWidth = container.clientWidth;
    const maxScroll = totalWidth - visibleWidth;
    if (maxScroll <= 0) {
      thumb.style.display = 'none';
      return;
    }
    thumb.style.display = 'block';
    const thumbWidth = Math.max((visibleWidth / totalWidth) * trackWidth, 80);
    thumb.style.width = `${thumbWidth}px`;
    const thumbLeft = (container.scrollLeft / maxScroll) * (trackWidth - thumbWidth);
    thumb.style.left = `${thumbLeft}px`;
  }

  if (container && track && thumb) {
    container.addEventListener('scroll', updateThumb, { passive: true });
    window.addEventListener('resize', updateThumb, { passive: true });
    updateThumb();

    // Direct content drag
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    container.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
    });
    window.addEventListener('mouseup', () => { isDown = false; });
    container.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX) * 2;
      container.scrollLeft = scrollLeft - walk;
    });

    // Thumb drag
    let isDraggingThumb = false;
    let thumbStartX: number;
    let thumbStartScrollLeft: number;

    thumb.addEventListener('mousedown', (e) => {
      isDraggingThumb = true;
      thumbStartX = e.pageX;
      thumbStartScrollLeft = container.scrollLeft;
      document.body.style.userSelect = 'none';
      e.stopPropagation();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDraggingThumb) return;
      const deltaX = e.pageX - thumbStartX;
      const trackWidth = track.offsetWidth;
      const thumbWidth = thumb.offsetWidth;
      const maxThumbTravel = trackWidth - thumbWidth;
      const maxScroll = container.scrollWidth - container.clientWidth;
      if (maxThumbTravel > 0) {
        container.scrollLeft = thumbStartScrollLeft + (deltaX / maxThumbTravel) * maxScroll;
      }
    });

    window.addEventListener('mouseup', () => {
      isDraggingThumb = false;
      document.body.style.userSelect = '';
    });
  }
</script>
