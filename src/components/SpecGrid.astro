---
interface Props {
  specs: { label: string; value: string; icon: string }[];
  dark?: boolean;
}
const { specs, dark = true } = Astro.props;

const iconMap: Record<string, string> = {
  ruler:               'ESLORA.webp',
  'arrows-horizontal': 'MANGA.webp',
  'arrow-up':          'PUNTAL.webp',
  lightning:           'MOTORIZACION.webp',
  drop:                'COMBUSTIBLE.webp',
  users:               'CAPACIDAD.webp',
  gauge:               'CAPACIDAD.webp',
};
---

<div
  class="flex flex-wrap justify-center py-16"
  id="spec-grid"
  role="list"
  aria-label="Especificaciones técnicas"
  style="gap: 40px 56px; max-width: 1100px; margin: 0 auto;"
>
  {specs.map((spec) => (
    <div
      class="spec-item-horizontal flex items-center opacity-0"
      role="listitem"
      style="gap: 16px; min-width: 170px; width: calc(25% - 48px);"
    >
      <div class="spec-icon-wrapper flex-shrink-0">
        <img 
          src={`/image/iconos/${iconMap[spec.icon] ?? 'ESLORA.webp'}`}
          alt="" 
          class="object-contain filter brightness-0 invert"
          style="width: 52px; height: 52px;"
        />
      </div>
      
      <div class="spec-details flex flex-col items-start">
        <span class="spec-value-text text-white font-display font-bold leading-none" style="font-size: 1.5rem;">
          {spec.value}
        </span>
      </div>
    </div>
  ))}
</div>

<style>
  #spec-grid {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const grid = document.getElementById('spec-grid');
  if (grid) {
    const tiles = grid.querySelectorAll('.spec-item-horizontal');
    gsap.fromTo(tiles,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: grid,
          start: 'top 85%',
        },
      }
    );
  }
</script>
