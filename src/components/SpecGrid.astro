---
interface Props {
  specs: { label: string; value: string; icon: string }[];
  dark?: boolean;
}
const { specs, dark = true } = Astro.props;

const iconMap: Record<string, string> = {
  ruler:               'ESLORA.png',
  'arrows-horizontal': 'MANGA.png',
  'arrow-up':          'PUNTAL.png',
  lightning:           'MOTORIZACION.png',
  drop:                'COMBUSTIBLE.png',
  users:               'CAPACIDAD.png',
  gauge:               'CAPACIDAD.png',
};
---

<div
  class="flex flex-wrap justify-center gap-x-12 gap-y-16 md:gap-x-20 md:gap-y-20 py-12"
  id="spec-grid"
  role="list"
  aria-label="Especificaciones técnicas"
>
  {specs.map((spec) => (
    <div
      class="spec-item-horizontal flex items-center gap-5 opacity-0 w-[45%] lg:w-[20%] min-w-[200px]"
      role="listitem"
    >
      <div class="spec-icon-wrapper flex-shrink-0">
        <img 
          src={`/image/iconos/${iconMap[spec.icon] ?? 'ESLORA.png'}`} 
          alt="" 
          class="w-16 h-16 md:w-20 md:h-20 object-contain filter brightness-0 invert opacity-100"
        />
      </div>
      
      <div class="spec-details flex flex-col items-start gap-1">
        <div class="spec-label-pill bg-[#ffccd566] px-2 py-0.5 rounded-[3px]">
           <span class="text-white text-[0.65rem] md:text-[0.75rem] font-extrabold uppercase tracking-wider leading-none">
            {spec.label}
          </span>
        </div>
        <span class="spec-value-text font-display font-medium text-2xl md:text-4xl text-white leading-none mt-1">
          {spec.value}
        </span>
      </div>
    </div>
  ))}
</div>

<style>
  #spec-grid {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const grid = document.getElementById('spec-grid');
  if (grid) {
    const tiles = grid.querySelectorAll('.spec-item-horizontal');
    gsap.fromTo(tiles,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: grid,
          start: 'top 85%',
        },
      }
    );
  }
</script>
