---
// CTAContacto.astro
// Dark navy bg (#020617), fully centered, max-w-xl.
---

<section
  style="background: #0d1628;"
  class="py-24"
  aria-label="Contactar un asesor"
>
  <div class="max-w-xl mx-auto px-6 text-center">

    <!-- ─── Headline ─────────────────────────────────────────── -->
    <h2
      class="font-display font-bold"
      style="
        color: #ffffff;
        font-size: clamp(2.5rem, 5vw, 4rem);
        letter-spacing: 0.02em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.1;
      "
    >
      TU PRÓXIMA AVENTURA
    </h2>

    <!-- ─── Subtitle ─────────────────────────────────────────── -->
    <p
      style="
        color: #a8b3c8;
        font-size: 1.1rem;
        line-height: 1.6;
        font-weight: 300;
        max-width: 32rem;
        margin: 0 auto 3rem;
      "
    >
      Dejanos tus datos. Un especialista de Classer te contactará
      para asesorarte sin compromiso.
    </p>

    <!-- ─── Form ──────────────────────────────────────────────── -->
    <form
      action="#"
      method="POST"
      novalidate
      class="flex flex-col gap-4 w-full max-w-md mx-auto"
      aria-label="Formulario de contacto"
    >
      <input
        type="text"
        name="nombre"
        placeholder="Nombre Completo"
        class="cta-input"
      />
      <input
        type="email"
        name="email"
        placeholder="Correo Electrónico"
        class="cta-input"
      />

      <button
        type="submit"
        class="cta-btn font-display font-bold uppercase"
        style="letter-spacing: 0.1em; font-size: 0.9rem;"
      >
        CONTACTAR A UN ASESOR
      </button>
    </form>

    <p style="color: rgba(255, 255, 255, 0.2); font-size: 0.7rem; margin-top: 1.5rem;">
      Tus datos están protegidos. Atención personalizada Classer.
    </p>

  </div>
</section>

<style>
  .cta-input {
    width: 100%;
    padding: 1.1rem 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: #ffffff;
    font-size: 0.95rem;
    outline: none;
    transition: all 200ms ease;
  }
  .cta-input::placeholder { color: rgba(255, 255, 255, 0.3); }
  .cta-input:focus { border-color: #1e90d4; background: rgba(255, 255, 255, 0.08); }

  .cta-btn {
    width: 100%;
    padding: 1.1rem;
    background: #1e90d4;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 200ms ease;
  }
  .cta-btn:hover    { background: #157bb8; }
  .cta-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .cta-status { font-size: 0.78rem; margin-top: 0.75rem; min-height: 1rem; }
  .cta-status--ok    { color: #4ade80; }
  .cta-status--error { color: #f87171; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('form[aria-label="Formulario de contacto"]');
  const btn  = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  const status = document.createElement('p');
  status.className = 'cta-status';
  btn?.insertAdjacentElement('afterend', status);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const nombre = (data.get('nombre') as string)?.trim();
    const email  = (data.get('email')  as string)?.trim();

    if (!nombre || !email) {
      status.textContent = 'Por favor completá nombre y correo.';
      status.className = 'cta-status cta-status--error';
      return;
    }

    const mensaje = `Hola! Me llamo ${nombre} y quiero recibir asesoramiento sobre embarcaciones Classer. Mi correo es ${email}.`;
    const url = `https://wa.me/5493534781206?text=${encodeURIComponent(mensaje)}`;
    window.open(url, '_blank');
  });
</script>
