---
interface Props {
  title: string;
  description?: string;
  images: { url: string; w: number; h: number }[];
  dark?: boolean;
}
const { title, description, images, dark = true } = Astro.props;
---

<section class={`py-20 ${dark ? 'bg-bg-deep' : 'bg-bg-mid'}`}>
  <div class="container-site">
    <div class="text-center mb-10 reveal">
      <h2 class="font-display font-bold italic text-3xl md:text-4xl text-white mb-3">{title}</h2>
      {description && <p class="text-text-secondary text-sm max-w-xl mx-auto">{description}</p>}
    </div>

    <!-- 3-image collage -->
    <div class="flex gap-3 h-72 md:h-96 reveal">
      {images.map((img, i) => (
        <div class={`overflow-hidden rounded-lg flex-shrink-0 ${i === 0 ? 'flex-[2]' : 'flex-[1.5]'}`}>
          <img
            src={img.url}
            alt={`${title} — imagen ${i + 1}`}
            width={img.w}
            height={img.h}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
