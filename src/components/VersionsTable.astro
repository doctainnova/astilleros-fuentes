---
interface Feature {
  label: string;
  ltd: boolean | 'optional';
  flyer: boolean | 'optional';
}

interface Props {
  modelName: string;
  features: Feature[];
  diagramUrl: string;
  silhouetteTechnicalUrl: string;
  paletteUrl?: string; 
}

const { 
  modelName, 
  features, 
  diagramUrl, 
  silhouetteTechnicalUrl,
  paletteUrl = `/image/paletas/${modelName.replace('Classer ', '')}.webp` 
} = Astro.props;

const cleanName = modelName.replace('Classer ', '');
---

<section class="py-20 bg-[#f0f0ee]" aria-label="Versiones y equipamiento">
  <div class="container-site max-w-5xl mx-auto px-4">
    
    <div class="relative w-full h-[250px] md:h-[300px] mb-16 reveal flex items-end">
      
      <img
        src={silhouetteTechnicalUrl}
        alt={`Silueta de ${modelName}`}
        class="absolute right-0 bottom-[45px] md:bottom-[55px] w-64 md:w-[450px] h-auto object-contain z-10"
        loading="lazy"
        decoding="async"
      />

      <div class="absolute bottom-0 left-0 w-full h-[150px] z-0">
        <svg width="100%" height="100%" viewBox="0 0 1000 150" preserveAspectRatio="none">
          <path 
            d="M0,50 L350,50 C400,50 420,130 470,130 L1000,130" 
            fill="none" 
            stroke="#000000" 
            stroke-width="2" 
            vector-effect="non-scaling-stroke" 
          />
        </svg>
      </div>

      <h2 class="relative z-10 font-display font-black italic text-[4rem] md:text-[6rem] text-black uppercase leading-none pl-4 pb-2">
        {cleanName}
      </h2>

    </div>

    <div class="w-full reveal mb-24">
      <p class="font-barlow text-[0.65rem] uppercase tracking-[0.15em] text-accent-blue mb-2">Versiones</p>
      
      <table class="w-full text-sm" aria-label={`Comparación de versiones ${modelName}`}>
        <thead>
          <tr class="border-b border-black/20">
            <th class="text-left py-3 font-medium text-text-muted uppercase text-[0.65rem] tracking-wide w-[60%]">Equipamiento</th>
            <th class="text-center py-3 font-medium text-black uppercase text-[0.65rem] tracking-wide font-display italic text-lg">LTD</th>
            <th class="text-center py-3 font-medium text-black uppercase text-[0.65rem] tracking-wide font-display italic text-lg">Flyer</th>
          </tr>
        </thead>
        <tbody>
          {features.map((feature, i) => (
            <tr class={`border-b border-black/10 ${i % 2 === 0 ? '' : 'bg-black/[0.03]'}`}>
              <td class="py-3 px-2 text-black font-medium text-[0.85rem]">{feature.label}</td>
              <td class="py-3 text-center">
                {feature.ltd === true && (
                  <span class="text-green-600 font-bold text-lg" aria-label="Incluye">✓</span>
                )}
                {feature.ltd === false && (
                  <span class="text-black font-bold text-lg" aria-label="No incluye">✗</span>
                )}
                {feature.ltd === 'optional' && (
                  <span class="text-gray-400 font-bold text-xl" aria-label="Opcional">*</span>
                )}
              </td>
              <td class="py-3 text-center">
                {feature.flyer === true && (
                  <span class="text-green-600 font-bold text-lg" aria-label="Incluye">✓</span>
                )}
                {feature.flyer === false && (
                  <span class="text-black font-bold text-lg" aria-label="No incluye">✗</span>
                )}
                {feature.flyer === 'optional' && (
                  <span class="text-gray-400 font-bold text-xl" aria-label="Opcional">*</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="flex gap-8 mt-6 justify-end pr-8">
        <span class="flex items-center gap-2 text-[0.8rem] text-black font-medium">
          <span class="text-green-600 font-bold text-xl leading-none">✓</span> Incluye
        </span>
        <span class="flex items-center gap-2 text-[0.8rem] text-black font-medium">
          <span class="text-black font-bold text-xl leading-none">✗</span> No incluye
        </span>
        <span class="flex items-center gap-2 text-[0.8rem] text-black font-medium">
          <span class="text-gray-400 font-bold text-2xl leading-none pt-2">*</span> Opcional
        </span>
      </div>
    </div>

    <div class="w-full reveal pt-12 relative">
      <div class="absolute top-0 left-0 w-full h-10 overflow-hidden">
        <svg width="100%" height="40" viewBox="0 0 100 40" preserveAspectRatio="none" class="w-full">
          <path d="M0,38 L60,38 C75,38 85,2 100,2" fill="none" stroke="#000000" stroke-width="1.5" vector-effect="non-scaling-stroke" />
        </svg>
      </div>

      <div class="pt-8">
        <h3 class="font-display italic text-3xl md:text-4xl text-black mb-10 text-center md:text-left">
          Hacé que tu <span class="font-black">Classer {cleanName}</span> sea única.
        </h3>
        
        <div class="palette-root">

          <!-- GELCOAT -->
          <div class="palette-section">
            <div class="palette-heading">
              <span class="palette-title">OPCIONES DE GELCOAT</span>
              <span class="palette-subtitle">Pintura del casco y borda.</span>
            </div>
            <div class="palette-swatches">
              <div class="swatch-item">
                <div class="swatch swatch--bordered" style="background:#FFFFFF"></div>
                <span class="swatch-name">BLANCO</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#3A3A3A"></div>
                <span class="swatch-name">TITANIUM</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#868686"></div>
                <span class="swatch-name">NARDO</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#1B6FC2"></div>
                <span class="swatch-name">TURQUESA</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#C62828"></div>
                <span class="swatch-name">ROJO</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#111111"></div>
                <span class="swatch-name">NEGRO</span>
                <span class="swatch-note">(Solo para el casco)</span>
              </div>
            </div>
          </div>

          <!-- TAPICERÍA -->
          <div class="palette-section">
            <div class="palette-heading">
              <span class="palette-title">OPCIONES DE TAPICERÍA</span>
              <span class="palette-subtitle">Elegí tanto el color principal como los vivos.</span>
            </div>
            <div class="palette-swatches">
              <div class="swatch-item">
                <span class="swatch-material">Glasgow</span>
                <div class="swatch swatch--bordered" style="background:#CACACA"></div>
                <span class="swatch-name">GRIS CLARO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Glasgow</span>
                <div class="swatch" style="background:#989898"></div>
                <span class="swatch-name">GRIS MEDIO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Glasgow</span>
                <div class="swatch" style="background:#585858"></div>
                <span class="swatch-name">GRIS OSCURO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Glasgow</span>
                <div class="swatch" style="background:#252525"></div>
                <span class="swatch-name">GRIS NEGRO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Cuerina Clásica</span>
                <div class="swatch" style="background:#C62828"></div>
                <span class="swatch-name">ROJO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Cuerina Clásica</span>
                <div class="swatch" style="background:#8B6040"></div>
                <span class="swatch-name">HABANO</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Cuerina Texturada</span>
                <div class="swatch" style="background:#111111"></div>
                <span class="swatch-name">NEGRO</span>
                <span class="swatch-note">(Texturado)</span>
              </div>
              <div class="swatch-item">
                <span class="swatch-material">Cuerina Texturada</span>
                <div class="swatch" style="background:#C62828"></div>
                <span class="swatch-name">ROJO</span>
                <span class="swatch-note">(Texturado)</span>
              </div>
            </div>
          </div>

          <!-- PISO -->
          <div class="palette-section palette-section--last">
            <div class="palette-heading">
              <span class="palette-title">OPCIONES DE PISO</span>
              <span class="palette-subtitle">Elegí entre goma Evadeck o alfombra Evolve desmontable.</span>
            </div>
            <div class="palette-swatches">
              <div class="swatch-item">
                <div class="swatch swatch--bordered" style="background:#CACACA"></div>
                <span class="swatch-name">GRIS CLARO</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#585858"></div>
                <span class="swatch-name">GRIS OSCURO</span>
              </div>
              <div class="swatch-item">
                <div class="swatch" style="background:#8B6040"></div>
                <span class="swatch-name">HABANO</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Palette root ───────────────────────────────────── */
  .palette-root {
    width: 100%;
  }

  /* ── Section ────────────────────────────────────────── */
  .palette-section {
    margin-bottom: 2rem;
  }
  .palette-section--last {
    margin-bottom: 0;
  }

  /* ── Heading row ────────────────────────────────────── */
  .palette-heading {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
  }
  .palette-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: #000;
    text-transform: uppercase;
    line-height: 1;
  }
  .palette-subtitle {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.82rem;
    color: #555;
    line-height: 1;
  }

  /* ── Swatches row ───────────────────────────────────── */
  .palette-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-start;
  }

  /* ── Individual swatch item ─────────────────────────── */
  .swatch-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    width: 76px;
  }

  /* ── Color square ───────────────────────────────────── */
  .swatch {
    width: 76px;
    height: 76px;
    flex-shrink: 0;
  }
  .swatch--bordered {
    outline: 1px solid #b8b8b8;
    outline-offset: -1px;
  }

  /* ── Labels ─────────────────────────────────────────── */
  .swatch-material {
    font-family: var(--font-body);
    font-weight: 300;
    font-style: italic;
    font-size: 0.58rem;
    color: #888;
    text-align: center;
    line-height: 1.2;
    min-height: 0.9rem;
  }
  .swatch-name {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.62rem;
    color: #111;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.2;
  }
  .swatch-note {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.55rem;
    color: #888;
    text-align: center;
    line-height: 1.2;
  }

  /* ── Mobile ─────────────────────────────────────────── */
  @media (max-width: 480px) {
    .swatch-item { width: 58px; }
    .swatch      { width: 58px; height: 58px; }
    .palette-title   { font-size: 0.9rem; }
    .palette-subtitle { font-size: 0.75rem; }
    .palette-swatches { gap: 0.5rem; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.reveal').forEach(el => {
    gsap.fromTo(el,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 85%' },
      }
    );
  });
</script>