---
// HeroSlider.astro
// Full-viewport hero slider — pure black bg, 3 slides, crossfade, vanilla JS.
// No GSAP. No pagination dots. No external library.

import { Picture, Image } from 'astro:assets';
import slider1 from '../assets/home/slider-1.webp';
import slider2 from '../assets/home/slider-2.webp';
import slider3 from '../assets/home/slider-3.webp';
import slider4 from '../assets/home/slider-4.jpg';

const slides = [
  {
    eyebrow:  'MÁS CERCA QUE NUNCA',
    headline: 'Lanzamiento Classer 186',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/186',
    image:    slider1,
    imageAlt: 'Classer 186 — hero product shot',
    eager:    true,
  },
  {
    eyebrow:  'DISEÑADO PARA EL AGUA',
    headline: 'Classer 206 FTX',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/206-ftx',
    image:    slider2,
    imageAlt: 'Classer 206 FTX — hero product shot',
    eager:    false,
  },
  {
    eyebrow:  'TRADICIÓN E INNOVACIÓN',
    headline: 'Classer 246 SURF',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/246-surf',
    image:    slider3,
    imageAlt: 'Classer 246 SURF — hero product shot',
    eager:    false,
  },
  {
    eyebrow:  'POTENCIA Y CONFORT',
    headline: 'Classer 206 FTX',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/206-ftx',
    image:    slider4,
    imageAlt: 'Classer 206 FTX — lifestyle shot',
    eager:    false,
  },
];
---

<section
  class="relative overflow-hidden bg-black h-screen"
  aria-label="Presentación de modelos Classer"
  id="hero-slider"
>

  <!-- ─── SLIDES ──────────────────────────────────────────────── -->
  {slides.map((slide, i) => (
    <div
      class="slide absolute inset-0 group"
      data-index={i}
      aria-hidden={i !== 0}
      style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${i === 0 ? 1 : 0}; transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);`}
    >

      <!-- Immersive Image -->
      {i === 0 ? (
        <Picture
          src={slide.image}
          alt={slide.imageAlt}
          widths={[480, 768, 1200, 1920]}
          width={1920}
          height={1080}
          sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, (max-width: 1200px) 1200px, 1920px"
          formats={['avif', 'webp', 'jpg']}
          quality={82}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-[10000ms] ease-out slide-img"
          style="transform: scale(1.1);"
        />
      ) : (
        <Image
          src={slide.image}
          alt={slide.imageAlt}
          width={1920}
          height={1080}
          format="webp"
          quality={80}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-[10000ms] ease-out slide-img"
          style="transform: scale(1);"
        />
      )}

      <!-- Premium Overlay (Gradient + subtle texture) -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
      <div class="absolute inset-0 bg-black/5 mix-blend-multiply h-full w-full pointer-events-none"></div>

      <!-- ─── TEXT OVERLAY ────────────────────── -->
      <div class="absolute inset-0 flex flex-col justify-end px-8 md:px-16 pb-20 md:pb-28">
        <div class="max-w-2xl slide-content flex flex-col gap-3 md:gap-5 opacity-0 translate-y-8 transition-all duration-700 delay-300" style={i === 0 ? 'opacity: 1; transform: translateY(0);' : ''}>

          <!-- Eyebrow -->
          <div>
            <span
              class="inline-block text-accent-blue uppercase font-semibold tracking-[0.2em] border-l-2 border-accent-blue pl-4 py-1"
              style="font-size: 0.7rem;"
            >
              {slide.eyebrow}
            </span>
          </div>

          <!-- Headline -->
          <h2
            class="font-display font-bold text-white italic leading-[1.05]"
            style="font-size: clamp(2.2rem, 6.5vw, 4.2rem);"
          >
            {slide.headline}
          </h2>

          <!-- CTA Wrapper -->
          <div class="mt-2">
            <a
              href={slide.ctaHref}
              class="inline-flex items-center gap-4 bg-white text-black font-barlow font-bold uppercase tracking-[0.15em] py-3.5 px-8 hover:bg-accent-blue hover:text-white transition-all duration-300 cursor-pointer shadow-xl hover:scale-105"
              style="font-size: 0.75rem;"
            >
              {slide.cta}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="animate-pulse" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  ))}

  <!-- ─── NAVIGATION ─────────────────────────── -->
  <div
    class="absolute bottom-8 right-8 md:bottom-16 md:right-16 z-20"
  >
    <!-- Arrow Controls -->
    <div class="flex gap-4">
      <button
        id="hero-prev"
        type="button"
        class="w-12 h-12 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white hover:text-black transition-all duration-300 cursor-pointer group"
        aria-label="Diapositiva anterior"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="group-hover:-translate-x-1 transition-transform">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        id="hero-next"
        type="button"
        class="w-12 h-12 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white hover:text-black transition-all duration-300 cursor-pointer group"
        aria-label="Siguiente diapositiva"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

</section>

<!-- ─── SLIDER LOGIC ─────────────────── -->
<script>
  const slider        = document.getElementById('hero-slider');
  const slides        = slider?.querySelectorAll<HTMLElement>('.slide');
  const slideImgs    = slider?.querySelectorAll<HTMLElement>('.slide-img');
  const slideContents = slider?.querySelectorAll<HTMLElement>('.slide-content');
  const prevBtn       = document.getElementById('hero-prev');
  const nextBtn       = document.getElementById('hero-next');

  if (slider && slides && slides.length > 0 && slideImgs && slideContents) {
    const total = slides.length;
    let current = 0;
    let autoTimer: any;

    function updateSlide(idx: number) {
      // 1. Reset current slide
      slides[current].style.opacity = '0';
      slides[current].style.zIndex  = '0';
      slides[current].setAttribute('aria-hidden', 'true');
      slideImgs[current].style.transform = 'scale(1)';
      slideContents[current].style.opacity = '0';
      slideContents[current].style.transform = 'translateY(2rem)';

      // 2. Set next slide
      current = (idx + total) % total;
      slides[current].style.opacity = '1';
      slides[current].style.zIndex  = '1';
      slides[current].setAttribute('aria-hidden', 'false');

      // Animations
      setTimeout(() => {
        slideImgs[current].style.transform = 'scale(1.1)';
        slideContents[current].style.opacity = '1';
        slideContents[current].style.transform = 'translateY(0)';
      }, 50);
    }

    function startAuto() {
      autoTimer = setInterval(() => updateSlide(current + 1), 6000);
    }

    function resetAuto() {
      clearInterval(autoTimer);
      startAuto();
    }

    prevBtn?.addEventListener('click', () => { updateSlide(current - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { updateSlide(current + 1); resetAuto(); });

    startAuto();
  }
</script>
