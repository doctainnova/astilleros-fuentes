---
// HeroSlider.astro
// Full-viewport hero slider — pure black bg, 3 slides, crossfade, vanilla JS.
// No GSAP. No pagination dots. No external library.

const slides = [
  {
    eyebrow:  'MÁS CERCA QUE NUNCA',
    headline: 'Lanzamiento Classer 186',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/186',
    image:    'https://placehold.co/1000x600/111111/444444',
    imageAlt: 'Classer 186 — hero product shot',
  },
  {
    eyebrow:  'DISEÑADO PARA EL AGUA',
    headline: 'Classer 206 FTX',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/206-ftx',
    image:    'https://placehold.co/1000x600/111111/444444',
    imageAlt: 'Classer 206 FTX — hero product shot',
  },
  {
    eyebrow:  'TRADICIÓN E INNOVACIÓN',
    headline: 'Classer 246',
    cta:      'DESCUBRIR',
    ctaHref:  '/modelos/246',
    image:    'https://placehold.co/1000x600/111111/444444',
    imageAlt: 'Classer 246 — hero product shot',
  },
];
---

<section
  class="relative overflow-hidden bg-black h-[70vh] md:h-screen"
  style="min-height: 520px;"
  aria-label="Presentación de modelos Classer"
  id="hero-slider"
>

  <!-- ─── SLIDES ──────────────────────────────────────────────── -->
  {slides.map((slide, i) => (
    <div
      class="slide absolute inset-0"
      data-index={i}
      aria-hidden={i !== 0}
      style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${i === 0 ? 1 : 0}; transition: opacity 0.5s ease;`}
    >

      <!-- Boat image — floats center-right against pure black -->
      <img
        src={slide.image}
        alt={slide.imageAlt}
        width="1000"
        height="600"
        class="absolute top-1/2 -translate-y-1/2 right-0 md:right-[-2%] object-contain w-[90%] md:w-[62%]"
        style="max-height: 85vh;"
        loading={i === 0 ? 'eager' : 'lazy'}
      />

      <!-- ─── TEXT OVERLAY — bottom left ────────────────────── -->
      <div class="absolute bottom-6 left-6 md:bottom-12 md:left-12 flex flex-col gap-3 md:gap-4">

        <!-- Eyebrow with semi-transparent highlight box -->
        <div>
          <span
            class="inline-block text-accent-blue uppercase font-semibold tracking-[0.15em]"
            style="font-size: 0.75rem; background: rgba(255,255,255,0.06); padding: 0.25rem 0.625rem;"
          >
            {slide.eyebrow}
          </span>
        </div>

        <!-- Headline — Barlow Condensed bold, sentence case -->
        <h2
          class="font-display font-bold text-white leading-none"
          style="font-size: clamp(2rem, 5vw, 3rem);"
        >
          {slide.headline}
        </h2>

        <!-- CTA — outlined, sharp corners (rounded-none) -->
        <div>
          <a
            href={slide.ctaHref}
            class="inline-flex items-center gap-2 border border-white text-white uppercase font-semibold rounded-none py-3 px-6 hover:bg-white hover:text-black transition-colors duration-200 cursor-pointer"
            style="font-size: 0.75rem; letter-spacing: 0.1em;"
          >
            {slide.cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  ))}

  <!-- ─── NAVIGATION ARROWS — bottom right, circular ─────────── -->
  <div
    class="absolute bottom-6 right-6 md:bottom-12 md:right-12 z-10 flex gap-3"
    aria-label="Navegación del slider"
  >
    <button
      id="hero-prev"
      type="button"
      class="w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center text-white cursor-pointer hover:bg-white/10 transition-colors duration-200"
      style="border: 1px solid rgba(255,255,255,0.5);"
      aria-label="Diapositiva anterior"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M11 14L6 9l5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button
      id="hero-next"
      type="button"
      class="w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center text-white cursor-pointer hover:bg-white/10 transition-colors duration-200"
      style="border: 1px solid rgba(255,255,255,0.5);"
      aria-label="Siguiente diapositiva"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M7 4l5 5-5 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</section>

<!-- ─── SLIDER LOGIC — vanilla JS, no library ─────────────────── -->
<script>
  const slider  = document.getElementById('hero-slider');
  const slides  = slider?.querySelectorAll<HTMLElement>('.slide');
  const prevBtn = document.getElementById('hero-prev');
  const nextBtn = document.getElementById('hero-next');

  if (slider && slides && slides.length > 0) {
    const total = slides.length;
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    function showSlide(idx: number) {
      // Deactivate current slide
      slides[current].style.opacity = '0';
      slides[current].style.zIndex  = '0';
      slides[current].setAttribute('aria-hidden', 'true');

      // Activate next slide
      current = (idx + total) % total;
      slides[current].style.opacity = '1';
      slides[current].style.zIndex  = '1';
      slides[current].setAttribute('aria-hidden', 'false');
    }

    function startAuto() {
      autoTimer = setInterval(() => showSlide(current + 1), 5000);
    }

    function resetAuto() {
      clearInterval(autoTimer);
      startAuto();
    }

    prevBtn?.addEventListener('click', () => { showSlide(current - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { showSlide(current + 1); resetAuto(); });

    startAuto();
  }
</script>
