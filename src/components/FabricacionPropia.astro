---
import { Image } from 'astro:assets';
import maestriaImg from '../assets/home/maestria.jpg';
// FabricacionPropia.astro
// Dark navy bg (#0d1628), 2-column grid.
// Left: Grayscale photo with blue corner brackets.
// Right: Eyebrow, serif headline, body, and 3-column pillars with serif labels.

const pillars = [
  {
    icon: 'anchor',
    label: 'Legado',
    sublabel: 'Más de 50 años construyendo.',
  },
  {
    icon: 'shield',
    label: 'Calidad',
    sublabel: 'Pruebas rigurosas.',
  },
  {
    icon: 'compass',
    label: 'Diseño',
    sublabel: 'Geometría galardonada.',
  },
];
---

<section
  style="background: #0d1628;"
  class="py-32"
  aria-label="Fabricación propia"
>
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center">

      <!-- ─── LEFT COLUMN: grayscale photo + corner brackets ──── -->
      <div class="relative flex justify-center md:justify-start">
        <div class="fab-photo-container relative inline-block">
          <!-- Top Left Bracket -->
          <div class="absolute -top-4 -left-4 w-12 h-12 border-t border-l border-accent-blue/60" aria-hidden="true"></div>
          
          <!-- Image -->
          <Image
            src={maestriaImg}
            alt="Maestría artesanal en Astilleros Fuentes"
            width={450}
            height={550}
            format="webp"
            quality={75}
            loading="lazy"
            decoding="async"
            class="block w-full contrast-110 brightness-90 shadow-2xl"
            style="object-fit: cover; max-width: 420px;"
          />

          <!-- Bottom Right Bracket -->
          <div class="absolute -bottom-4 -right-4 w-12 h-12 border-b border-r border-accent-blue/60" aria-hidden="true"></div>
        </div>
      </div>

      <!-- ─── RIGHT COLUMN: text content ────────────────────── -->
      <div class="fab-text flex flex-col justify-center">

        <p
          class="text-accent-blue font-semibold tracking-[0.2em] mb-4"
          style="font-size: 0.85rem;"
        >
          FABRICACIÓN PROPIA
        </p>

        <!-- Headline -->
        <h2
          class="text-white leading-[1.2] mb-8"
          style="
            font-size: clamp(2.2rem, 4vw, 3.2rem);
            font-weight: 400;
            font-family: 'Rogue Sans Nova Extended', sans-serif;
          "
        >
          Maestría en cada detalle.
        </h2>

        <!-- Body copy -->
        <p
          class="text-text-secondary font-light mb-12"
          style="
            font-size: 0.95rem;
            line-height: 1.8;
            max-width: 32rem;
          "
        >
          El verdadero lujo no se puede subcontratar. Desde el boceto inicial
          hasta el pulido final, cada barco Classer se fabrica en nuestro
          astillero. Esto nos permite un control absoluto sobre la calidad,
          asegurando que cada curva, costura y unión cumpla con nuestros
          exigentes estándares.
        </p>

        <!-- 3 pillar columns -->
        <div class="grid grid-cols-3 gap-6 md:gap-8">
          {pillars.map(p => (
            <div class="flex flex-col gap-3">

              <!-- Icon -->
              <div class="text-accent-blue opacity-80">
                {p.icon === 'anchor' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="3"/>
                    <line x1="12" y1="22" x2="12" y2="8"/>
                    <path d="M5 12H2a10 10 0 0 0 20 0h-3"/>
                  </svg>
                )}
                {p.icon === 'shield' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path d="M9 12l2 2 4-4"/>
                  </svg>
                )}
                {p.icon === 'compass' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
                  </svg>
                )}
              </div>

              <!-- Content -->
              <div class="space-y-1">
                <p 
                  class="text-white font-bold"
                  style="font-family: 'Rogue Sans Nova Extended', sans-serif; font-size: 1rem;"
                >
                  {p.label}
                </p>
                <p class="text-text-muted text-[0.7rem] leading-relaxed uppercase tracking-wider">
                  {p.sublabel}
                </p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* Subtle image entrance or interactions could go here */
</style>
