---
---
<footer class="bg-bg-dark border-t border-white/10" role="contentinfo">
  <div class="container-site py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12" id="footer-cols">
      <!-- Col 1: Brand -->
      <div class="reveal">
        <a href="/" aria-label="CLASSER Home" class="inline-block mb-4">
          <svg width="120" height="24" viewBox="0 0 120 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="CLASSER">
            <text x="0" y="20" font-family="'Barlow Condensed', sans-serif" font-size="24" font-weight="700" fill="white" letter-spacing="4">CLASSER</text>
          </svg>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed mb-4 max-w-xs">
          Creando experiencias trascendentales en el agua desde 1972.<br/>
          Diseñado en Italia, construido para el mundo.
        </p>
        <address class="not-italic text-text-muted text-xs leading-relaxed">
          Via del Porto 42, Génova, Italia
        </address>
      </div>

      <!-- Col 2: Explorar -->
      <div class="reveal">
        <p class="font-barlow text-[0.65rem] uppercase tracking-[0.15em] text-accent-blue mb-5">Explorar</p>
        <nav aria-label="Pie de página explorar">
          <ul class="space-y-3">
            {[
              { label: 'Eventos', href: '/eventos' },
              { label: 'Modelos', href: '/modelos' },
              { label: 'Legado', href: '/legado' },
              { label: 'Contacto', href: '/contacto' },
            ].map(link => (
              <li>
                <a href={link.href} class="text-text-secondary text-sm hover:text-white transition-colors cursor-pointer">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Col 3: Conectar -->
      <div class="reveal">
        <p class="font-barlow text-[0.65rem] uppercase tracking-[0.15em] text-accent-blue mb-5">Conectar</p>
        <div class="flex gap-4">
          <!-- Instagram -->
          <a href="https://instagram.com/astillero.fuentes" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Astillero Fuentes" class="w-10 h-10 rounded border border-white/20 flex items-center justify-center text-text-secondary hover:border-accent-blue hover:text-accent-blue transition-all duration-200 cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a href="https://facebook.com/astillero.fuentes" target="_blank" rel="noopener noreferrer" aria-label="Facebook de Astillero Fuentes" class="w-10 h-10 rounded border border-white/20 flex items-center justify-center text-text-secondary hover:border-accent-blue hover:text-accent-blue transition-all duration-200 cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn de Astillero Fuentes" class="w-10 h-10 rounded border border-white/20 flex items-center justify-center text-text-secondary hover:border-accent-blue hover:text-accent-blue transition-all duration-200 cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a href="https://wa.me/5493534781206" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp de Astillero Fuentes" class="w-10 h-10 rounded border border-white/20 flex items-center justify-center text-text-secondary hover:border-accent-blue hover:text-accent-blue transition-all duration-200 cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.533 5.849L0 24l6.335-1.509A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894c-1.943 0-3.747-.536-5.289-1.467l-.379-.225-3.756.895.952-3.655-.246-.389A9.862 9.862 0 012.105 12C2.105 6.529 6.529 2.105 12 2.105S21.895 6.529 21.895 12 17.471 21.894 12 21.894z"/>
            </svg>
          </a>
        </div>

        <div class="mt-8">
          <p class="text-text-muted text-xs mb-1">Teléfono</p>
          <a href="tel:+5493534781206" class="text-text-secondary text-sm hover:text-white transition-colors">+54 9 3534 78-1206</a>
        </div>
        <div class="mt-3">
          <p class="text-text-muted text-xs mb-1">Web</p>
          <a href="https://astillerofuentes.com.ar" target="_blank" rel="noopener noreferrer" class="text-text-secondary text-sm hover:text-white transition-colors">astillerofuentes.com.ar</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-text-muted text-xs">©2025 CLASSER — Astillero Fuentes. Todos los derechos reservados.</p>
      <p class="text-text-muted text-xs">Villa María, Córdoba, Argentina</p>
    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cols = document.querySelectorAll('#footer-cols .reveal');
  gsap.fromTo(cols,
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#footer-cols',
        start: 'top 85%',
      },
    }
  );
</script>
