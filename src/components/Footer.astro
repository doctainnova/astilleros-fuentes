---
// Footer.astro
// Background #0a0e1a — continuous with page base, no visible seam.
// 3-column grid: Brand | Explorar | Conectar. Bottom bar with copyright.
// Self-contained. No props required.
import { Image } from 'astro:assets';
import classerLogo from '../assets/brand/CLASSER 1.webp';
---

<footer
  style="background: #0a0e1a; border-top: 1px solid rgba(255,255,255,0.05);"
  class="pt-20 pb-12"
  role="contentinfo"
>
  <div class="max-w-6xl mx-auto px-6">

    <!-- ─── MAIN GRID ─────────────────────────────────────────── -->
    <div class="footer-grid grid gap-12 md:gap-16" style="align-items: start;">

      <!-- ── COLUMN 1: Brand ────────────────────────────────── -->
      <div>

        <!-- CLASSER logo lockup: double chevron + wordmark -->
        <a href="/" class="inline-flex items-center gap-2 mb-6" aria-label="CLASSER — inicio">
          <Image src={classerLogo} alt="" width={200} format="webp" quality={85} loading="lazy" decoding="async" class="text-white color-white invert" />
        </a>

        <!-- Tagline -->
        <p
          style="
            color: #6b7a99;
            font-size: 0.82rem;
            line-height: 1.7;
            font-weight: 300;
            max-width: 20rem;
          "
        >
          Creando experiencias trascendentales en el agua
          desde 1972. Diseñado en Italia, construido para el
          mundo.
        </p>
      </div>

      <!-- ── COLUMN 2: Explorar ─────────────────────────────── -->
      <div>
        <p
          style="color: #ffffff; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;"
        >Explorar</p>

        <nav aria-label="Pie de página — explorar">
          <ul class="flex flex-col gap-4" style="list-style: none; padding: 0; margin: 0;">
            {[
              { label: 'Eventos',      href: '/eventos' },
              { label: 'Configurador', href: '#'        },
              { label: 'Legado',       href: '/legado'  },
              { label: 'Propiedad',    href: '#'        },
            ].map(link => (
              <li>
                <a
                  href={link.href}
                  class="footer-link"
                  style="color: #a8b3c8; font-size: 0.875rem; font-weight: 300; text-decoration: none;"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- ── COLUMN 3: Conectar ─────────────────────────────── -->
      <div>
        <p
          style="color: #ffffff; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;"
        >Conectar</p>

        <!-- Social icons row -->
        <div class="flex gap-4 mb-8">

          <!-- Instagram -->
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de Astillero Fuentes"
            class="social-icon"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook de Astillero Fuentes"
            class="social-icon"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de Astillero Fuentes"
            class="social-icon"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>

        </div>

        <!-- Address block -->
        <address
          style="
            font-style: normal;
            color: #6b7a99;
            font-size: 0.82rem;
            line-height: 1.6;
            font-weight: 300;
          "
        >
          Via del Porto 42<br/>
          Génova, Italia
        </address>

      </div>
    </div>

    <!-- ─── BOTTOM BAR ────────────────────────────────────────── -->
    <div
      class="footer-bottom flex flex-col md:flex-row justify-between items-center gap-2"
      style="
        margin-top: 4rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        padding-top: 2rem;
      "
    >
      <p style="color: #4a5568; font-size: 0.75rem;">
        © 2025 Classer. Astillero Fuentes.
      </p>
      <p style="color: #4a5568; font-size: 0.75rem;">
        Villa María, Córdoba, Argentina.
      </p>
    </div>

  </div>
</footer>

<style>
  /* ── Main grid: 3 cols desktop, 1 col mobile ─────────────── */
  .footer-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  /* ── Nav link hover ──────────────────────────────────────── */
  .footer-link {
    transition: color 150ms ease;
  }
  .footer-link:hover {
    color: #ffffff;
  }

  /* ── Social icon hover ───────────────────────────────────── */
  .social-icon {
    color: #a8b3c8;
    line-height: 0;
    transition: color 150ms ease;
  }
  .social-icon:hover {
    color: #ffffff;
  }

  /* ── Bottom bar: center on mobile ───────────────────────── */
  @media (max-width: 767px) {
    .footer-bottom {
      text-align: center;
    }
  }
</style>
