---
import { Image } from 'astro:assets';
import mercuryLogo from '../assets/partners/MERCURY.webp';
import yamahaLogo from '../assets/partners/YAMAHA.webp';
// PartnersOficiales.astro
// Pure black bg (#000000), centered content.
// Eyebrow, headline, body copy, then Mercury + Yamaha as CSS/SVG text lockups.
// Self-contained. No props required. No placehold.co images.
---

<section
  style="background: #000000;"
  class="py-24"
  aria-label="Partners oficiales"
>
  <div class="max-w-3xl mx-auto px-6 text-center">

    <!-- ─── Eyebrow ──────────────────────────────────────────── -->
    <p
      style="color: #1e90d4; font-size: 0.7rem; letter-spacing: 0.18em; font-weight: 600; text-transform: uppercase; margin-bottom: 1.25rem;"
    >
      PARTNERS OFICIALES
    </p>

    <!-- ─── Headline ─────────────────────────────────────────── -->
    <h2
      style="
        color: #ffffff;
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 400;
        font-family: 'Rogue Sans Nova Extended', sans-serif;
        line-height: 1.2;
        margin-bottom: 1.5rem;
      "
    >
      Potencia y Confianza
    </h2>

    <!-- ─── Body copy ─────────────────────────────────────────── -->
    <p
      style="
        color: #a8b3c8;
        font-size: 0.9rem;
        line-height: 1.8;
        font-weight: 300;
        max-width: 32rem;
        margin: 0 auto 4rem;
      "
    >
      La excelencia en el diseño requiere excelencia en la propulsión.
      Como distribuidores oficiales, equipamos nuestras embarcaciones
      con la fiabilidad y tecnología de punta de los líderes mundiales
      en motores marinos.
    </p>

    <!-- ─── Logo lockups ──────────────────────────────────────── -->
    <div class="partners-logos flex flex-col md:flex-row items-center justify-center gap-12 md:gap-10">

      <!-- MERCURY -->
      <div class="flex items-center gap-6" style="min-width: 280px; justify-content: center;">
        <Image src={mercuryLogo} alt="Mercury Marine — motores fuera de borda" width={350} format="webp" quality={80} loading="lazy" decoding="async" class="text-white color-white invert" />
      </div>

      <!-- Vertical divider — desktop only -->
      <div class="partners-divider" aria-hidden="true"></div>

      <!-- YAMAHA -->
      <div class="flex items-center gap-6" style="min-width: 280px; justify-content: center;">
        <Image src={yamahaLogo} alt="Yamaha Marine — motores marinos" width={350} format="webp" quality={80} loading="lazy" decoding="async" class="text-white color-white invert" />
      </div>

    </div>
  </div>
</section>

<style>
  .partners-divider {
    display: none;
  }

  @media (min-width: 768px) {
    .partners-divider {
      display: block;
      width: 1px;
      height: 80px;
      background: rgba(255, 255, 255, 0.2);
      flex-shrink: 0;
    }
  }
</style>
