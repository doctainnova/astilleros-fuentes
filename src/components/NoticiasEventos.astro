---
import { Image } from 'astro:assets';
import proyecto186Img from '../assets/notyeven/proyecto-186.webp';
import lanzamiento246Img from '../assets/notyeven/lanzamiento-246.webp';
import fabricaImg from '../assets/notyeven/fabrica.jpg';
// NoticiasEventos.astro
// Pure white bg. H2 left-aligned. 3-column card grid.
// Card 1: black teaser centered content. Cards 2-3: standard news with serif titles.
---

<section
  class="bg-white pt-12 pb-24"
  aria-label="Noticias y eventos"
  
>
  <div class="max-w-7xl mx-auto px-6">

    <!-- ─── H2 Header ─────────────────────────────────────────── -->
    <h2
      class="text-text-dark mb-12"
      style="
        font-size: clamp(2rem, 3.5vw, 2.5rem);
        font-weight: 400;
        font-family: 'Rogue Sans Nova Extended', sans-serif;
      "
    >
      Noticias y eventos
    </h2>

    <!-- ─── Cards grid ───────────────────────────────────────── -->
    <div class="noticias-grid grid gap-8" style="align-items: start;">

      <!-- ── CARD 1: Proyecto 186 — black teaser ──────────────── -->
      <a
        href="/pre-venta/186/"
        class="noticias-card-teaser relative overflow-hidden flex items-center justify-center p-8 active:scale-[0.98] transition-transform duration-300"
        style="background: #070707; height: 320px; text-decoration: none;"
        aria-label="Proyecto 186 — próximamente"
      >
        <!-- Faint boat silhouette — centered & visible ghost effect -->
        <Image
          src={proyecto186Img}
          alt=""
          width={520}
          height={300}
          format="webp"
          quality={75}
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          class="absolute inset-0 m-auto object-contain pointer-events-none scale-125 md:scale-150"
          style="filter: invert(1); opacity: 0.15;"
        />

        <!-- Text overlay — Centered -->
        <div class="relative z-10 text-center flex flex-col gap-2">
          <p
            class="text-accent-blue font-semibold tracking-[0.2em] uppercase"
            style="font-size: 0.85rem;"
          >
            PRÓXIMAMENTE
          </p>

          <!-- H3 -->
          <h3
            class="text-white font-bold leading-none"
            style="font-family: 'Rogue Sans Nova Extended', sans-serif; font-size: 2.2rem;"
          >
            Proyecto 186
          </h3>

          <p
            class="text-white/40 font-light mt-1"
            style="font-size: 1rem;"
          >
            El futuro del lujo compacto.
          </p>
        </div>
      </a>

      <!-- ── CARD 2: Lanzamiento 246 — standard news ───────────── -->
      <a
        href="/eventos#lanzamiento-246"
        class="noticias-card-news flex flex-col group cursor-pointer"
        style="text-decoration: none;"
        aria-label="Noticia: Lanzamiento Classer 246"
      >
        <!-- Image -->
        <div class="overflow-hidden bg-bg-light" style="line-height: 0;">
          <Image
            src={lanzamiento246Img}
            alt="Lanzamiento Classer 246 en el agua"
            width={400}
            height={220}
            format="webp"
            quality={75}
            loading="lazy"
            decoding="async"
            class="w-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="height: 320px; display: block;"
          />
        </div>

        <!-- Text area -->
        <div class="pt-6">

          <!-- Article title -->
          <h3
            class="text-text-dark font-bold leading-tight group-hover:text-accent-blue transition-colors"
            style="font-family: 'Rogue Sans Nova Extended', sans-serif; font-size: 1.4rem;"
          >
            Lanzamiento 246
          </h3>
        </div>
      </a>

      <!-- ── CARD 3: Nuevo Astillero Fuentes — standard news ────── -->
      <a
        href="/eventos#astillero-fuentes"
        class="noticias-card-news flex flex-col group cursor-pointer"
        style="text-decoration: none;"
        aria-label="Noticia: Nuevo Astillero Fuentes"
      >
        <!-- Image -->
        <div class="overflow-hidden bg-bg-light" style="line-height: 0;">
          <Image
            src={fabricaImg}
            alt="Nuevo local comercial Astillero Fuentes"
            width={400}
            height={220}
            format="webp"
            quality={75}
            loading="lazy"
            decoding="async"
            class="w-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="height: 320px; display: block;"
          />
        </div>

        <!-- Text area -->
        <div class="pt-6">

          <!-- Article title -->
          <h3
            class="text-text-dark font-bold leading-tight group-hover:text-accent-blue transition-colors"
            style="font-family: 'Rogue Sans Nova Extended', sans-serif; font-size: 1.4rem;"
          >
            Nuevo Astillero Fuentes
          </h3>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  /* Desktop: 3 equal columns */
  .noticias-grid {
    grid-template-columns: 1fr 1fr 1fr;
  }

  /* Mobile: single column */
  @media (max-width: 1023px) {
    .noticias-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

