---
// NoticiasEventos.astro
// Light off-white bg (#f4f4f2). H2 left-aligned. 3-column card grid.
// Card 1: black teaser with "PRÓXIMAMENTE". Cards 2-3: standard news cards.
// Self-contained. No props required.
---

<section
  style="background: #f4f4f2;"
  class="pt-6 pb-20"
  aria-label="Noticias y eventos"
>
  <div class="max-w-6xl mx-auto px-6">

    <!-- ─── H2 Header ─────────────────────────────────────────── -->
    <h2
      style="
        color: #0a0e1a;
        font-size: clamp(1.6rem, 3vw, 2rem);
        font-weight: 400;
        font-family: Georgia, 'Times New Roman', serif;
        line-height: 1.2;
        margin-bottom: 2rem;
      "
    >
      Noticias y eventos
    </h2>

    <!-- ─── Cards grid ───────────────────────────────────────── -->
    <div class="noticias-grid grid gap-6" style="align-items: start;">

      <!-- ── CARD 1: Proyecto 186 — black teaser ──────────────── -->
      <article
        class="noticias-card-teaser relative overflow-hidden rounded-lg"
        style="background: #000000; height: 344px;"
        aria-label="Proyecto 186 — próximamente"
      >
        <!-- Faint boat silhouette — dark on dark, moody -->
        <img
          src="https://placehold.co/180x100/111111/333333"
          alt=""
          width="180"
          height="100"
          aria-hidden="true"
          style="
            position: absolute;
            top: 25%;
            left: 50%;
            transform: translateX(-50%);
            opacity: 0.6;
            object-fit: contain;
          "
          loading="lazy"
        />

        <!-- Text overlay — anchored to bottom -->
        <div
          style="
            position: absolute;
            bottom: 2rem;
            left: 0;
            right: 0;
            text-align: center;
            padding: 0 1.5rem;
          "
        >
          <!-- Eyebrow -->
          <p
            style="
              color: #1e90d4;
              font-size: 0.65rem;
              letter-spacing: 0.2em;
              font-weight: 600;
              text-transform: uppercase;
              margin-bottom: 0.75rem;
            "
          >
            PRÓXIMAMENTE
          </p>

          <!-- H3 -->
          <h3
            class="font-display font-bold"
            style="
              color: #ffffff;
              font-size: 1.8rem;
              line-height: 1.1;
              margin-bottom: 0.75rem;
            "
          >
            Proyecto 186
          </h3>

          <!-- Subtitle -->
          <p
            style="
              color: rgba(255, 255, 255, 0.5);
              font-size: 0.85rem;
              font-weight: 300;
              line-height: 1.5;
            "
          >
            El futuro del lujo compacto.
          </p>
        </div>
      </article>

      <!-- ── CARD 2: Lanzamiento 246 — standard news ───────────── -->
      <article
        class="noticias-card-news flex flex-col"
        aria-label="Noticia: Lanzamiento Classer 246"
      >
        <!-- Image -->
        <div class="overflow-hidden rounded-lg" style="line-height: 0;">
          <img
            src="https://placehold.co/400x200"
            alt="Lanzamiento Classer 246 en el agua"
            width="400"
            height="200"
            class="w-full object-cover"
            style="height: 200px; display: block;"
            loading="lazy"
          />
        </div>

        <!-- Text area -->
        <div style="padding-top: 1rem;">

          <!-- Tag + Date row -->
          <div class="flex items-center gap-3">
            <span
              style="
                color: #1e90d4;
                font-size: 0.65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                line-height: 1;
              "
            >LANZAMIENTO</span>
            <span style="color: #cccccc; font-size: 0.65rem; line-height: 1;" aria-hidden="true">·</span>
            <span
              style="
                color: #999999;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                line-height: 1;
              "
            >MARZO, 2025</span>
          </div>

          <!-- Article title -->
          <h3
            style="
              color: #0a0e1a;
              font-size: 1.1rem;
              font-weight: 600;
              line-height: 1.3;
              margin-top: 0.5rem;
            "
          >
            Lanzamiento 246
          </h3>
        </div>
      </article>

      <!-- ── CARD 3: Nuevo Astillero Fuentes — standard news ────── -->
      <article
        class="noticias-card-news flex flex-col"
        aria-label="Noticia: Nuevo Astillero Fuentes"
      >
        <!-- Image -->
        <div class="overflow-hidden rounded-lg" style="line-height: 0;">
          <img
            src="https://placehold.co/400x200"
            alt="Nuevo local comercial Astillero Fuentes"
            width="400"
            height="200"
            class="w-full object-cover"
            style="height: 200px; display: block;"
            loading="lazy"
          />
        </div>

        <!-- Text area -->
        <div style="padding-top: 1rem;">

          <!-- Tag + Date row -->
          <div class="flex items-center gap-3">
            <span
              style="
                color: #1e90d4;
                font-size: 0.65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                line-height: 1;
              "
            >NOTICIAS</span>
            <span style="color: #cccccc; font-size: 0.65rem; line-height: 1;" aria-hidden="true">·</span>
            <span
              style="
                color: #999999;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                line-height: 1;
              "
            >ENERO, 2025</span>
          </div>

          <!-- Article title -->
          <h3
            style="
              color: #0a0e1a;
              font-size: 1.1rem;
              font-weight: 600;
              line-height: 1.3;
              margin-top: 0.5rem;
            "
          >
            Nuevo Astillero Fuentes
          </h3>
        </div>
      </article>

    </div>
  </div>
</section>

<style>
  /* Desktop: 3 equal columns */
  .noticias-grid {
    grid-template-columns: 1fr 1fr 1fr;
  }

  /* Mobile: single column */
  @media (max-width: 767px) {
    .noticias-grid {
      grid-template-columns: 1fr;
    }
    .noticias-card-teaser {
      width: 100%;
    }
  }
</style>
