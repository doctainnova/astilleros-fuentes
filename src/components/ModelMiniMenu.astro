---
interface Props {
  modelName: string;
  activeTab?: string;
  brochure?: string;
}
const { modelName, activeTab = 'Especificaciones técnicas', brochure } = Astro.props;

// Clean name for display (strip "Classer" if present to follow image)
const cleanName = modelName.replace(/Classer\s+/i, '');

const tabs = [
  { label: 'Especificaciones técnicas', href: '#especificaciones' },
  { label: 'Exterior', href: '#exterior' },
  { label: 'Interior', href: '#interior' },
  { label: 'Galería', href: '#galeria' },
];
---

<div class="model-mini-menu flex justify-center py-6 md:py-10">
  <div class="bg-[#dcdcd8] rounded-full flex items-center shadow-xl overflow-x-auto no-scrollbar" style="width: fit-content; max-width: 95vw; padding: 6px 6px 6px 0;">
    
    <!-- Model Name Section -->
    <div class="flex items-center h-12" style="padding-left: 28px; padding-right: 24px; border-right: 1px solid rgba(0,0,0,0.12); flex-shrink: 0;">
      <span class="font-display font-black italic text-[#0d1222] whitespace-nowrap uppercase" style="font-size: clamp(1.4rem, 2.5vw, 2rem); letter-spacing: -0.04em;">
        {cleanName}
      </span>
    </div>

    <!-- Nav Links Section -->
    <nav class="flex items-center" style="padding: 0 36px; gap: 36px; flex-shrink: 0;">
      {tabs.map((tab) => (
        <a 
          href={tab.href}
          class={`text-[#0d1222] font-bold whitespace-nowrap transition-all duration-300 hover:text-black/50 ${activeTab === tab.label ? 'opacity-100' : 'opacity-60'}`}
          style="font-size: 0.875rem;"
        >
          {tab.label}
        </a>
      ))}
    </nav>

    <!-- Brochure Button Section -->
    <div class="hidden md:flex items-center" style="padding-right: 6px; flex-shrink: 0;">
      {brochure ? (
        <a
          href={brochure}
          download
          class="bg-[#00a3e0] hover:bg-[#008cc2] text-white font-bold uppercase rounded-full transition-all duration-300 whitespace-nowrap shadow-md hover:shadow-lg active:scale-95"
          style="font-size: 0.72rem; letter-spacing: 0.1em; padding: 14px 28px;"
        >
          Descargar brochure
        </a>
      ) : (
        <span
          class="bg-[#00a3e0]/40 text-white/60 font-bold uppercase rounded-full cursor-not-allowed"
          style="font-size: 0.72rem; letter-spacing: 0.1em; padding: 14px 28px;"
          title="Brochure no disponible"
        >
          Descargar brochure
        </span>
      )}
    </div>
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Mobile: reduce font sizes inside the pill */
  @media (max-width: 640px) {
    .model-mini-menu .ev-name {
      font-size: 1.1rem;
    }
  }
</style>
